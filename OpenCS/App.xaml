<Application x:Class="OpenCS.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OpenCS"
             xmlns:core="clr-namespace:CScore;assembly=CScore"
             xmlns:vm="clr-namespace:OpenCS.ViewModels"
             xmlns:conv="clr-namespace:OpenCS.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             StartupUri="MainWindow.xaml">
   <Application.Resources>
      <ResourceDictionary>
         <ResourceDictionary.MergedDictionaries>
             <ResourceDictionary Source="/Images/svg.xaml"/>
             <ResourceDictionary Source="Resources/Strings.en-US.xaml"/>
             <ResourceDictionary Source="Resources/Strings.ru-RU.xaml"/>
         </ResourceDictionary.MergedDictionaries>

         <DataTemplate DataType="{x:Type core:Fiber}">
            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
               <Image Source="/Images/volokno--32.png"/>
               <TextBlock Text="{Binding Num, StringFormat={}{0:D3}}" Margin="3,0,3,0"/>
               <TextBlock Text="| X:"/>
               <TextBlock Text="{Binding X, StringFormat={}{0:F4}}" />
               <TextBlock Text="{DynamicResource Unit_m}" Margin="0,0,3,0"/>
               <TextBlock Text="Y:"/>
               <TextBlock Text="{Binding Y, StringFormat={}{0:F4}}" />
               <TextBlock Text="{DynamicResource Unit_m}" Margin="0,0,3,0"/>
               <TextBlock Text="{DynamicResource Area}"/>
               <TextBlock Text="{Binding Astr}"/>
               <TextBlock Text="{DynamicResource Unit_cm2}"/>
               <TextBlock Text="{DynamicResource Superscript2}" FontSize="8" VerticalAlignment="Top"/>

            </StackPanel>
         </DataTemplate>
         
         <DataTemplate DataType="{x:Type core:CircleP}">
            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
               <Image Source="/Images/circle__32.png" Stretch="UniformToFill"/>
               <TextBlock Text="{Binding Num, StringFormat={}{0:D2}}" Margin="3,0,3,0"/>
               <TextBlock Text="| X:"/>
               <TextBlock Text="{Binding X, StringFormat={}{0:F4}}" Margin="3,0,3,0"/>
               <TextBlock Text="Y:"/>
               <TextBlock Text="{Binding Y, StringFormat={}{0:F4}}" Margin="3,0,3,0" />
               <TextBlock Text="{DynamicResource D_mm}"/>
               <TextBlock Text="{Binding Dstr}" Margin="3,0,3,0" />
               <TextBlock Text="{DynamicResource Unit_m}"/>
            </StackPanel>
         </DataTemplate>

         <DataTemplate DataType="{x:Type core:StressPoint}">
            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
               <Image Source="/Images/point--32.png"/>
               <TextBlock Text="{Binding Num, StringFormat={}{0:D3}}" Margin="3,0,3,0"/>
               <TextBlock Text="| X:"/>
               <TextBlock Text="{Binding X, StringFormat={}{0:F4}}" Margin="3,0,3,0"/>
               <TextBlock Text="Y:"/>
               <TextBlock Text="{Binding Y, StringFormat={}{0:F4}}" Margin="3,0,3,0"/>
               <TextBlock Text="{DynamicResource Unit_m}"/>
            </StackPanel>
         </DataTemplate>

         <DataTemplate  x:Key="ContourBig" DataType="{x:Type vm:ContourVM}">
            <Border BorderBrush="#BFC1C2" CornerRadius="7" BorderThickness="1">
               <StackPanel Margin="3">
                  <Image Source="{Binding DI}" Margin="3" Width="70" Height="70"/>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                     <TextBlock Text="{Binding Contour.Num, StringFormat={}{0:D2}}"/>
                     <TextBlock Text="  |  "/>
                     <TextBlock Text="{Binding Contour.Tag}" Foreground="Blue"/>
                     <TextBlock Text="  '"/>
                     <TextBlock Text="{Binding Contour.GeometrySet}" Foreground="DarkGreen"/>
                     <TextBlock Text="'"/>
                  </StackPanel>
               </StackPanel>
            </Border>
         </DataTemplate>

         <HierarchicalDataTemplate x:Key="ContourSmall" DataType="{x:Type vm:ContourVM}" ItemsSource="{Binding Points}">
            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
               <Image Source="/Images/contours__32.png"/>
               <TextBlock Text="{Binding Num, StringFormat={}{0:D2}}" Margin="5,0,0,0"/>
               <TextBlock Text="  |  "/>
               <TextBlock Text="{Binding Tag}" Foreground="Blue"/>
               <TextBlock Text="  '"/>
               <TextBlock Text="{Binding Contour.GeometrySet}" Foreground="DarkGreen"/>
               <TextBlock Text="'"/>
            </StackPanel>

            <HierarchicalDataTemplate.ItemTemplate>
               <DataTemplate DataType="{x:Type core:StressPoint}">
                  <ContentControl Content="{Binding}"/>
               </DataTemplate>
            </HierarchicalDataTemplate.ItemTemplate>
         </HierarchicalDataTemplate>

         <ContextMenu x:Key="RCRegionContextMenu">

            <MenuItem Header="{DynamicResource Change}" Command="{Binding EditRCFiberRegionCommand}">
               <MenuItem.Icon>
                  <Image Source="/Images/edit--32.png"/>
               </MenuItem.Icon>
            </MenuItem>

            <MenuItem Header="{DynamicResource Delete}" Command="{Binding DeleteRCFiberRegionCommand}">
               <MenuItem.Icon>
                  <Image Source="/Images/delete__32.png"/>
               </MenuItem.Icon>
            </MenuItem>

         </ContextMenu>


         <!-- MaterialArea type brushes -->
         <SolidColorBrush x:Key="AreaBrush_Concrete" Color="#3B82F6"/>
         <SolidColorBrush x:Key="AreaBrush_ReSteelF" Color="#F97316"/>
         <SolidColorBrush x:Key="AreaBrush_ReSteelU" Color="#EAB308"/>
         <SolidColorBrush x:Key="AreaBrush_Steel"    Color="#22C55E"/>
         <SolidColorBrush x:Key="AreaBrush_None"     Color="#9CA3AF"/>

         <!-- Area-type icon geometries (16x16) -->
         <Geometry x:Key="Icon_Concrete">M1,1 H15 V15 H1 Z</Geometry>
         <Geometry x:Key="Icon_ReSteelF">M3,8 a2,2 0 1,0 0.001,0 Z M8,8 a2,2 0 1,0 0.001,0 Z M13,8 a2,2 0 1,0 0.001,0 Z</Geometry>
         <Geometry x:Key="Icon_ReSteelU">M3,8 a2,2 0 1,0 0.001,0 Z M8,8 a2,2 0 1,0 0.001,0 Z M13,8 a2,2 0 1,0 0.001,0 Z</Geometry>
         <Geometry x:Key="Icon_Steel">M1,3 H15 V13 H1 Z M2,4 H14 V12 H2 Z</Geometry>

         <!-- Converters -->
         <conv:MatTypeToBrushConverter x:Key="MatTypeToBrushConverter"/>
         <conv:MatTypeToGeometryConverter x:Key="MatTypeToGeometryConverter"/>
         <conv:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
         <conv:NullableToListConverter x:Key="NullableToList"/>

         <sys:Double x:Key="AppFontSize">13</sys:Double>

         <Style x:Key="RibbonButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="2,0"/>
         </Style>

         <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
         </Style>

         <Style x:Key="IconButton25" TargetType="Button">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Width" Value="25"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
         </Style>

         <Style TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
         </Style>

         <Style TargetType="DataGridCell">
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
         </Style>

         <Style TargetType="MenuItem">
            <Setter Property="FontSize" Value="{StaticResource AppFontSize}"/>
         </Style>

         <Style TargetType="UserControl">
            <Setter Property="FontSize" Value="{StaticResource AppFontSize}"/>
         </Style>

         <Style TargetType="Window">
            <Setter Property="FontSize" Value="{StaticResource AppFontSize}"/>
         </Style>

         <Style TargetType="TreeView">
            <Setter Property="FontSize" Value="{StaticResource AppFontSize}"/>
         </Style>

         <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource AppFontSize}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
         </Style>

         <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="{StaticResource AppFontSize}"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
         </Style>

         <Style TargetType="TreeViewItem">
            <Setter Property="FontSize" Value="{StaticResource AppFontSize}"/>
            <Style.Resources>
               <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="FloralWhite"/>
               <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="LightBlue"/>
               <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
            </Style.Resources>
            <Style.Triggers>
               <Trigger Property="IsSelected" Value="True">
                  <Setter Property="Background" Value="FloralWhite"/>
                  <Setter Property="Foreground" Value="Black"/>
                  <Setter Property="BorderBrush" Value="LightGray"/>
                  <Setter Property="BorderThickness" Value="1"/>
               </Trigger>
            </Style.Triggers>
         </Style>

      </ResourceDictionary>
   </Application.Resources>
</Application>