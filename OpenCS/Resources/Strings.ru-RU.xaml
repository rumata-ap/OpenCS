   <system:String x:Key="CalcSettingsSp20GammaGFav">G — постоянная (благ.)</system:String>
   <system:String x:Key="CalcSettingsSp20GammaL">L — длительная</system:String>
   <system:String x:Key="CalcSettingsSp20GammaQ">Q — кратковременная</system:String>
   <system:String x:Key="CalcSettingsSp20GammaA">A — особая</system:String>
   <system:String x:Key="CalcSettingsSp20GammaTip">Используются в комбинаторике СП20, если γf не задан явно в наборе усилий</system:String>
   <system:String x:Key="BatchParallel_Label">Параллельный расчёт (клонирование сечения на поток)</system:String>
