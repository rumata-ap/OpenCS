<Window x:Class="OpenCS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:OpenCS"
        xmlns:views="clr-namespace:OpenCS.Views"
        xmlns:core="clr-namespace:CScore;assembly=CScore"
        xmlns:fire="clr-namespace:CScore.Fire.Entities;assembly=CScore.Fire"
        xmlns:col="clr-namespace:System.Collections;assembly=mscorlib"
        xmlns:vm="clr-namespace:OpenCS.ViewModels"
        mc:Ignorable="d"
        Title="{Binding ProjectTitle}" WindowStartupLocation="CenterScreen" Height="850" Width="1500"
        Closing="Window_Closing">


   <Window.Resources>
      <ResourceDictionary>
         <HierarchicalDataTemplate DataType="{x:Type core:Material}" ItemsSource="{Binding MaterialChars}">
            <StackPanel Orientation="Horizontal" Margin="1">
               <Image Source="/Images/material1__32.png" Margin="0,0,5,0" Stretch="None"/>
               <TextBlock Text="{Binding Num}"/>
               <TextBlock Text=":"/>
               <TextBlock Text="{Binding Tag}" Margin="5,0,5,0"/>
               <TextBlock Text="|"/>
               <TextBlock Text="{Binding Description}" Margin="5,0,0,0" Foreground="Gray" />

               <StackPanel.ContextMenu>
                  <ContextMenu>
                     <MenuItem Header="{DynamicResource Add}" Click="ConcreteAdd_Click">
                        <MenuItem.Icon>
                           <Image Source="/Images/add__32.png"/>
                        </MenuItem.Icon>
                     </MenuItem>
                     <MenuItem Header="{DynamicResource Delete}" Click="ConcreteDel_Click">
                        <MenuItem.Icon>
                           <Image Source="/Images/delete--32.png"/>
                        </MenuItem.Icon>
                     </MenuItem>
                  </ContextMenu>
               </StackPanel.ContextMenu>
            </StackPanel>

            <HierarchicalDataTemplate.ItemTemplate>
               <DataTemplate>
                  <StackPanel Orientation="Horizontal" Margin="1">
                     <Image Source="/Images/diagramma--32.png"/>
                     <TextBlock Text=" ' "/>
                     <TextBlock Text="{Binding TypeCalc}"/>
                     <TextBlock Text=" '"/>
                  </StackPanel>
               </DataTemplate>
            </HierarchicalDataTemplate.ItemTemplate>
          </HierarchicalDataTemplate>

           <HierarchicalDataTemplate DataType="{x:Type core:Diagramm}">
              <StackPanel Orientation="Horizontal" Margin="1">
                 <StackPanel.ContextMenu>
                    <ContextMenu>
                       <MenuItem Header="{DynamicResource Delete}" Click="DeleteDiagram_Click">
                          <MenuItem.Icon>
                             <Image Source="/Images/delete--32.png"/>
                          </MenuItem.Icon>
                       </MenuItem>
                    </ContextMenu>
                 </StackPanel.ContextMenu>
                 <Image Source="/Images/diagramma--32.png"/>
                 <TextBlock Text="{Binding Tag}" Margin="5,0,0,0"/>
                 <TextBlock Text="  [" Foreground="Gray"/>
                 <TextBlock Text="{Binding CalcType}" Foreground="Gray"/>
                 <TextBlock Text="]" Foreground="Gray"/>
              </StackPanel>
           </HierarchicalDataTemplate>
       </ResourceDictionary>
    </Window.Resources>

   <Grid x:Name="masterGrid" ShowGridLines="False">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
         <RowDefinition Height="*"></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
         <RowDefinition Height="0.2*"></RowDefinition>
         <RowDefinition Height="Auto"></RowDefinition>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="0.275*"></ColumnDefinition>
         <ColumnDefinition Width="Auto"></ColumnDefinition>
         <ColumnDefinition Width="*"></ColumnDefinition>
      </Grid.ColumnDefinitions>

      <GridSplitter Grid.Column="1" Grid.Row="2" Grid.RowSpan="3"  ShowsPreview="True" Width="4"
        HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

      <GridSplitter Grid.Column="2" Grid.Row="3"  ShowsPreview="True" Height="4"
        HorizontalAlignment="Stretch" VerticalAlignment="Center" />

       <ListView x:Name="LoggerListBox" Grid.Column="2" Grid.Row="4" SelectionMode="Single" FontSize="11"
                  ItemsSource="{Binding LogService.LogEntries}">
          <ListView.ItemTemplate>
             <DataTemplate>
                <TextBlock Text="{Binding FormattedMessage}">
                   <TextBlock.Style>
                      <Style TargetType="TextBlock">
                         <Setter Property="Foreground" Value="Blue"/>
                         <Style.Triggers>
                            <DataTrigger Binding="{Binding Level}" Value="Error">
                               <Setter Property="Foreground" Value="Red"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                               <Setter Property="Foreground" Value="Gray"/>
                            </DataTrigger>
                         </Style.Triggers>
                      </Style>
                   </TextBlock.Style>
                </TextBlock>
             </DataTemplate>
          </ListView.ItemTemplate>
           <ListView.ContextMenu>
              <ContextMenu>
                 <MenuItem Header="{DynamicResource Copy}" Click="CopyLogEntry_Click" />
              </ContextMenu>
           </ListView.ContextMenu>
       </ListView>


      <Menu Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="3" FontSize="14" >
         <MenuItem Header="{DynamicResource File}" Margin="3">
            <MenuItem Header="{DynamicResource New}" Command="{Binding NewProjectCommand}" />
            <MenuItem Header="{DynamicResource Open}" Command="{Binding OpenProjectCommand}" />
            <Separator />
            <MenuItem Header="{DynamicResource Save}" Command="{Binding SaveProjectCommand}" />
            <MenuItem Header="{DynamicResource SaveAs}" Command="{Binding SaveAsProjectCommand}" />
            <Separator />
            <MenuItem Header="{DynamicResource Settings}" Command="{Binding OpenSettingsCommand}" />
            <Separator />
            <MenuItem Header="{DynamicResource Exit}" Command="{Binding ExitCommand}" />
         </MenuItem>
         <MenuItem Header="{DynamicResource Edit}" ></MenuItem>
         <MenuItem Header="{DynamicResource View}" >
            <MenuItem Header="{DynamicResource Language}">
               <MenuItem Header="{DynamicResource Russian}" Command="{Binding SetLanguageCommand}" CommandParameter="0" />
               <MenuItem Header="{DynamicResource English}" Command="{Binding SetLanguageCommand}" CommandParameter="1" />
            </MenuItem>
         </MenuItem>
      </Menu>

      <ToolBarTray Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
         <ToolBar>
            <!-- Файл -->
            <!-- Новый проект: светло-голубой лист + зелёный плюс -->
            <Button Command="{Binding NewProjectCommand}" ToolTip="{DynamicResource New}" Padding="4,3">
               <Viewbox Width="18" Height="18">
                  <Grid Width="24" Height="24">
                     <!-- Лист бумаги -->
                     <Path Fill="#DBEAFE" Stroke="#2563EB" StrokeThickness="1"
                           Data="M14 2H6C4.89 2 4 2.89 4 4V20C4 21.11 4.89 22 6 22H18C19.11 22 20 21.11 20 20V8L14 2Z"/>
                     <!-- Загнутый уголок -->
                     <Path Fill="#3B82F6"
                           Data="M13 3.5L18.5 9H13V3.5Z"/>
                     <!-- Горизонтальные строки-декор -->
                     <Path Fill="#2563EB"
                           Data="M7 12H12V13.5H7ZM7 15H11V16.5H7Z"/>
                     <!-- Зелёный плюс (Новый) -->
                     <Path Fill="#16A34A"
                           Data="M11 11H9V13H11V15H13V13H15V11H13V9H11V11Z"/>
                  </Grid>
               </Viewbox>
            </Button>
            <!-- Открыть: двухтоновая янтарная папка -->
            <Button Command="{Binding OpenProjectCommand}" ToolTip="{DynamicResource Open}" Padding="4,3">
               <Viewbox Width="18" Height="18">
                  <Grid Width="24" Height="24">
                     <!-- Задняя стенка папки (тёмнее) -->
                     <Path Fill="#D97706" Stroke="#92400E" StrokeThickness="1"
                           Data="M10 4H4A2 2 0 0 0 2 6V18A2 2 0 0 0 4 20H20A2 2 0 0 0 22 18V8A2 2 0 0 0 20 6H12L10 4Z"/>
                     <!-- Передняя стенка (светлее) -->
                     <Path Fill="#FCD34D" Stroke="#92400E" StrokeThickness="1"
                           Data="M2 10V18C2 19.11 2.89 20 4 20H20C21.11 20 22 19.11 22 18V10H2Z"/>
                     <!-- Белые листы внутри -->
                     <Path Fill="White" Opacity="0.75"
                           Data="M6 12H18V17H6V12Z"/>
                     <!-- Тонкие линии листов -->
                     <Path Fill="#FDE68A"
                           Data="M6 13.5H18V14H6ZM6 15H15V15.5H6Z"/>
                  </Grid>
               </Viewbox>
            </Button>
            <!-- Сохранить: синяя дискета с белым ярлыком -->
            <Button Command="{Binding SaveProjectCommand}" ToolTip="{DynamicResource Save}" Padding="4,3">
               <Viewbox Width="18" Height="18">
                  <Grid Width="24" Height="24">
                     <!-- Корпус дискеты -->
                     <Path Fill="#2563EB"
                           Data="M17 3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V7L17 3Z"/>
                     <!-- Белый ярлык -->
                     <Path Fill="White" Opacity="0.92"
                           Data="M6 4H15V10H6V4Z"/>
                     <!-- Строчки на ярлыке -->
                     <Path Fill="#93C5FD"
                           Data="M8 5.5H13V6.5H8ZM8 7.5H11V8.5H8Z"/>
                     <!-- Диск (светло-голубой круг) -->
                     <Path Fill="#BFDBFE"
                           Data="M12 12C10.34 12 9 13.34 9 15S10.34 18 12 18 15 16.66 15 15 13.66 12 12 12Z"/>
                     <!-- Отверстие диска -->
                     <Path Fill="#1D4ED8"
                           Data="M12 13.5C11.17 13.5 10.5 14.17 10.5 15S11.17 16.5 12 16.5 13.5 15.83 13.5 15 12.83 13.5 12 13.5Z"/>
                  </Grid>
               </Viewbox>
            </Button>
            <!-- Сохранить как: оранжевая стрелка-скачать (выбор места) -->
            <Button Command="{Binding SaveAsProjectCommand}" ToolTip="{DynamicResource SaveAs}" Padding="4,3">
               <Viewbox Width="18" Height="18">
                  <Grid Width="24" Height="24">
                     <!-- Горизонтальная полоса-«стол» -->
                     <Path Fill="#EA580C"
                           Data="M3 19H21V21H3V19Z"/>
                     <!-- Стрелка вниз (сохранить в выбранное место) -->
                     <Path Fill="#F97316"
                           Data="M15 3H9V11H5L12 18L19 11H15V3Z"/>
                  </Grid>
               </Viewbox>
            </Button>
            <Separator/>
            <!-- Геометрия -->
            <Button Command="{Binding FromDxfCommand}" ToolTip="{DynamicResource FromDxf}" Padding="5,3">
               <Image Source="{StaticResource di_dxf_file_xaml}" Width="16" Height="16"/>
            </Button>
            <Button Command="{Binding NewContourCommand}" ToolTip="{DynamicResource TipNewContour}" Padding="5,3">
               <Viewbox Width="16" Height="16">
                  <Path Fill="#2563EB" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/>
               </Viewbox>
            </Button>
            <Button Command="{Binding DelContourCommand}" ToolTip="{DynamicResource TipDelContour}" Padding="5,3">
               <Viewbox Width="16" Height="16">
                  <Path Fill="#DC2626" Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
               </Viewbox>
            </Button>
            <Separator/>
            <!-- Материалы -->
            <Button Command="{Binding NewMaterialCommand}" ToolTip="{DynamicResource TipNewMaterial}" Padding="5,3">
               <Path Width="16" Height="16" Stretch="Uniform"
                     Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                     Data="M19 13H13V19H11V13H5V11H11V5H13V11H19V13Z"/>
            </Button>
            <Button Command="{Binding DelMaterialCommand}" ToolTip="{DynamicResource TipDelMaterial}" Padding="5,3">
               <Path Width="16" Height="16" Stretch="Uniform"
                     Fill="#CC3333"
                     Data="M9 3V4H4V6H5V19C5 20.1 5.9 21 7 21H17C18.1 21 19 20.1 19 19V6H20V4H15V3H9M7 6H17V19H7V6M9 8V17H11V8H9M13 8V17H15V8H13Z"/>
            </Button>
            <Separator/>
            <!-- Настройки -->
            <Button Command="{Binding OpenSettingsCommand}" ToolTip="{DynamicResource Settings}" Padding="5,3">
               <Path Width="16" Height="16" Stretch="Uniform"
                     Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                     Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
            </Button>
         </ToolBar>
      </ToolBarTray>

      <GroupBox Grid.Column="0" Grid.Row="2" Grid.RowSpan="3" Margin="4"
                Header="{Binding ProjectFileName}">
      <TreeView x:Name="structureTree" Margin="4,2" BorderThickness="0" SelectedItemChanged="structureTree_SelectedItemChanged">

               <TreeViewItem x:Name="geometryNode">
                  <TreeViewItem.Header>
                     <StackPanel Orientation="Horizontal" Margin="2">
                        <Image Source="/Images/geometry__32.png"/>
                        <TextBlock Text="{DynamicResource Geometry}" Margin="5,0,0,0" FontWeight="Bold"/>
                     </StackPanel>
                  </TreeViewItem.Header>

                  <TreeViewItem.ContextMenu>
                     <ContextMenu>
                        <MenuItem Header="{DynamicResource FromDxf}" Command="{Binding FromDxfCommand}">
                           <MenuItem.Icon>
                              <Image Source="{StaticResource di_dxf_file_xaml}" />
                           </MenuItem.Icon>
                        </MenuItem>
                     </ContextMenu>
                  </TreeViewItem.ContextMenu>

                  <TreeViewItem x:Name="CirclesTreeItem" ItemsSource="{Binding CirclesLive}">
                     <TreeViewItem.Header>
                        <StackPanel Orientation="Horizontal" Margin="2">
                           <Image Source="/Images/circles__32.png"/>
                           <TextBlock Text="{DynamicResource Circles}" Margin="5,0,0,0"/>
                        </StackPanel>
                     </TreeViewItem.Header>

                     <TreeViewItem.ContextMenu>
                        <ContextMenu>
                           <MenuItem Header="{DynamicResource FromDxf}" Command="{Binding ImportCirclesFromDxfCommand}">
                              <MenuItem.Icon>
                                 <Image Source="{StaticResource di_dxf_file_xaml}"/>
                              </MenuItem.Icon>
                           </MenuItem>
                           <MenuItem Header="{DynamicResource ToDxf}" Command="{Binding ExportCirclesToDxfCommand}">
                              <MenuItem.Icon>
                                 <Image Source="{StaticResource di_dxf_file_xaml}"/>
                              </MenuItem.Icon>
                           </MenuItem>
                           <Separator/>
                           <MenuItem Header="{DynamicResource FromCsv}" Command="{Binding ImportCirclesFromCsvCommand}">
                              <MenuItem.Icon>
                                 <Image Source="{StaticResource di_to_csv_xaml}"/>
                              </MenuItem.Icon>
                           </MenuItem>
                           <MenuItem Header="{DynamicResource ToCsv}" Command="{Binding ExportCirclesToCsvCommand}">
                              <MenuItem.Icon>
                                 <Image Source="{StaticResource di_from_csv_xaml}"/>
                              </MenuItem.Icon>
                           </MenuItem>
                        </ContextMenu>
                     </TreeViewItem.ContextMenu>

                  </TreeViewItem>

                  <TreeViewItem x:Name="ContoursTreeItem" ItemsSource="{Binding ContoursLive}" ItemTemplate="{StaticResource ContourSmall}">
                     <TreeViewItem.Header>
                        <StackPanel Orientation="Horizontal" Margin="2">
                           <Image Source="/Images/contours__32.png"/>
                           <TextBlock Text="{DynamicResource Contours}" Margin="5,0,0,0"/>
                        </StackPanel>
                     </TreeViewItem.Header>

                     <TreeViewItem.ContextMenu>
                        <ContextMenu>
                           <MenuItem Header="{DynamicResource FromDxf}" Command="{Binding ImportContoursFromDxfCommand}">
                              <MenuItem.Icon>
                                 <Image Source="{StaticResource di_dxf_file_xaml}" />
                              </MenuItem.Icon>
                           </MenuItem>
                           <MenuItem Header="{DynamicResource Create}" Command="{Binding NewContourCommand}">
                              <MenuItem.Icon>
                                 <Viewbox Width="16" Height="16">
                                    <Path Fill="#2563EB" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/>
                                 </Viewbox>
                              </MenuItem.Icon>
                           </MenuItem>
                           <MenuItem Header="{DynamicResource Delete}" Command="{Binding DelContourCommand}">
                              <MenuItem.Icon>
                                 <Viewbox Width="16" Height="16">
                                    <Path Fill="#DC2626" Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                                 </Viewbox>
                              </MenuItem.Icon>
                           </MenuItem>
                        </ContextMenu>
                     </TreeViewItem.ContextMenu>

                  </TreeViewItem>

               </TreeViewItem>

               <TreeViewItem x:Name="materialNode">
                  <TreeViewItem.Header>
                     <StackPanel Orientation="Horizontal" Margin="2">
                        <Image Source="/Images/material1__32.png"/>
                        <TextBlock Text="{DynamicResource Materials}" Margin="5,0,0,0" FontWeight="Bold"/>
                     </StackPanel>
                  </TreeViewItem.Header>

                  <TreeViewItem.ContextMenu>
                     <ContextMenu>
                        <MenuItem Header="{DynamicResource Add}" Command="{Binding NewMaterialCommand}">
                           <MenuItem.Icon>
                              <Image Source="/Images/add__32.png" />
                           </MenuItem.Icon>
                        </MenuItem>
                     </ContextMenu>
                  </TreeViewItem.ContextMenu>

                  <TreeViewItem x:Name="concreteNode" ItemsSource="{Binding Concretes}">
                     <TreeViewItem.Header>
                        <StackPanel Orientation="Horizontal" Margin="2">
                           <Image Source="/Images/kamni_wouahfq6r5gi__32.png"/>
                           <TextBlock Text="{DynamicResource Concrete}" Margin="5,0,0,0"/>
                        </StackPanel>
                     </TreeViewItem.Header>
                  </TreeViewItem>

                  <TreeViewItem x:Name="rfsteelNode" ItemsSource="{Binding Armatures}">
                     <TreeViewItem.Header>
                        <StackPanel Orientation="Horizontal" Margin="2">
                           <Image Source="/Images/armarura__32.png"/>
                           <TextBlock Text="{DynamicResource Reinforcement}" Margin="5,0,0,0"/>
                        </StackPanel>
                     </TreeViewItem.Header>
                  </TreeViewItem>

                   <TreeViewItem x:Name="steelNode" ItemsSource="{Binding Steels}">
                      <TreeViewItem.Header>
                         <StackPanel Orientation="Horizontal" Margin="2">
                            <Image Source="/Images/steel_3rbuwfklgl3w__32.png"/>
                            <TextBlock Text="{DynamicResource StructuralSteel}" Margin="5,0,0,0"/>
                         </StackPanel>
                      </TreeViewItem.Header>
                   </TreeViewItem>

                   <TreeViewItem x:Name="diagramNode" ItemsSource="{Binding DiagramsLive}">
                      <TreeViewItem.Header>
                         <StackPanel Orientation="Horizontal" Margin="2">
                            <Image Source="/Images/diagramma--32.png"/>
                            <TextBlock Text="{DynamicResource Diagrams}" Margin="5,0,5,0" FontWeight="Bold"/>
                            <Button Content="+" Width="22" Height="22" Padding="0"
                                    FontWeight="Bold" FontSize="13"
                                    Command="{Binding DataContext.AddDiagramCommand,
                                              RelativeSource={RelativeSource AncestorType=TreeView}}"
                                    ToolTip="{DynamicResource AddDiagramTooltip}"
                                    Style="{StaticResource IconButton25}"/>
                         </StackPanel>
                      </TreeViewItem.Header>
                      <TreeViewItem.ContextMenu>
                         <ContextMenu>
                            <MenuItem Header="{DynamicResource DeleteAll}" Click="DeleteAllDiagrams_Click">
                               <MenuItem.Icon>
                                  <Image Source="/Images/delete--32.png"/>
                               </MenuItem.Icon>
                            </MenuItem>
                         </ContextMenu>
                      </TreeViewItem.ContextMenu>
                   </TreeViewItem>
                </TreeViewItem>

               <!-- Материальные области -->
               <TreeViewItem x:Name="RegionsNode" IsExpanded="True">
                  <TreeViewItem.Header>
                     <StackPanel Orientation="Horizontal" Margin="2">
                        <Image Source="/Images/shape-design--32.png" Stretch="None"/>
                        <TextBlock Text="{DynamicResource MaterialAreas}" Margin="5,0,0,0" FontWeight="Bold"/>
                     </StackPanel>
                  </TreeViewItem.Header>

                  <!-- Подузел: Области (Region) -->
                  <TreeViewItem x:Name="AreasNode" ItemsSource="{Binding AreasLive}" IsExpanded="True">
                     <TreeViewItem.Header>
                        <StackPanel Orientation="Horizontal" Margin="2">
                           <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0"
                                 Fill="#3B82F6" Data="M1,1 H15 V15 H1 Z"/>
                           <TextBlock Text="{DynamicResource Areas}"/>
                        </StackPanel>
                     </TreeViewItem.Header>
                     <TreeViewItem.ContextMenu>
                        <ContextMenu>
                           <MenuItem Header="{DynamicResource NewArea}"
                                     Command="{Binding NewAreaCommand}"/>
                           <MenuItem Header="{DynamicResource DeleteArea}"
                                     Command="{Binding DeleteMaterialAreaCommand}"/>
                           <Separator/>
                           <MenuItem Header="{DynamicResource MenuFromDxfMaterialArea}"
                                     Command="{Binding FromDxfCommand}">
                              <MenuItem.Icon>
                                 <Image Source="{StaticResource di_dxf_file_xaml}"/>
                              </MenuItem.Icon>
                           </MenuItem>
                        </ContextMenu>
                     </TreeViewItem.ContextMenu>
                     <TreeViewItem.ItemTemplate>
                        <DataTemplate DataType="{x:Type core:MaterialArea}">
                           <StackPanel Orientation="Horizontal" Margin="1">
                              <Path Width="13" Height="13" Margin="0,0,4,0" Stretch="Uniform"
                                    Fill="{Binding Material.Type, Converter={StaticResource MatTypeToBrushConverter}}"
                                    Data="{Binding Material.Type, Converter={StaticResource MatTypeToGeometryConverter}}"/>
                              <TextBlock Text="{Binding Tag}" VerticalAlignment="Center"/>
                           </StackPanel>
                        </DataTemplate>
                     </TreeViewItem.ItemTemplate>
                  </TreeViewItem>

                  <!-- Подузел: Группы арматуры (RebarGroup) -->
                  <TreeViewItem x:Name="RebarGroupsNode" ItemsSource="{Binding RebarGroupsLive}" IsExpanded="True">
                     <TreeViewItem.Header>
                        <StackPanel Orientation="Horizontal" Margin="2">
                           <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0"
                                 Fill="#F97316"
                                 Data="M3,8 A2,2 0 1,0 3.001,8 Z M8,8 A2,2 0 1,0 8.001,8 Z M13,8 A2,2 0 1,0 13.001,8 Z"/>
                           <TextBlock Text="{DynamicResource RebarGroups}"/>
                        </StackPanel>
                     </TreeViewItem.Header>
                     <TreeViewItem.ContextMenu>
                        <ContextMenu>
                           <MenuItem Header="{DynamicResource NewArea}"
                                     Command="{Binding NewRebarGroupCommand}"/>
                           <MenuItem Header="{DynamicResource DeleteArea}"
                                     Command="{Binding DeleteMaterialAreaCommand}"/>
                           <Separator/>
                           <MenuItem Header="{DynamicResource MenuFromDxfMaterialArea}"
                                     Command="{Binding FromDxfCommand}">
                              <MenuItem.Icon>
                                 <Image Source="{StaticResource di_dxf_file_xaml}"/>
                              </MenuItem.Icon>
                           </MenuItem>
                        </ContextMenu>
                     </TreeViewItem.ContextMenu>
                     <TreeViewItem.ItemTemplate>
                        <DataTemplate DataType="{x:Type core:MaterialArea}">
                           <StackPanel Orientation="Horizontal" Margin="1">
                              <Path Width="13" Height="13" Margin="0,0,4,0" Stretch="Uniform"
                                    Fill="{Binding Material.Type, Converter={StaticResource MatTypeToBrushConverter}}"
                                    Data="M3,8 A2,2 0 1,0 3.001,8 Z M8,8 A2,2 0 1,0 8.001,8 Z M13,8 A2,2 0 1,0 13.001,8 Z"/>
                              <TextBlock Text="{Binding Tag}" VerticalAlignment="Center"/>
                           </StackPanel>
                        </DataTemplate>
                     </TreeViewItem.ItemTemplate>
                  </TreeViewItem>

                  <!-- Подузел: Одиночные стержни (SingleBar) -->
                  <TreeViewItem x:Name="SingleBarsNode" ItemsSource="{Binding SingleBarsLive}" IsExpanded="True">
                     <TreeViewItem.Header>
                        <StackPanel Orientation="Horizontal" Margin="2">
                           <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0"
                                 Fill="#F97316"
                                 Data="M8,8 A3,3 0 1,0 8.001,8 Z"/>
                           <TextBlock Text="{DynamicResource SingleBars}"/>
                        </StackPanel>
                     </TreeViewItem.Header>
                     <TreeViewItem.ContextMenu>
                        <ContextMenu>
                           <MenuItem Header="{DynamicResource NewArea}"
                                     Command="{Binding NewSingleBarCommand}"/>
                           <MenuItem Header="{DynamicResource DeleteArea}"
                                     Command="{Binding DeleteMaterialAreaCommand}"/>
                           <Separator/>
                           <MenuItem Header="{DynamicResource MenuFromDxfMaterialArea}"
                                     Command="{Binding FromDxfCommand}">
                              <MenuItem.Icon>
                                 <Image Source="{StaticResource di_dxf_file_xaml}"/>
                              </MenuItem.Icon>
                           </MenuItem>
                        </ContextMenu>
                     </TreeViewItem.ContextMenu>
                     <TreeViewItem.ItemTemplate>
                        <DataTemplate DataType="{x:Type core:MaterialArea}">
                           <StackPanel Orientation="Horizontal" Margin="1">
                              <Path Width="13" Height="13" Margin="0,0,4,0" Stretch="Uniform"
                                    Fill="{Binding Material.Type, Converter={StaticResource MatTypeToBrushConverter}}"
                                    Data="M8,8 A3,3 0 1,0 8.001,8 Z"/>
                              <TextBlock Text="{Binding Tag}" VerticalAlignment="Center"/>
                           </StackPanel>
                        </DataTemplate>
                     </TreeViewItem.ItemTemplate>
                  </TreeViewItem>

               </TreeViewItem>



               <!-- Поперечные сечения -->
               <TreeViewItem x:Name="crosssectNode"
                             ItemsSource="{Binding SectionTreeItems}"
                             IsExpanded="True">
                  <TreeViewItem.Header>
                     <StackPanel Orientation="Horizontal" Margin="2">
                        <Image Source="/Images/crossect--32.png"/>
                        <TextBlock Text="{DynamicResource CrossSections}" Margin="5,0,0,0" FontWeight="Bold"/>
                     </StackPanel>
                  </TreeViewItem.Header>
                  <TreeViewItem.ContextMenu>
                     <ContextMenu>
                        <MenuItem Header="{DynamicResource NewCrossSection}"
                                  Command="{Binding NewCrossSectionCommand}"/>
                        <MenuItem Header="{DynamicResource EditCrossSection}"
                                  Command="{Binding EditCrossSectionCommand}"/>
                        <MenuItem Header="{DynamicResource DeleteCrossSection}"
                                  Command="{Binding DeleteCrossSectionCommand}"/>
                     </ContextMenu>
                  </TreeViewItem.ContextMenu>
                  <TreeViewItem.Resources>
                     <!-- Обычное сечение: иконка + дочерние области -->
                     <HierarchicalDataTemplate DataType="{x:Type core:CrossSection}"
                                               ItemsSource="{Binding Areas}">
                        <StackPanel Orientation="Horizontal">
                           <Path Width="14" Height="14" Margin="0,0,4,0" Stretch="Uniform"
                                 Fill="SteelBlue" Data="M1,1 H7 L15,8 L7,15 H1 Z"/>
                           <TextBlock Text="{Binding Tag}"/>
                        </StackPanel>
                        <HierarchicalDataTemplate.ItemTemplate>
                           <DataTemplate DataType="{x:Type core:MaterialArea}">
                              <StackPanel Orientation="Horizontal">
                                 <Path Width="12" Height="12" Margin="0,0,4,0" Stretch="Uniform"
                                       Fill="{Binding Material.Type, Converter={StaticResource MatTypeToBrushConverter}}"
                                       Data="{Binding Material.Type, Converter={StaticResource MatTypeToGeometryConverter}}"/>
                                 <TextBlock Text="{Binding Tag}"/>
                              </StackPanel>
                           </DataTemplate>
                        </HierarchicalDataTemplate.ItemTemplate>
                     </HierarchicalDataTemplate>

                     <!-- Группа «Усиление»: папка с двухстадийными сечениями -->
                     <HierarchicalDataTemplate DataType="{x:Type local:SectionTreeGroup}"
                                               ItemsSource="{Binding Items}">
                        <StackPanel Orientation="Horizontal" Margin="2"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                           <StackPanel.ContextMenu>
                              <ContextMenu>
                                 <MenuItem Header="{DynamicResource NewTwoStageSection}"
                                           Command="{Binding PlacementTarget.Tag.NewTwoStageSectionCommand,
                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                 <MenuItem Header="{DynamicResource DeleteCrossSection}"
                                           Command="{Binding PlacementTarget.Tag.DeleteCrossSectionCommand,
                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                              </ContextMenu>
                           </StackPanel.ContextMenu>
                           <!-- Иконка «Усиление»: две зеркальные копии иконки простого
                                сечения в двух цветах (исходное + усиливающее сечение) -->
                           <Viewbox Width="14" Height="14" Margin="0,0,4,0">
                              <Canvas Width="16" Height="16">
                                 <Path Fill="SteelBlue"  Data="M0.5,1 H3.5 L7.5,8 L3.5,15 H0.5 Z"/>
                                 <Path Fill="DarkOrange" Data="M15.5,1 H12.5 L8.5,8 L12.5,15 H15.5 Z"/>
                              </Canvas>
                           </Viewbox>
                           <TextBlock Text="{DynamicResource TwoStageSections}"/>
                        </StackPanel>
                        <HierarchicalDataTemplate.ItemTemplate>
                           <DataTemplate DataType="{x:Type core:TwoStageSection}">
                              <StackPanel Orientation="Horizontal">
                                 <!-- Иконка двухстадийного сечения: две зеркальные копии
                                      иконки простого сечения в двух цветах -->
                                 <Viewbox Width="14" Height="14" Margin="0,0,4,0">
                                    <Canvas Width="16" Height="16">
                                       <Path Fill="SteelBlue"  Data="M0.5,1 H3.5 L7.5,8 L3.5,15 H0.5 Z"/>
                                       <Path Fill="DarkOrange" Data="M15.5,1 H12.5 L8.5,8 L12.5,15 H15.5 Z"/>
                                    </Canvas>
                                 </Viewbox>
                                 <TextBlock Text="{Binding Tag}"/>
                              </StackPanel>
                           </DataTemplate>
                        </HierarchicalDataTemplate.ItemTemplate>
                     </HierarchicalDataTemplate>

                     <!-- Группа «Пластины»: папка с PlateSection -->
                     <HierarchicalDataTemplate DataType="{x:Type local:PlateSectionTreeGroup}"
                                               ItemsSource="{Binding Items}">
                        <StackPanel Orientation="Horizontal" Margin="2"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                           <StackPanel.ContextMenu>
                              <ContextMenu>
                                 <MenuItem Header="{DynamicResource NewPlateSection}"
                                           Command="{Binding PlacementTarget.Tag.NewPlateSectionCommand,
                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                 <MenuItem Header="{DynamicResource DeletePlateSection}"
                                           Command="{Binding PlacementTarget.Tag.DeletePlateSectionCommand,
                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                              </ContextMenu>
                           </StackPanel.ContextMenu>
                           <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0"
                                 Fill="SlateGray"
                                 Data="M1,2 H15 V14 H1 Z M1,6 H15 M1,10 H15"/>
                           <TextBlock Text="{DynamicResource PlateSections}"/>
                        </StackPanel>
                        <HierarchicalDataTemplate.ItemTemplate>
                           <DataTemplate DataType="{x:Type core:PlateSection}">
                              <StackPanel Orientation="Horizontal" Margin="1"
                                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                 <StackPanel.ContextMenu>
                                    <ContextMenu>
                                       <MenuItem Header="{DynamicResource DuplicatePlateSection}"
                                                 Command="{Binding PlacementTarget.Tag.DuplicatePlateSectionCommand,
                                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                 CommandParameter="{Binding PlacementTarget.DataContext,
                                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                       <Separator/>
                                       <MenuItem Header="{DynamicResource DeletePlateSectionItem}"
                                                 Command="{Binding PlacementTarget.Tag.DeletePlateSectionCommand,
                                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                 CommandParameter="{Binding PlacementTarget.DataContext,
                                                                   RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                 </StackPanel.ContextMenu>
                                 <Path Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0"
                                       Fill="SlateGray"
                                       Data="M1,2 H15 V14 H1 Z M1,6 H15 M1,10 H15"/>
                                 <TextBlock Text="{Binding Tag}" VerticalAlignment="Center"/>
                                 <TextBlock Text=" h=" Foreground="Gray"/>
                                 <TextBlock Text="{Binding H, StringFormat={}{0:G3}}" Foreground="Gray"/>
                                 <TextBlock Text=" м" Foreground="Gray"/>
                              </StackPanel>
                           </DataTemplate>
                        </HierarchicalDataTemplate.ItemTemplate>
                     </HierarchicalDataTemplate>

                  </TreeViewItem.Resources>
               </TreeViewItem>

               <TreeViewItem x:Name="fireNode" ItemsSource="{Binding FireSections}" IsExpanded="True">
                  <TreeViewItem.Header>
                     <StackPanel Orientation="Horizontal" Margin="2">
                        <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,5,0"
                              Fill="#B91C1C"
                              Data="M12 2C8.9 5.6 7 8.3 7 11.2C7 14.4 9.7 17 13 17C16.3 17 19 14.4 19 11.2C19 8.8 17.8 6.7 16 4.6C15.2 6.6 13.7 8.2 12.1 9.1C11.9 6.7 12 4.3 12 2Z"/>
                        <TextBlock Text="{DynamicResource FireSection_Node}" FontWeight="Bold"/>
                     </StackPanel>
                  </TreeViewItem.Header>
                  <TreeViewItem.ContextMenu>
                     <ContextMenu>
                        <MenuItem Header="{DynamicResource FireSection_New}"
                                  Command="{Binding NewFireSectionCommand}"/>
                        <MenuItem Header="{DynamicResource FireSection_Rename}"
                                  Command="{Binding RenameFireSectionCommand}"/>
                        <MenuItem Header="{DynamicResource FireSection_Delete}"
                                  Command="{Binding DeleteFireSectionCommand}"/>
                     </ContextMenu>
                  </TreeViewItem.ContextMenu>
                  <TreeViewItem.ItemTemplate>
                     <DataTemplate DataType="{x:Type fire:FireSectionDef}">
                        <StackPanel Orientation="Horizontal" Margin="1">
                           <Path Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0"
                                 Fill="#B91C1C"
                                 Data="M12 2C8.9 5.6 7 8.3 7 11.2C7 14.4 9.7 17 13 17C16.3 17 19 14.4 19 11.2C19 8.8 17.8 6.7 16 4.6C15.2 6.6 13.7 8.2 12.1 9.1C11.9 6.7 12 4.3 12 2Z"/>
                           <TextBlock Text="{Binding Tag}" VerticalAlignment="Center"/>
                        </StackPanel>
                     </DataTemplate>
                  </TreeViewItem.ItemTemplate>
               </TreeViewItem>
               <!-- Усилия -->
               <TreeViewItem IsExpanded="True">
                  <TreeViewItem.Header>
                     <StackPanel Orientation="Horizontal" Margin="2">
                        <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,5,0"
                              Fill="Teal"
                              Data="M16,3V5H8V3H16M16,7V9H8V7H16M16,11V13H8V11H16M5,15H19L12,22L5,15Z"/>
                        <TextBlock Text="{DynamicResource ForceSets}" FontWeight="Bold"/>
                     </StackPanel>
                  </TreeViewItem.Header>

                  <!-- Стержни -->
                  <TreeViewItem x:Name="barForceSetsNode" ItemsSource="{Binding BarForceSets}" IsExpanded="True">
                     <TreeViewItem.Header>
                        <TextBlock Text="{DynamicResource BarForceSets}" FontWeight="SemiBold"/>
                     </TreeViewItem.Header>
                     <TreeViewItem.ContextMenu>
                        <ContextMenu>
                           <MenuItem Header="{DynamicResource NewBarForceSet}"
                                     Command="{Binding NewBarForceSetCommand}"/>
                        </ContextMenu>
                     </TreeViewItem.ContextMenu>
                     <TreeViewItem.ItemTemplate>
                        <DataTemplate DataType="{x:Type core:ForceSet}">
                           <StackPanel Orientation="Horizontal" Margin="1"
                                       Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                              <StackPanel.ContextMenu>
                                 <ContextMenu>
                                    <MenuItem Header="{DynamicResource RenameForceSet}"
                                              Command="{Binding PlacementTarget.Tag.SetForceSetLoadTypeCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="{DynamicResource DuplicateForceSet}"
                                              Command="{Binding PlacementTarget.Tag.DuplicateForceSetCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource DeleteForceSetItem}"
                                              Command="{Binding PlacementTarget.Tag.DeleteForceSetCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                 </ContextMenu>
                              </StackPanel.ContextMenu>
                              <Path Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0"
                                    Fill="Teal"
                                    Data="M16,3V5H8V3H16M16,7V9H8V7H16M16,11V13H8V11H16M5,15H19L12,22L5,15Z"/>
                              <TextBlock Text="{Binding Tag}" VerticalAlignment="Center"/>
                              <TextBlock Text=" (" Foreground="Gray"/>
                              <TextBlock Text="{Binding Items.Count}" Foreground="Gray"/>
                              <TextBlock Text=")" Foreground="Gray"/>
                           </StackPanel>
                        </DataTemplate>
                     </TreeViewItem.ItemTemplate>
                  </TreeViewItem>

                  <!-- Пластины -->
                  <TreeViewItem x:Name="shellForceSetsNode" ItemsSource="{Binding ShellForceSets}" IsExpanded="True">
                     <TreeViewItem.Header>
                        <TextBlock Text="{DynamicResource ShellForceSets}" FontWeight="SemiBold"/>
                     </TreeViewItem.Header>
                     <TreeViewItem.ContextMenu>
                        <ContextMenu>
                           <MenuItem Header="{DynamicResource NewShellForceSet}"
                                     Command="{Binding NewShellForceSetCommand}"/>
                        </ContextMenu>
                     </TreeViewItem.ContextMenu>
                     <TreeViewItem.ItemTemplate>
                        <DataTemplate DataType="{x:Type core:ForceSet}">
                           <StackPanel Orientation="Horizontal" Margin="1"
                                       Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                              <StackPanel.ContextMenu>
                                 <ContextMenu>
                                    <MenuItem Header="{DynamicResource RenameForceSet}"
                                              Command="{Binding PlacementTarget.Tag.SetForceSetLoadTypeCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="{DynamicResource DuplicateForceSet}"
                                              Command="{Binding PlacementTarget.Tag.DuplicateForceSetCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource DeleteForceSetItem}"
                                              Command="{Binding PlacementTarget.Tag.DeleteForceSetCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                 </ContextMenu>
                              </StackPanel.ContextMenu>
                              <Path Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0"
                                    Fill="Teal"
                                    Data="M16,3V5H8V3H16M16,7V9H8V7H16M16,11V13H8V11H16M5,15H19L12,22L5,15Z"/>
                              <TextBlock Text="{Binding Tag}" VerticalAlignment="Center"/>
                              <TextBlock Text=" (" Foreground="Gray"/>
                              <TextBlock Text="{Binding ShellItems.Count}" Foreground="Gray"/>
                              <TextBlock Text=")" Foreground="Gray"/>
                           </StackPanel>
                        </DataTemplate>
                     </TreeViewItem.ItemTemplate>
                  </TreeViewItem>

               </TreeViewItem>

               <!-- Задачи -->
               <TreeViewItem x:Name="tasksNode"
                             IsExpanded="True"
                             Selected="TasksNode_Selected">
                  <TreeViewItem.Header>
                     <StackPanel Orientation="Horizontal" Margin="2">
                        <Viewbox Width="16" Height="16" Margin="0,0,5,0">
                           <Path Fill="#4F46E5"
                                 Data="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-2 14l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                        </Viewbox>
                        <TextBlock Text="{DynamicResource Tasks}" FontWeight="Bold"/>
                     </StackPanel>
                  </TreeViewItem.Header>
                  <TreeViewItem.Resources>
                     <HierarchicalDataTemplate DataType="{x:Type vm:CalcTaskVM}"
                                               ItemsSource="{Binding Results}">
                        <StackPanel Orientation="Horizontal"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                           <StackPanel.ContextMenu>
                              <ContextMenu>
                                 <MenuItem Header="{DynamicResource CalcTaskNew}"
                                           Command="{Binding PlacementTarget.Tag.NewCalcTaskCommand,
                                                     RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                 <Separator/>
                                 <MenuItem Header="{DynamicResource CalcTaskRun}"
                                           Command="{Binding PlacementTarget.Tag.RunCalcTaskCommand,
                                                     RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                           CommandParameter="{Binding PlacementTarget.DataContext.Model,
                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                 <MenuItem Header="{DynamicResource CalcTaskEdit}"
                                           Command="{Binding PlacementTarget.Tag.EditCalcTaskCommand,
                                                     RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                           CommandParameter="{Binding PlacementTarget.DataContext.Model,
                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                 <Separator/>
                                 <MenuItem Header="{DynamicResource CalcTaskDelete}"
                                           Command="{Binding PlacementTarget.Tag.DeleteCalcTaskCommand,
                                                     RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                           CommandParameter="{Binding PlacementTarget.DataContext.Model,
                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                              </ContextMenu>
                           </StackPanel.ContextMenu>
                           <TextBlock Text="{Binding Model.Num, StringFormat='{}{0:D3}  '}" Foreground="Gray"/>
                           <TextBlock Text="{Binding Model.Tag}"/>
                           <TextBlock Text="{Binding Model.Kind, StringFormat='  [{0}]'}" Foreground="Gray"/>
                        </StackPanel>
                     </HierarchicalDataTemplate>
                     <DataTemplate DataType="{x:Type core:CalcResult}">
                        <StackPanel Orientation="Horizontal">
                           <TextBlock Text="{Binding Created}" Foreground="Gray" Margin="0,0,6,0"/>
                           <TextBlock Text="{Binding Status}">
                              <TextBlock.Style>
                                 <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Green"/>
                                    <Style.Triggers>
                                       <DataTrigger Binding="{Binding Status}" Value="error">
                                          <Setter Property="Foreground" Value="Red"/>
                                       </DataTrigger>
                                       <DataTrigger Binding="{Binding Status}" Value="not_converged">
                                          <Setter Property="Foreground" Value="Orange"/>
                                       </DataTrigger>
                                       <DataTrigger Binding="{Binding Status}" Value="not_passed">
                                          <Setter Property="Foreground" Value="OrangeRed"/>
                                       </DataTrigger>
                                    </Style.Triggers>
                                 </Style>
                              </TextBlock.Style>
                           </TextBlock>
                        </StackPanel>
                     </DataTemplate>
                  </TreeViewItem.Resources>
               </TreeViewItem>
      </TreeView>
      </GroupBox>



      <!--<ScrollViewer Grid.Column="2" Grid.Row="2" 
                      HorizontalScrollBarVisibility="Auto" 
                      VerticalScrollBarVisibility="Auto">

          

      </ScrollViewer>-->

      <GroupBox Grid.Column="2" Grid.Row="2" Margin="4"
                Header="{Binding CurrentPageTitle}">
         <ContentControl x:Name="masterFrame" Content="{Binding CurrentPage}"/>
      </GroupBox>

      <StatusBar Height="25" Grid.Column="0" Grid.Row="5" Grid.ColumnSpan="3" >
         <StatusBarItem>

         </StatusBarItem>
      </StatusBar>

   </Grid>
</Window>