<Window x:Class="OpenCS.Views.SectionCutExportDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource SectionCutExportTitle}"
        MinWidth="440"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="{DynamicResource SectionCutExportFormatLabel}"
               FontWeight="SemiBold"
               Margin="0,0,0,8"/>

    <StackPanel Grid.Row="1" Margin="0,0,0,16">
      <RadioButton x:Name="FormatPng"
                   Content="{DynamicResource SectionCutExportFormatPng}"
                   IsChecked="True"
                   GroupName="CutExportFormat"
                   Margin="0,0,0,6"/>
      <RadioButton x:Name="FormatSvg"
                   Content="{DynamicResource SectionCutExportFormatSvg}"
                   GroupName="CutExportFormat"
                   Margin="0,0,0,6"/>
      <RadioButton x:Name="FormatDxf"
                   Content="{DynamicResource SectionCutExportFormatDxf}"
                   GroupName="CutExportFormat"/>
    </StackPanel>

    <StackPanel Grid.Row="2" Margin="0,0,0,20">
      <CheckBox x:Name="AsOnScreenCheck"
                Content="{DynamicResource SectionCutExportAsOnScreen}"
                IsChecked="True"
                Margin="0,0,0,6"/>
      <TextBlock Text="{DynamicResource SectionCutExportAsOnScreenHint}"
                 TextWrapping="Wrap"
                 Opacity="0.75"
                 MaxWidth="400"
                 Margin="20,0,0,0"/>
    </StackPanel>

    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button Content="{DynamicResource Ok}"
              Width="90"
              IsDefault="True"
              Margin="0,0,8,0"
              Click="OnOk"/>
      <Button Content="{DynamicResource Cancel}"
              Width="90"
              IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
