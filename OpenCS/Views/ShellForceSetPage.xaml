<UserControl x:Class="OpenCS.Views.ShellForceSetPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenCS.ViewModels">

   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Верхняя панель -->
      <Border Grid.Row="0" BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
              Padding="8,6">
         <StackPanel Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Tag}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding Tag, UpdateSourceTrigger=PropertyChanged}"
                     Width="260" Margin="0,0,12,0"/>
            <Button Style="{StaticResource IconButton25}"
                    Command="{Binding SaveCommand}"
                    ToolTip="{DynamicResource Save}"
                    Margin="0,0,8,0">
               <Path Width="16" Height="16" Stretch="Uniform"
                     Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                     Data="M17 3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V7L17 3M19 19H5V5H16.17L19 7.83V19M12 12C10.34 12 9 13.34 9 15S10.34 18 12 18 15 16.66 15 15 13.66 12 12 12M6 6H15V10H6V6Z"/>
            </Button>
            <Separator Width="1" Margin="0,0,8,0"/>
            <Button Style="{StaticResource IconButton25}"
                    Command="{Binding ExportCsvCommand}"
                    ToolTip="{DynamicResource ExportCsvBtn}"
                    Margin="0,0,4,0">
               <Path Width="16" Height="16" Stretch="Uniform"
                     Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                     Data="M14,2L20,8V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V4A2,2 0 0,1 6,2H14M18,20V9H13V4H6V20H18M12,19L8,15H10.5V12H13.5V15H16L12,19Z"/>
            </Button>
            <Button Style="{StaticResource IconButton25}"
                    Command="{Binding ImportCsvCommand}"
                    ToolTip="{DynamicResource ImportCsvBtn}">
               <Path Width="16" Height="16" Stretch="Uniform"
                     Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                     Data="M14,2L20,8V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V4A2,2 0 0,1 6,2H14M18,20V9H13V4H6V20H18M12,12L16,16H13.5V19H10.5V16H8L12,12Z"/>
            </Button>
         </StackPanel>
      </Border>

      <!-- Таблица усилий пластины -->
      <DataGrid Grid.Row="1"
                ItemsSource="{Binding Items}"
                SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                Margin="4,4,4,0">

         <DataGrid.Columns>

            <DataGridTextColumn Binding="{Binding Num, Mode=OneWay}" IsReadOnly="True" Width="36">
               <DataGridTextColumn.Header>
                  <TextBlock Text="#" HorizontalAlignment="Center"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                     <Setter Property="HorizontalAlignment" Value="Center"/>
                     <Setter Property="VerticalAlignment" Value="Center"/>
                     <Setter Property="Foreground" Value="Gray"/>
                  </Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                Width="140">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColLabel}"/>
               </DataGridTextColumn.Header>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding Nx, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="80">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ShellForceColNx}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding Ny, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="80">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ShellForceColNy}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding Nxy, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="80">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ShellForceColNxy}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding Mx, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="85">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ShellForceColMx}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding My, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="85">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ShellForceColMy}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding Mxy, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="90">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ShellForceColMxy}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding Qx, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="80">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ShellForceColQx}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding Qy, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="80">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ShellForceColQy}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

         </DataGrid.Columns>
      </DataGrid>

      <!-- Кнопки внизу -->
      <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="4,4,4,4">
         <Button Style="{StaticResource IconButton25}"
                 Command="{Binding AddItemCommand}"
                 ToolTip="{DynamicResource AddForceItem}"
                 Margin="0,0,4,0">
            <Path Width="16" Height="16" Stretch="Uniform"
                  Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                  Data="M22,10A2,2 0 0,1 20,12H4A2,2 0 0,1 2,10V3H4V5H8V3H10V5H14V3H16V5H20V3H22V10M4,10H8V7H4V10M10,10H14V7H10V10M20,10V7H16V10H20M11,14H13V17H16V19H13V22H11V19H8V17H11V14Z"/>
         </Button>
         <Button Style="{StaticResource IconButton25}"
                 Command="{Binding DuplicateItemCommand}"
                 ToolTip="{DynamicResource DuplicateForceItem}"
                 Margin="0,0,4,0">
            <Path Width="16" Height="16" Stretch="Uniform"
                  Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                  Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"/>
         </Button>
         <Button Style="{StaticResource IconButton25}"
                 Command="{Binding DeleteItemCommand}"
                 ToolTip="{DynamicResource DeleteForceItem}">
            <Path Width="16" Height="16" Stretch="Uniform"
                  Fill="#CC3333"
                  Data="M9.41,13L12,15.59L14.59,13L16,14.41L13.41,17L16,19.59L14.59,21L12,18.41L9.41,21L8,19.59L10.59,17L8,14.41L9.41,13M22,9A2,2 0 0 1 20,11H4A2,2 0 0 1 2,9V6A2,2 0 0 1 4,4H20A2,2 0 0 1 22,6V9M4,9H8V6H4V9M10,9H14V6H10V9M16,9H20V6H16V9Z"/>
         </Button>
      </StackPanel>

   </Grid>
</UserControl>
