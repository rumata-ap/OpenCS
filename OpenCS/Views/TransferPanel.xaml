<UserControl x:Class="OpenCS.Views.TransferPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="30">
   <Grid x:Name="LayoutRoot">
      <Grid.RowDefinitions>
         <RowDefinition x:Name="InRow"/>
         <RowDefinition x:Name="InAllRow"/>
         <RowDefinition x:Name="OutRow"/>
      </Grid.RowDefinitions>

      <Button x:Name="InButton" Grid.Row="0" Style="{StaticResource IconButton}"
              Command="{Binding InCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
         <Image Source="/Images/strelka_vlevo_32.png"/>
      </Button>

      <Button x:Name="InAllButton" Grid.Row="1" Style="{StaticResource IconButton}"
              Command="{Binding InAllCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
         <Image Source="/Images/strelki_vlevo_32.png"/>
      </Button>

      <Button x:Name="OutButton" Grid.Row="2" Style="{StaticResource IconButton}"
              Command="{Binding OutCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
         <Image Source="/Images/strelka_vpravo_32.png"/>
      </Button>
   </Grid>
</UserControl>