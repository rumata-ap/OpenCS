         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="1.8*"></ColumnDefinition>
         <ColumnDefinition Width="*"></ColumnDefinition>
         <ColumnDefinition Width="*"></ColumnDefinition>
         <ColumnDefinition Width="*"></ColumnDefinition>
         <ColumnDefinition Width="*"></ColumnDefinition>
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0"
                   Grid.Column="0" 
                   Grid.ColumnSpan="5" 
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#FF000070" 
                   FontSize="14" 
                   Margin="0,10,0,5"
                   TextDecorations="Underline" 
                   FontFamily="Segoe UI Semibold">
         <TextBlock.Text>
            <DynamicResource ResourceKey="MaterialParams"/>
         </TextBlock.Text>
      </TextBlock>

      <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.08*"/>
         </Grid.ColumnDefinitions>

         <DockPanel Grid.Column="0">
            <Button Height="25"
                        Margin="5,0,5,5"
                        Command="{Binding EditCommand}" Content="{DynamicResource Change}"/>
         </DockPanel>

         <DockPanel Grid.Column="1">
            <Button Height="25"
                        Margin="0,0,5,5"
                        Command="{Binding AddCommand}" Content="{DynamicResource Save}"/>
         </DockPanel>

         <DockPanel Grid.Column="2">
            <Button Height="25"
                        Command="{Binding DataSourceCommand}"
                        Margin="0,0,5,5">
               <Image x:Name="ImageDB" Source="/Images/database_icon_174569.png"/>
            </Button>
         </DockPanel>
      </Grid>



      <DockPanel Grid.Row="1" Grid.Column="0" 
                   Margin="5,10,5,10" 
                   VerticalAlignment="Center">
         <TextBlock Text="{DynamicResource Name}" Foreground="#FF2813EB"/>
         <TextBox Margin="5,0,0,0" 
                     Text="{Binding Tag}"
                     HorizontalContentAlignment="Left"/>
      </DockPanel>

      <StackPanel>

      </StackPanel>

      <DockPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5" 
                   Margin="5,10,5,10" 
                   VerticalAlignment="Center">
         <TextBlock Text="{DynamicResource DescriptionLabel}" 
                       Foreground="#FF2813EB"/>
         <TextBox Margin="5,0,0,0" 
                     HorizontalContentAlignment="Left"
                     Text="{Binding Description}"/>

      </DockPanel>


