<UserControl x:Class="OpenCS.Views.MaterialPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OpenCS.Views"
      xmlns:vm="clr-namespace:OpenCS.ViewModels"
      xmlns:ut="clr-namespace:OpenCS.Utilites"
      xmlns:core="clr-namespace:CScore;assembly=CScore"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="900"
      Background="White">

   <UserControl.DataContext>
      <vm:MaterialVM/>
   </UserControl.DataContext>

   <UserControl.Resources>
      <ut:MPaConvert x:Key="mpa" />
      <ut:GPaConvert x:Key="gpa" />
      <ut:MPaConvertInv x:Key="mpa_" />
      <ut:ConvertInv x:Key="inv" />
   </UserControl.Resources>

