<UserControl x:Class="OpenCS.Views.ShellSimplResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
   <UserControl.Resources>
      <Style x:Key="StatusOkStyle" TargetType="TextBlock">
         <Setter Property="Foreground" Value="Green"/>
         <Setter Property="FontWeight" Value="Bold"/>
      </Style>
      <Style x:Key="StatusFailStyle" TargetType="TextBlock">
         <Setter Property="Foreground" Value="Red"/>
         <Setter Property="FontWeight" Value="Bold"/>
      </Style>
   </UserControl.Resources>
   <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="8">
         <TextBlock FontWeight="Bold" FontSize="14" Text="{Binding Title}" Margin="0,0,0,4"/>

         <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                 Background="{Binding OverallStatusBrush}">
            <TextBlock FontWeight="Bold" FontSize="13" Text="{Binding OverallStatus}"
                       HorizontalAlignment="Center"/>
         </Border>

         <GroupBox Header="Усилия" Margin="0,0,0,8">
            <Grid>
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0" Margin="4 0 8 0" Text="{Binding Nx, StringFormat='Nx: {0}'}"/>
               <TextBlock Grid.Column="1" Margin="4 0 8 0" Text="{Binding Ny, StringFormat='Ny: {0}'}"/>
               <TextBlock Grid.Column="2" Margin="4 0 8 0" Text="{Binding Nxy, StringFormat='Nxy: {0}'}"/>
               <TextBlock Grid.Column="3" Margin="4 0 8 0" Text="{Binding Mx, StringFormat='Mx: {0}'}"/>
               <TextBlock Grid.Column="4" Margin="4 0 8 0" Text="{Binding My, StringFormat='My: {0}'}"/>
               <TextBlock Grid.Column="5" Margin="4 0 8 0" Text="{Binding Mxy, StringFormat='Mxy: {0}'}"/>
            </Grid>
         </GroupBox>

         <GroupBox Header="{Binding StripHeader}" Margin="0,0,0,8"
                   Visibility="{Binding HasStrips, Converter={StaticResource BoolToVisibility}}">
            <ItemsControl ItemsSource="{Binding Strips}">
               <ItemsControl.ItemTemplate>
                  <DataTemplate>
                     <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="4">
                        <StackPanel>
                           <StackPanel Orientation="Horizontal">
                              <TextBlock FontWeight="Bold" Text="{Binding Name}" Margin="0,0,12,0"/>
                              <TextBlock Text="Выполняется" Style="{StaticResource StatusOkStyle}"
                                         Visibility="{Binding StatusOk, Converter={StaticResource BoolToVisibility}}"/>
                              <TextBlock Text="Не выполняется" Style="{StaticResource StatusFailStyle}"
                                         Visibility="{Binding StatusOk, Converter={StaticResource InverseBoolToVisibility}}"/>
                           </StackPanel>
                           <Grid>
                              <Grid.ColumnDefinitions>
                                 <ColumnDefinition Width="Auto"/>
                                 <ColumnDefinition Width="Auto"/>
                                 <ColumnDefinition Width="Auto"/>
                                 <ColumnDefinition Width="Auto"/>
                                 <ColumnDefinition Width="Auto"/>
                              </Grid.ColumnDefinitions>
                              <TextBlock Grid.Column="0" Margin="4 0 8 0" Text="{Binding M_des, StringFormat='M: {0}'}"/>
                              <TextBlock Grid.Column="1" Margin="4 0 8 0" Text="{Binding N_des, StringFormat='N: {0}'}"/>
                              <TextBlock Grid.Column="2" Margin="4 0 8 0" Text="{Binding SigmaDisplay, StringFormat='σs: {0} МПа'}"/>
                              <TextBlock Grid.Column="3" Margin="4 0 8 0"
                                         Text="{Binding AcrcDisplay, StringFormat='acrc: {0} мм'}"
                                         Visibility="{Binding ShowSls, Converter={StaticResource BoolToVisibility}}"/>
                              <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="4 0 8 0"
                                          Visibility="{Binding ShowUls, Converter={StaticResource BoolToVisibility}}">
                                 <TextBlock Text="η: "/>
                                 <TextBlock Text="{Binding EtaDisplay}"/>
                              </StackPanel>
                           </Grid>
                           <StackPanel Orientation="Horizontal"
                                       Visibility="{Binding ShowSls, Converter={StaticResource BoolToVisibility}}">
                              <TextBlock Margin="4 0 8 0" Text="{Binding Psi_s, StringFormat='ψs: {0}'}"/>
                              <TextBlock Margin="4 0 8 0" Text="{Binding B_kNm2, StringFormat='B: {0} кН·м²/м'}"/>
                              <TextBlock Margin="4 0 8 0" Text="{Binding Xm, StringFormat='xm: {0} м'}"/>
                           </StackPanel>
                           <StackPanel Orientation="Horizontal"
                                       Visibility="{Binding ShowUls, Converter={StaticResource BoolToVisibility}}">
                              <TextBlock Margin="4 0 8 0" Text="{Binding Xm, StringFormat='x: {0} м'}"/>
                              <TextBlock Margin="4 0 8 0" Text="{Binding Xi, StringFormat='ξ: {0}'}"/>
                              <TextBlock Margin="4 0 8 0" Text="{Binding Xi_R, StringFormat='ξ_R: {0}'}"/>
                              <TextBlock Margin="4 0 8 0" Text="{Binding M_ult, StringFormat='M_ult: {0}'}"/>
                              <TextBlock Margin="4 0 8 0" Text="{Binding Case}"/>
                          </StackPanel>
                         </StackPanel>
                      </Border>
                  </DataTemplate>
               </ItemsControl.ItemTemplate>
            </ItemsControl>
         </GroupBox>

         <GroupBox Header="Критические направления" Margin="0,0,0,8"
                   Visibility="{Binding HasCapri, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
               <StackPanel Orientation="Horizontal" Margin="4"
                           Visibility="{Binding HasCriticalTop, Converter={StaticResource BoolToVisibility}}">
                  <TextBlock FontWeight="Bold" Text="Верх: α=" Margin="0,0,4,0"/>
                  <TextBlock Text="{Binding CritTopAlpha}" Margin="0,0,4,0"/>
                  <TextBlock Text="°," Margin="0,0,4,0"/>
                  <TextBlock Text="{Binding CritTopSigmaDisplay, StringFormat='σs: {0} МПа'}" Margin="0,0,4,0"/>
                  <TextBlock Text="{Binding CritTopEtaDisplay, StringFormat='η: {0}'}" Margin="0,0,4,0"
                             Visibility="{Binding HasEtaMax, Converter={StaticResource BoolToVisibility}}"/>
                  <TextBlock Text="{Binding CritTopAcrcDisplay, StringFormat='acrc: {0} мм'}" Margin="0,0,4,0"/>
               </StackPanel>
               <StackPanel Orientation="Horizontal" Margin="4"
                           Visibility="{Binding HasCriticalBot, Converter={StaticResource BoolToVisibility}}">
                  <TextBlock FontWeight="Bold" Text="Низ: α=" Margin="0,0,4,0"/>
                  <TextBlock Text="{Binding CritBotAlpha}" Margin="0,0,4,0"/>
                  <TextBlock Text="°," Margin="0,0,4,0"/>
                  <TextBlock Text="{Binding CritBotSigmaDisplay, StringFormat='σs: {0} МПа'}" Margin="0,0,4,0"/>
                  <TextBlock Text="{Binding CritBotEtaDisplay, StringFormat='η: {0}'}" Margin="0,0,4,0"
                             Visibility="{Binding HasEtaMax, Converter={StaticResource BoolToVisibility}}"/>
                  <TextBlock Text="{Binding CritBotAcrcDisplay, StringFormat='acrc: {0} мм'}" Margin="0,0,4,0"/>
               </StackPanel>
               <TextBlock Margin="4" FontWeight="Bold"
                          Text="{Binding EtaMaxDisplay, StringFormat='η_max: {0}'}"
                          Visibility="{Binding HasEtaMax, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
         </GroupBox>

         <GroupBox Header="Все направления" Margin="0,0,0,8"
                   Visibility="{Binding HasCapri, Converter={StaticResource BoolToVisibility}}">
            <DataGrid ItemsSource="{Binding Directions}" AutoGenerateColumns="False" IsReadOnly="True"
                      MaxHeight="300" RowHeaderWidth="0">
               <DataGrid.RowStyle>
                  <Style TargetType="DataGridRow">
                     <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCritical}" Value="True">
                           <Setter Property="Background" Value="#FFFFCC"/>
                           <Setter Property="FontWeight" Value="Bold"/>
                        </DataTrigger>
                     </Style.Triggers>
                  </Style>
               </DataGrid.RowStyle>
               <DataGrid.Columns>
                  <DataGridTextColumn Header="α,°" Binding="{Binding Alpha_deg}"/>
                  <DataGridTextColumn Header="M_n" Binding="{Binding M_n}"/>
                  <DataGridTextColumn Header="N_n" Binding="{Binding N_n}"/>
                  <DataGridTextColumn Header="Растянутая грань" Binding="{Binding Face}"/>
                  <DataGridTextColumn Header="σs, МПа" Binding="{Binding SigmaDisplay}"/>
                  <DataGridTextColumn Header="acrc, мм" Binding="{Binding AcrcDisplay}"/>
                  <DataGridTextColumn Header="η" Binding="{Binding EtaDisplay}"/>
                  <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}"/>
               </DataGrid.Columns>
            </DataGrid>
         </GroupBox>
      </StackPanel>
   </ScrollViewer>
</UserControl>
