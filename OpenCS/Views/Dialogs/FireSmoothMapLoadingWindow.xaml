<Window x:Class="OpenCS.Views.Dialogs.FireSmoothMapLoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FireThermal_SmoothMapLoadingTitle}"
        Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow">
   <StackPanel Margin="24,20">
      <TextBlock Text="{DynamicResource FireThermal_SmoothMapLoadingTitle}"
                 FontWeight="Bold" FontSize="14" Margin="0,0,0,8" TextWrapping="Wrap"/>
      <TextBlock Text="{DynamicResource FireThermal_SmoothMapLoadingMessage}"
                 TextWrapping="Wrap" Margin="0,0,0,16"/>
      <Grid x:Name="track" Height="14" ClipToBounds="True"
            Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
         <Border x:Name="marquee" Width="96" Height="14" HorizontalAlignment="Left"
                 Background="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}">
            <Border.RenderTransform>
               <TranslateTransform x:Name="marqueeTransform"/>
            </Border.RenderTransform>
         </Border>
      </Grid>
   </StackPanel>
</Window>
