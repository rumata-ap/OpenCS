<UserControl x:Class="OpenCS.Views.StrainSummaryBody"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

   <StackPanel>

      <!-- Плоскость деформаций -->
      <GroupBox Header="{DynamicResource ResultStrainPlane}" Margin="0,0,0,6" Padding="8,4">
         <Grid>
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="100"/>
               <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="ε₀"  Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Eps0Text}" FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="κy"  Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding KyText}"   FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="κz"  Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding KzText}"   FontFamily="Consolas" Margin="0,1"/>
         </Grid>
      </GroupBox>

      <!-- Усилия -->
      <GroupBox Header="{DynamicResource ResultForces}" Margin="0,0,0,6" Padding="8,4">
         <Grid>
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="40"/>
               <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="N"  Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NText}"  FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Mx" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MxText}" FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="My" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MyText}" FontFamily="Consolas" Margin="0,1"/>
         </Grid>
      </GroupBox>

      <!-- Экстремальные деформации -->
      <GroupBox Header="{DynamicResource ResultExtremeStrains}"
                Margin="0,0,0,6" Padding="8,4"
                Visibility="{Binding HasExtremes, Converter={StaticResource BoolToVisibility}}">
         <Grid>
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="70"/>
               <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="ε_min" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EpsMinText}" FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="ε_max" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EpsMaxText}" FontFamily="Consolas" Margin="0,1"/>
         </Grid>
      </GroupBox>

      <!-- Жёсткости -->
      <GroupBox Header="{DynamicResource ResultStiffness}"
                Margin="0,0,0,6" Padding="8,4"
                Visibility="{Binding HasStiffness, Converter={StaticResource BoolToVisibility}}">
         <Grid>
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="120"/>
               <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="4"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Foreground="Gray" Margin="0,1"
                       Text="{DynamicResource ResultCentroid}"/>
            <TextBlock Grid.Row="0" Grid.Column="1" FontFamily="Consolas" Margin="0,1"
                       Text="{Binding XcText, StringFormat='xc = {0}'}"/>
            <TextBlock Grid.Row="1" Grid.Column="1" FontFamily="Consolas" Margin="0,1"
                       Text="{Binding YcText, StringFormat='yc = {0}'}"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="EA"   Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EAText}"   FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="4" Grid.Column="0" Text="EIy₀" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding EIy0Text}" FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="5" Grid.Column="0" Text="EIz₀" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding EIz0Text}" FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="6" Grid.Column="0" Text="EIy (ц.т.)" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding EIycText}" FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="7" Grid.Column="0" Text="EIz (ц.т.)" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding EIzcText}" FontFamily="Consolas" Margin="0,1"/>
         </Grid>
      </GroupBox>

      <!-- Упругие жёсткости -->
      <GroupBox Header="{DynamicResource ResultElasticStiffness}"
                Margin="0,0,0,6" Padding="8,4"
                Visibility="{Binding HasStiffness, Converter={StaticResource BoolToVisibility}}">
         <Grid>
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="120"/>
               <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="4"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="EA,упр"  Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EAelText}"  FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="EIy,упр" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EIyelText}" FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="EIz,упр" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EIzelText}" FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="4" Grid.Column="0" Text="φEA"  Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PhiEAText}"  FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="5" Grid.Column="0" Text="φEIy" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding PhiEIyText}" FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="6" Grid.Column="0" Text="φEIz" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding PhiEIzText}" FontFamily="Consolas" Margin="0,1"/>
         </Grid>
      </GroupBox>

      <!-- Арматура -->
      <GroupBox Header="{DynamicResource ResultRebarTable}"
                Margin="0,0,0,6" Padding="4"
                Visibility="{Binding HasRebar, Converter={StaticResource BoolToVisibility}}">
         <DataGrid ItemsSource="{Binding RebarRows}"
                   AutoGenerateColumns="False" IsReadOnly="True"
                   CanUserAddRows="False" CanUserDeleteRows="False"
                   HeadersVisibility="Column" SelectionMode="Single">
            <DataGrid.Columns>
               <DataGridTextColumn Header="№"       Binding="{Binding Num}"   Width="36"/>
               <DataGridTextColumn Header="x, мм"   Binding="{Binding X}"     Width="72"/>
               <DataGridTextColumn Header="y, мм"   Binding="{Binding Y}"     Width="72"/>
               <DataGridTextColumn Header="ε"       Binding="{Binding Eps}"   Width="100"/>
               <DataGridTextColumn Header="σ, МПа"  Binding="{Binding Sigma}" Width="90"/>
            </DataGrid.Columns>
         </DataGrid>
      </GroupBox>

      <!-- Сходимость -->
      <GroupBox Header="{DynamicResource ResultConvergence}" Margin="0,0,0,6" Padding="8,4"
                Visibility="{Binding ShowConvergence, Converter={StaticResource BoolToVisibility}}">
         <Grid>
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="100"/>
               <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource CalcResultIterations}" Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding IterationsText}" FontFamily="Consolas" Margin="0,1"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource CalcResultResidual}"   Foreground="Gray" Margin="0,1"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ResidualText}"   FontFamily="Consolas" Margin="0,1"/>
         </Grid>
      </GroupBox>

      <!-- Примечание об учёте замещения площади бетона -->
      <TextBlock Text="{Binding RebarAreaNote}" TextWrapping="Wrap"
                 Foreground="Gray" FontStyle="Italic" Margin="0,4,0,0"
                 Visibility="{Binding ShowRebarAreaNote, Converter={StaticResource BoolToVisibility}}"/>

   </StackPanel>
</UserControl>
