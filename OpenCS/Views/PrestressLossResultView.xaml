<UserControl x:Class="OpenCS.Views.PrestressLossResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
   <Grid Margin="8">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Ошибки и предупреждения -->
      <ItemsControl Grid.Row="0" ItemsSource="{Binding Messages}" Margin="0,0,0,6"
                    Visibility="{Binding HasMessages, Converter={StaticResource BoolToVisibility}}">
         <ItemsControl.ItemTemplate>
            <DataTemplate>
               <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}"
                          FontWeight="SemiBold" Margin="0,1"/>
            </DataTemplate>
         </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- DataGrid результатов по группам -->
      <DataGrid Grid.Row="1"
                ItemsSource="{Binding GroupRows}"
                AutoGenerateColumns="False"
                CanUserAddRows="False" CanUserDeleteRows="False"
                IsReadOnly="True" HeadersVisibility="Column"
                SelectionMode="Single" SelectionUnit="FullRow">
         <DataGrid.Columns>
            <DataGridTextColumn Header="{DynamicResource ColGroup}"      Binding="{Binding AreaTag}"             Width="80"/>
            <DataGridTextColumn Header="A, мм²"                          Binding="{Binding AreaMm2, StringFormat=F1}"  Width="70"/>
            <DataGridTextColumn Header="{DynamicResource ColSigSp0}"     Binding="{Binding SigSp0,  StringFormat=F1}"  Width="68"/>
            <DataGridTextColumn Header="{DynamicResource ColDSp1}"       Binding="{Binding DSp1,    StringFormat=F1}"  Width="60"/>
            <DataGridTextColumn Header="{DynamicResource ColDSp2}"       Binding="{Binding DSp2,    StringFormat=F1}"  Width="60"/>
            <DataGridTextColumn Header="{DynamicResource ColDSp3}"       Binding="{Binding DSp3,    StringFormat=F1}"  Width="62"/>
            <DataGridTextColumn Header="{DynamicResource ColDSp4}"       Binding="{Binding DSp4,    StringFormat=F1}"  Width="60"/>
            <DataGridTextColumn Header="{DynamicResource ColDSp7}"       Binding="{Binding DSp7,    StringFormat=F1}"  Width="60"/>
            <DataGridTextColumn Header="{DynamicResource ColTotalFirst}"  Binding="{Binding TotalFirst, StringFormat=F1}" Width="50"/>
            <DataGridTextColumn Header="{DynamicResource ColSigSp1}"     Binding="{Binding SigSp1,  StringFormat=F1}"  Width="68"/>
            <DataGridTextColumn Header="{DynamicResource ColSigmaBpj}"   Binding="{Binding SigmaBpj, StringFormat=F2}" Width="68"/>
            <DataGridTextColumn Header="{DynamicResource ColDSp5}"       Binding="{Binding DSp5,    StringFormat=F1}"  Width="62"/>
            <DataGridTextColumn Header="{DynamicResource ColDSp6}"       Binding="{Binding DSp6,    StringFormat=F1}"  Width="62"/>
            <DataGridTextColumn Header="{DynamicResource ColTotalAll}"    Binding="{Binding TotalAll, StringFormat=F1}" Width="55"/>
            <DataGridTextColumn Header="{DynamicResource ColSigSp2}"     Binding="{Binding SigSp2,  StringFormat=F1}"  Width="68"/>
            <DataGridTextColumn Header="{DynamicResource ColMinLoss}"    Binding="{Binding MinLossText}"               Width="50"/>
         </DataGrid.Columns>
      </DataGrid>

      <!-- P̄_(1) и P̄_(2) -->
      <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,6">
         <TextBlock Text="{DynamicResource PrestressForceFirst}" FontWeight="SemiBold" Margin="0,0,4,0"/>
         <TextBlock Text="{Binding PrecompForceFirstText}" Margin="0,0,24,0"/>
         <TextBlock Text="{DynamicResource PrestressForceTotal}" FontWeight="SemiBold" Margin="0,0,4,0"/>
         <TextBlock Text="{Binding PrecompForceTotalText}"/>
      </WrapPanel>

      <!-- Кнопка Применить -->
      <Button Grid.Row="3" Content="{DynamicResource PrestressApplyBtn}"
              Command="{Binding ApplyCommand}"
              HorizontalAlignment="Left"
              Padding="16,4"/>
   </Grid>
</UserControl>
