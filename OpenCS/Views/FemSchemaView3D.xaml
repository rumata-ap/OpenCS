<UserControl x:Class="OpenCS.Views.FemSchemaView3D" x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OpenCS.Views"
             xmlns:conv="clr-namespace:OpenCS.Converters"
             xmlns:h="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf">
    <UserControl.Resources>
        <conv:NullableDoubleTextConverter x:Key="NullableDoubleTextConverter"/>
        <Style x:Key="IconToggleButton25" TargetType="ToggleButton">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Width" Value="25"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        <ContextMenu x:Key="MemberContextMenu">
            <MenuItem Header="{DynamicResource FemMemberSectionCtx}" Click="MemberSectionCtx_Click"/>
            <MenuItem Header="{DynamicResource FemMemberPropertiesCtx}" Click="MemberPropertiesCtx_Click"/>
            <MenuItem Header="{DynamicResource FemMemberRotationCtx}" Click="MemberRotationCtx_Click"/>
            <MenuItem Header="{DynamicResource FemMemberLoadCtx}" Click="MemberLoadCtx_Click"/>
            <Separator/>
            <MenuItem Header="{DynamicResource FemMemberSplitCtx}" Click="MemberSplitCtx_Click"/>
            <MenuItem Header="{DynamicResource FemMemberDeleteCtx}" Click="MemberDeleteCtx_Click"/>
            <Separator/>
            <MenuItem Header="{DynamicResource FemMemberForcesCtx}" Click="MemberForcesCtx_Click"/>
        </ContextMenu>
        <ContextMenu x:Key="NodeContextMenu">
            <MenuItem Header="{DynamicResource FemNodeMoveCtx}" Click="NodeMoveCtx_Click"/>
            <MenuItem Header="{DynamicResource FemNodeCopyCtx}" Click="NodeCopyCtx_Click"/>
            <MenuItem Header="{DynamicResource FemNodeLoadCtx}" Click="NodeLoadCtx_Click"/>
            <Separator/>
            <MenuItem Header="{DynamicResource FemNodePropertiesCtx}" Click="NodePropertiesCtx_Click"/>
        </ContextMenu>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0">
            <ToggleButton Style="{StaticResource IconToggleButton25}"
                          IsChecked="{Binding Editor.CreateNodeMode, ElementName=root, Mode=TwoWay}"
                          ToolTip="{DynamicResource FemCreateNodeMode}">
                <Path Data="M17,13H13V17H11V13H7V11H11V7H13V11H17M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z" Fill="Black" Stretch="Uniform" Margin="2"/>
            </ToggleButton>
            <ToggleButton Style="{StaticResource IconToggleButton25}"
                          IsChecked="{Binding Editor.CreateBarMode, ElementName=root, Mode=TwoWay}"
                          ToolTip="{DynamicResource FemCreateBarMode}">
                <Path Data="M15,3.5A3.5,3.5 0 0,1 18.5,7C18.5,8.75 17.21,10.2 15.53,10.45L10.45,15.53C10.2,17.21 8.75,18.5 7,18.5A3.5,3.5 0 0,1 3.5,15C3.5,13.25 4.79,11.8 6.47,11.55L11.55,6.47C11.8,4.79 13.25,3.5 15,3.5M15,5.5A1.5,1.5 0 0,0 13.5,7A1.5,1.5 0 0,0 15,8.5A1.5,1.5 0 0,0 16.5,7A1.5,1.5 0 0,0 15,5.5M7,13.5A1.5,1.5 0 0,0 5.5,15A1.5,1.5 0 0,0 7,16.5A1.5,1.5 0 0,0 8.5,15A1.5,1.5 0 0,0 7,13.5Z" Fill="Black" Stretch="Uniform" Margin="2"/>
            </ToggleButton>
            <Separator/>
            <Button Style="{StaticResource IconButton25}" Click="NodeLoadTool_Click"
                    ToolTip="{DynamicResource FemNodeLoadToolTip}">
                <Path Data="M12,2 L12,16 M12,2 L8,6 M12,2 L16,6 M5,20 H19"
                      Stroke="Crimson" StrokeThickness="2" Stretch="Uniform" Margin="2"/>
            </Button>
            <Button Style="{StaticResource IconButton25}" Click="MemberLoadTool_Click"
                    ToolTip="{DynamicResource FemMemberLoadToolTip}">
                <Path Data="M3,12 H21 M7,12 V5 M12,12 V3 M17,12 V7 M5,5 L7,7 M10,3 L12,5 M15,7 L17,9"
                      Stroke="DarkGreen" StrokeThickness="2" Stretch="Uniform" Margin="2"/>
            </Button>
            <Button Style="{StaticResource IconButton25}"
                    Command="{Binding Editor.UndoCommand, ElementName=root}"
                    ToolTip="{DynamicResource FemUndo}">
                <Path Data="M13.5,7A6.5,6.5 0 0,1 20,13.5A6.5,6.5 0 0,1 13.5,20H10V18H13.5C16,18 18,16 18,13.5C18,11 16,9 13.5,9H7.83L10.91,12.09L9.5,13.5L4,8L9.5,2.5L10.92,3.91L7.83,7H13.5Z" Fill="Black" Stretch="Uniform" Margin="2"/>
            </Button>
            <Button Style="{StaticResource IconButton25}"
                    Command="{Binding Editor.RedoCommand, ElementName=root}"
                    ToolTip="{DynamicResource FemRedo}">
                <Path Data="M10.5,7A6.5,6.5 0 0,0 4,13.5A6.5,6.5 0 0,0 10.5,20H14V18H10.5C8,18 6,16 6,13.5C6,11 8,9 10.5,9H16.17L13.09,12.09L14.5,13.5L20,8L14.5,2.5L13.08,3.91L16.17,7H10.5Z" Fill="Black" Stretch="Uniform" Margin="2"/>
            </Button>
            <Button Style="{StaticResource IconButton25}"
                    Command="{Binding Editor.SaveCommand, ElementName=root}"
                    ToolTip="{DynamicResource FemSaveSchema}">
                <Path Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" Fill="Black" Stretch="Uniform" Margin="2"/>
            </Button>
            <Separator/>
            <Button Style="{StaticResource IconButton25}" Click="ZoomExtents_Click"
                    ToolTip="{DynamicResource Fem3DZoomExtents}">
                <Path Data="M10,21V19H6.41L10.91,14.5L9.5,13.09L5,17.59V14H3V21H10M14.5,10.91L19,6.41V10H21V3H14V5H17.59L13.09,9.5L14.5,10.91M3,3V10H5V6.41L9.5,10.91L10.91,9.5L6.41,5H10V3H3M21,21V14H19V17.59L14.5,13.09L13.09,14.5L17.59,19H14V21H21Z" Fill="Black" Stretch="Uniform" Margin="2"/>
            </Button>
            <ToggleButton x:Name="showNodesCheck" Style="{StaticResource IconToggleButton25}"
                          IsChecked="False" ToolTip="{DynamicResource Fem3DShowNodes}"
                          Checked="NodesToggle" Unchecked="NodesToggle">
                <Path Data="M12,4A2.5,2.5 0 0,1 14.5,6.5A2.5,2.5 0 0,1 12,9A2.5,2.5 0 0,1 9.5,6.5A2.5,2.5 0 0,1 12,4M5.5,14A2.5,2.5 0 0,1 8,16.5A2.5,2.5 0 0,1 5.5,19A2.5,2.5 0 0,1 3,16.5A2.5,2.5 0 0,1 5.5,14M18.5,14A2.5,2.5 0 0,1 21,16.5A2.5,2.5 0 0,1 18.5,19A2.5,2.5 0 0,1 16,16.5A2.5,2.5 0 0,1 18.5,14Z" Fill="Black" Stretch="Uniform" Margin="2"/>
            </ToggleButton>
            <ToggleButton x:Name="showGridCheck" Style="{StaticResource IconToggleButton25}"
                          IsChecked="True" ToolTip="{DynamicResource Fem3DShowGrid}"
                          Checked="GridToggle" Unchecked="GridToggle">
                <Path Data="M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M19,11H13V5H19V11M11,5V11H5V5H11M5,19V13H11V19H5M13,19V13H19V19H13Z" Fill="Black" Stretch="Uniform" Margin="2"/>
            </ToggleButton>
            <Separator/>
            <Menu>
                <MenuItem ToolTip="{DynamicResource Fem3DDrawingFlags}">
                    <MenuItem.Header>
                        <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" Fill="Black" Stretch="Uniform" Margin="2" Width="20" Height="20"/>
                    </MenuItem.Header>
                    <MenuItem Header="{DynamicResource Fem3DShowSupports}" IsCheckable="True"
                              IsChecked="{Binding ShowSupportGlyphs, Mode=TwoWay}"/>
                    <MenuItem Header="{DynamicResource Fem3DShowLoads}" IsCheckable="True"
                              IsChecked="{Binding ShowLoadGlyphs, Mode=TwoWay}"/>
                    <MenuItem Header="{DynamicResource Fem3DShowSectionGlyphs}" IsCheckable="True"
                              IsChecked="{Binding ShowSectionGlyphs, Mode=TwoWay}"/>
                </MenuItem>
            </Menu>
            <TextBlock Text="{DynamicResource Fem3DLoadDisplay}" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <ComboBox Width="180" ItemsSource="{Binding DiagramLoadSources}" DisplayMemberPath="Label"
                      SelectedItem="{Binding SelectedDiagramLoadSource, Mode=TwoWay}"/>
            <Separator/>
            <TextBlock Text="{DynamicResource FemDiscretizeTargetLength}" VerticalAlignment="Center" Margin="4,0,4,0"/>
            <TextBox Width="72" VerticalContentAlignment="Center"
                     Text="{Binding Editor.DefaultTargetMeshLengthM, ElementName=root,
                                    Converter={StaticResource NullableDoubleTextConverter},
                                    UpdateSourceTrigger=LostFocus}"/>
            <Button Style="{StaticResource IconButton25}"
                    Command="{Binding Editor.DiscretizeCommand, ElementName=root}"
                    ToolTip="{DynamicResource FemDiscretize}">
                <Path Data="M2,11 H22 V13 H2 Z M6,7 V17 H8 V7 Z M11,7 V17 H13 V7 Z M16,7 V17 H18 V7 Z" Fill="Black" Stretch="Uniform" Margin="2"/>
            </Button>
            <Button Style="{StaticResource IconButton25}"
                    Command="{Binding Editor.MergeNodesCommand, ElementName=root}"
                    ToolTip="{DynamicResource FemMergeNodes}">
                <Path Data="M9,12 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0 M15,12 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0" Fill="Black" Stretch="Uniform" Margin="2"/>
            </Button>
        </ToolBar>

        <!-- 3D viewport -->
        <h:HelixViewport3D x:Name="viewport" Grid.Row="1"
                           Background="White"
                           ShowCoordinateSystem="True"
                           ShowViewCube="True"
                           ZoomAroundMouseDownPoint="True"/>

        <!-- Немодальная панель «Добавить узел» -->
        <Border x:Name="createNodePanel" Grid.Row="1"
                Visibility="Collapsed"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="8" Padding="10" Background="#F0FFFFFF"
                BorderBrush="Gray" BorderThickness="1" CornerRadius="4"
                Panel.ZIndex="20">
            <StackPanel Width="200">
                <Grid>
                    <TextBlock Text="{DynamicResource FemCreateNodePanelTitle}" FontWeight="Bold"/>
                    <Button Content="{DynamicResource FemPanelClose}"
                            HorizontalAlignment="Right" Padding="4,0"
                            Click="CloseCreateNodePanel_Click"/>
                </Grid>
                <TextBlock Text="{DynamicResource FemCreateNodeHint}"
                           TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,4,0,8"/>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource FemCreateNodeX}" Grid.Column="0"/>
                    <TextBox x:Name="createNodeXBox" Grid.Column="1" Text="0"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource FemCreateNodeY}" Grid.Column="0"/>
                    <TextBox x:Name="createNodeYBox" Grid.Column="1" Text="0"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource FemCreateNodeZ}" Grid.Column="0"/>
                    <TextBox x:Name="createNodeZBox" Grid.Column="1" Text="0"/>
                </Grid>
                <Button Content="{DynamicResource FemCreateNodeAdd}" Margin="0,8,0,0"
                        Click="CreateNodeFromPanel_Click"/>
            </StackPanel>
        </Border>

        <!-- Немодальная панель «Добавить элемент» -->
        <Border x:Name="createBarPanel" Grid.Row="1"
                Visibility="Collapsed"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="8" Padding="10" Background="#F0FFFFFF"
                BorderBrush="Gray" BorderThickness="1" CornerRadius="4"
                Panel.ZIndex="20">
            <StackPanel Width="220">
                <Grid>
                    <TextBlock Text="{DynamicResource FemCreateMemberPanelTitle}" FontWeight="Bold"/>
                    <Button Content="{DynamicResource FemPanelClose}"
                            HorizontalAlignment="Right" Padding="4,0"
                            Click="CloseCreateBarPanel_Click"/>
                </Grid>
                <TextBlock Text="{DynamicResource FemCreateMemberHint}"
                           TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,4,0,8"/>
                <TextBlock Text="{DynamicResource FemCreateMemberSection}" Margin="0,2"/>
                <ComboBox x:Name="createBarSectionCombo"
                          DisplayMemberPath="Tag"
                          SelectionChanged="CreateBarSectionCombo_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- Оверлей загрузки -->
        <Border Grid.Row="1"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                Background="#80000000" Panel.ZIndex="10">
            <TextBlock Text="{Binding Status}"
                       Foreground="White" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Оверлей «нет данных» -->
        <Border Grid.Row="1"
                Visibility="{Binding NoData, Converter={StaticResource BoolToVisibility}}"
                Background="#80000000" Panel.ZIndex="10">
            <TextBlock Text="{DynamicResource Fem3DNoData}"
                       Foreground="White" FontSize="13" TextWrapping="Wrap"
                       MaxWidth="400"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
