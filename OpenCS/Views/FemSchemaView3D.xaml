<UserControl x:Class="OpenCS.Views.FemSchemaView3D"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0">
            <Button Content="{DynamicResource Fem3DZoomExtents}"
                    Click="ZoomExtents_Click" Padding="8,2"/>
            <Separator/>
            <CheckBox x:Name="showNodesCheck"
                      Content="{DynamicResource Fem3DShowNodes}"
                      IsChecked="True"
                      VerticalAlignment="Center" Margin="4,0"
                      Checked="NodesToggle" Unchecked="NodesToggle"/>
            <CheckBox x:Name="showShellEdgesCheck"
                      Content="{DynamicResource Fem3DShowShellEdges}"
                      VerticalAlignment="Center" Margin="4,0"
                      Checked="ShellEdgesToggle" Unchecked="ShellEdgesToggle"/>
        </ToolBar>

        <!-- 3D viewport -->
        <h:HelixViewport3D x:Name="viewport" Grid.Row="1"
                           Background="White"
                           ShowCoordinateSystem="True"
                           ShowViewCube="True"
                           ZoomAroundMouseDownPoint="True"/>

        <!-- Оверлей загрузки -->
        <Border Grid.Row="1"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                Background="#80000000" Panel.ZIndex="10">
            <TextBlock Text="{Binding Status}"
                       Foreground="White" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Оверлей «нет данных» -->
        <Border Grid.Row="1"
                Visibility="{Binding NoData, Converter={StaticResource BoolToVisibility}}"
                Background="#80000000" Panel.ZIndex="10">
            <TextBlock Text="{DynamicResource Fem3DNoData}"
                       Foreground="White" FontSize="13" TextWrapping="Wrap"
                       MaxWidth="400"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
