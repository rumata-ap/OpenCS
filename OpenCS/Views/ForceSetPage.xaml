<UserControl x:Class="OpenCS.Views.ForceSetPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenCS.ViewModels"
             xmlns:core="clr-namespace:CScore;assembly=CScore">

   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Верхняя панель: обозначение + кнопка Сохранить -->
      <Border Grid.Row="0" BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
              Padding="8,6">
         <StackPanel Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Tag}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding Tag, UpdateSourceTrigger=PropertyChanged}"
                     Width="220" Margin="0,0,12,0"/>
            <Button Content="{DynamicResource Save}"
                    Command="{Binding SaveCommand}"
                    Padding="16,3"/>
         </StackPanel>
      </Border>

      <!-- Таблица усилий -->
      <DataGrid Grid.Row="1"
                ItemsSource="{Binding Items}"
                SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                Margin="4,4,4,0">

         <DataGrid.Columns>

            <!-- # -->
            <DataGridTextColumn Binding="{Binding Num, Mode=OneWay}"
                                IsReadOnly="True" Width="36">
               <DataGridTextColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                     <Setter Property="HorizontalContentAlignment" Value="Center"/>
                  </Style>
               </DataGridTextColumn.HeaderStyle>
               <DataGridTextColumn.Header>
                  <TextBlock Text="#" HorizontalAlignment="Center"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                     <Setter Property="HorizontalAlignment" Value="Center"/>
                     <Setter Property="VerticalAlignment" Value="Center"/>
                     <Setter Property="Foreground" Value="Gray"/>
                  </Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- Обозначение -->
            <DataGridTextColumn Binding="{Binding Tag, UpdateSourceTrigger=PropertyChanged}"
                                Width="120">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColTag}"/>
               </DataGridTextColumn.Header>
            </DataGridTextColumn>

            <!-- N -->
            <DataGridTextColumn Binding="{Binding N, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="90">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColN}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                     <Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/>
                  </Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- My -->
            <DataGridTextColumn Binding="{Binding My, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="90">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColMy}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                     <Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/>
                  </Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- Mz -->
            <DataGridTextColumn Binding="{Binding Mz, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="90">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColMz}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                     <Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/>
                  </Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <!-- CalcType -->
            <DataGridTemplateColumn Width="80">
               <DataGridTemplateColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColCalcType}"/>
               </DataGridTemplateColumn.Header>
               <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                     <TextBlock Text="{Binding CalcType}" VerticalAlignment="Center" Margin="4,0"/>
                  </DataTemplate>
               </DataGridTemplateColumn.CellTemplate>
               <DataGridTemplateColumn.CellEditingTemplate>
                  <DataTemplate>
                     <ComboBox ItemsSource="{Binding CalcTypeValues}"
                               SelectedItem="{Binding CalcType, UpdateSourceTrigger=PropertyChanged}"
                               IsDropDownOpen="True"/>
                  </DataTemplate>
               </DataGridTemplateColumn.CellEditingTemplate>
            </DataGridTemplateColumn>

         </DataGrid.Columns>
      </DataGrid>

      <!-- Кнопки внизу -->
      <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="4,4,4,4">
         <Button Content="{DynamicResource AddForceItem}"
                 Command="{Binding AddItemCommand}"
                 Padding="12,3" Margin="0,0,4,0"/>
         <Button Content="{DynamicResource DuplicateForceItem}"
                 Command="{Binding DuplicateItemCommand}"
                 Padding="12,3" Margin="0,0,4,0"/>
         <Button Content="{DynamicResource DeleteForceItem}"
                 Command="{Binding DeleteItemCommand}"
                 Padding="12,3"/>
      </StackPanel>

   </Grid>
</UserControl>
