<UserControl x:Class="OpenCS.Views.ForceSetPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenCS.ViewModels">

   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Верхняя панель -->
      <Border Grid.Row="0" BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
              Padding="8,6">
         <StackPanel Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Tag}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding Tag, UpdateSourceTrigger=PropertyChanged}"
                     Width="260" Margin="0,0,12,0"/>
            <Button Content="{DynamicResource Save}"
                    Command="{Binding SaveCommand}"
                    Padding="16,3" Margin="0,0,8,0"/>
            <Separator Width="1" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource SP20CombineBtn}"
                    Command="{Binding SP20Command}"
                    Padding="12,3"/>
         </StackPanel>
      </Border>

      <!-- Таблица усилий -->
      <DataGrid Grid.Row="1"
                ItemsSource="{Binding Items}"
                SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                Margin="4,4,4,0">

         <DataGrid.Columns>

            <DataGridTextColumn Binding="{Binding Num, Mode=OneWay}" IsReadOnly="True" Width="36">
               <DataGridTextColumn.Header>
                  <TextBlock Text="#" HorizontalAlignment="Center"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                     <Setter Property="HorizontalAlignment" Value="Center"/>
                     <Setter Property="VerticalAlignment" Value="Center"/>
                     <Setter Property="Foreground" Value="Gray"/>
                  </Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                Width="140">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColLabel}"/>
               </DataGridTextColumn.Header>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding N, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="80">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColN}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding Mx, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="80">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColMx}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding My, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="80">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColMy}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding Vx, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="75">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColVx}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding Vy, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="75">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColVy}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

            <DataGridTextColumn Binding="{Binding T, StringFormat=G6, UpdateSourceTrigger=PropertyChanged}"
                                Width="75">
               <DataGridTextColumn.Header>
                  <TextBlock Text="{DynamicResource ForceColT}"/>
               </DataGridTextColumn.Header>
               <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/>
                     <Setter Property="VerticalAlignment" Value="Center"/></Style>
               </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>

         </DataGrid.Columns>
      </DataGrid>

      <!-- Кнопки внизу -->
      <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="4,4,4,4">
         <Button Content="{DynamicResource AddForceItem}"
                 Command="{Binding AddItemCommand}"
                 Padding="12,3" Margin="0,0,4,0"/>
         <Button Content="{DynamicResource DuplicateForceItem}"
                 Command="{Binding DuplicateItemCommand}"
                 Padding="12,3" Margin="0,0,4,0"/>
         <Button Content="{DynamicResource DeleteForceItem}"
                 Command="{Binding DeleteItemCommand}"
                 Padding="12,3"/>
      </StackPanel>

   </Grid>
</UserControl>
