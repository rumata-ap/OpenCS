<UserControl x:Class="OpenCS.Views.ContourPlot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpenCS.Views"
             xmlns:vm="clr-namespace:OpenCS.ViewModels"
             xmlns:core="clr-namespace:CScore;assembly=CScore"

             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
   
   <UserControl.DataContext>
      <vm:ContourVM/>
   </UserControl.DataContext>

   <UserControl.Resources>
      <ResourceDictionary Source="/Images/svg.xaml"/>
   </UserControl.Resources>

   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="Auto"/>
         <ColumnDefinition/>
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0" Margin="5">
         <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
         </Grid.RowDefinitions>

         <GroupBox Header="{DynamicResource ContourTagHeader}" Grid.Row="0">
            <TextBox Text="{Binding Tag}" Height="25" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
         </GroupBox>

         <GroupBox Header="{DynamicResource ContourSetHeader}" Grid.Row="1">
            <TextBox Text="{Binding Set}" Height="25" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
         </GroupBox>

         <GroupBox Header="{DynamicResource ContourDrawAreaHeader}" Grid.Row="2" VerticalAlignment="Top"
                   Visibility="{Binding IsEdit, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
               <Grid Margin="0,0,0,4"
                     Visibility="{Binding IsDrawingSetup, Converter={StaticResource BoolToVisibility}}">
                  <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="Auto"/>
                     <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>

                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource ContourDrawWidth}" VerticalAlignment="Center" Margin="0,0,8,4"/>
                  <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ViewWidth, UpdateSourceTrigger=PropertyChanged, StringFormat=F4}" Height="24" Margin="0,0,0,4"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource ContourDrawHeight}" VerticalAlignment="Center" Margin="0,0,8,4"/>
                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ViewHeight, UpdateSourceTrigger=PropertyChanged, StringFormat=F4}" Height="24" Margin="0,0,0,4"/>
               </Grid>

               <Grid Margin="0,0,0,4">
                  <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="Auto"/>
                     <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>

                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource ContourGridStep}" VerticalAlignment="Center" Margin="0,0,8,4"/>
                  <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding GridStepMmOptions}"
                            SelectedItem="{Binding GridStepMm}" Height="24" Margin="0,0,0,4"/>

                  <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                            Content="{DynamicResource ContourSnapToGrid}" IsChecked="{Binding SnapToGrid}" Margin="0,0,0,2"/>
               </Grid>

               <Button Command="{Binding BeginDrawingCommand}" Content="{DynamicResource ContourBeginDrawing}"
                       ToolTip="{DynamicResource TipContourBeginDrawing}" Height="28" HorizontalAlignment="Stretch" Margin="0,2,0,4"
                       Visibility="{Binding IsDrawingSetup, Converter={StaticResource BoolToVisibility}}"/>

               <TextBlock Text="{DynamicResource ContourDrawSetupHint}" TextWrapping="Wrap"
                          Foreground="#6B7280" FontStyle="Italic" FontSize="11"
                          Visibility="{Binding IsDrawingSetup, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
         </GroupBox>

         <GroupBox Header="{DynamicResource ContourCoordinates}" Grid.Row="3" VerticalAlignment="Top">
            <Grid>
               <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
               </Grid.RowDefinitions>

               <Grid>
                   <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="auto"/>
                      <ColumnDefinition Width="auto"/>
                      <ColumnDefinition Width="auto"/>
                      <ColumnDefinition Width="auto"/>
                      <ColumnDefinition Width="auto"/>
                      <ColumnDefinition Width="auto"/>
                      <ColumnDefinition Width="auto"/>
                      <ColumnDefinition Width="auto"/>
                      <ColumnDefinition />
                   </Grid.ColumnDefinitions>

                   <Button Grid.Column="0" Height="26" Width="26" Margin="1" Background="Transparent" BorderThickness="0"
                           IsEnabled="{Binding IsEdit}" Command="{Binding RenumPointCommand}"
                           ToolTip="{DynamicResource TipRenumContour}">
                      <Image Source="{StaticResource di_list_xaml}"/>
                   </Button>

                   <Button Grid.Column="1" Height="26" Width="26" Margin="1" Background="Transparent" BorderThickness="0"
                           IsEnabled="{Binding IsEdit}" Command="{Binding CloseContourCommand}"
                           ToolTip="{DynamicResource TipCloseContour}">
                      <Viewbox Width="16" Height="16">
                         <Path Stroke="#4B5563" StrokeThickness="2.5" Fill="Transparent"
                               StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                               Data="M4 12a8 8 0 1 1 8-8 M12 4v4h4"/>
                      </Viewbox>
                   </Button>

                   <Button Grid.Column="2" Height="26" Width="26" Margin="1" Background="Transparent" BorderThickness="0"
                           IsEnabled="{Binding IsEdit}" Command="{Binding ExportCsvCommand}"
                           ToolTip="{DynamicResource TipExportContourCsv}">
                      <Image Source="{StaticResource di_from_csv_xaml}"/>
                   </Button>

                   <Button Grid.Column="3" Height="26" Width="26" Margin="1" Background="Transparent" BorderThickness="0"
                           IsEnabled="{Binding IsEdit}" Command="{Binding ImportCsvCommand}"
                           ToolTip="{DynamicResource TipImportContourCsv}">
                      <Image Source="{StaticResource di_to_csv_xaml}"/>
                   </Button>

                   <Button Grid.Column="4" Width="25" Margin="1" Background="Transparent" BorderThickness="0"
                           Command="{Binding SaveCommand}" IsEnabled="{Binding IsEdit}"
                           ToolTip="{DynamicResource TipSaveContour}">
                      <Image Source="{StaticResource di_save_xaml}"/>
                   </Button>

                    <Button Grid.Column="5" Height="26" Width="26" Margin="1" Background="Transparent" BorderThickness="0"
                            Command="{Binding TranslateCommand}"
                            ToolTip="{DynamicResource TipTranslateContour}">
                       <Viewbox Width="16" Height="16">
                          <Path Stroke="#4B5563" StrokeThickness="4" Fill="Transparent"
                                StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                Data="M20 8L24 4M24 4L28 8M24 4V16 M20 40L24 44M24 44L28 40M24 44V32 M40 20L44 24M44 24L40 28M44 24H32 M8 20L4 24M4 24L8 28M4 24H16 M22 24a2 2 0 1 0 4 0 2 2 0 1 0-4 0z"/>
                       </Viewbox>
                    </Button>

                    <Button Grid.Column="6" Height="26" Width="26" Margin="1" Background="Transparent" BorderThickness="0"
                            Command="{Binding ScaleCommand}"
                            ToolTip="{DynamicResource TipScaleContour}">
                       <Viewbox Width="16" Height="16">
                          <Path Stroke="#4B5563" StrokeThickness="2" Fill="Transparent"
                                StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                Data="M16 21H16.2C17.8802 21 18.7202 21 19.362 20.673C19.9265 20.3854 20.3854 19.9265 20.673 19.362C21 18.7202 21 17.8802 21 16.2V7.8C21 6.11984 21 5.27976 20.673 4.63803C20.3854 4.07354 19.9265 3.6146 19.362 3.32698C18.7202 3 17.8802 3 16.2 3H7.8C6.11984 3 5.27976 3 4.63803 3.32698C4.07354 3.6146 3.6146 4.07354 3.32698 4.63803C3 5.27976 3 6.11984 3 7.8V8M11.5 12.5L17 7M17 7H12M17 7V12M6.2 21H8.8C9.9201 21 10.4802 21 10.908 20.782C11.2843 20.5903 11.5903 20.2843 11.782 19.908C12 19.4802 12 18.9201 12 17.8V15.2C12 14.0799 12 13.5198 11.782 13.092C11.5903 12.7157 11.2843 12.4097 10.908 12.218C10.4802 12 9.92011 12 8.8 12H6.2C5.0799 12 4.51984 12 4.09202 12.218C3.71569 12.4097 3.40973 12.7157 3.21799 13.092C3 13.5198 3 14.0799 3 15.2V17.8C3 18.9201 3 19.4802 3.21799 19.908C3.40973 20.2843 3.71569 20.5903 4.09202 20.782C4.51984 21 5.07989 21 6.2 21Z"/>
                       </Viewbox>
                    </Button>

                    <Button Grid.Column="7" Height="26" Width="26" Margin="1" Background="Transparent" BorderThickness="0"
                            Command="{Binding ShowPropertiesCommand}"
                            ToolTip="{DynamicResource TipShowProperties}">
                       <Viewbox Width="16" Height="16">
                          <Path Fill="#4B5563" Stretch="Uniform"
                                Data="M11 17h2v-6h-2v6zm1-15C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zM11 9h2V7h-2v2z"/>
                       </Viewbox>
                    </Button>

                   <ToggleButton Name="EditTB" Grid.Column="8" Width="25" Margin="1" Background="Transparent" BorderThickness="0"
                                 Command="{Binding SaveChangesCommand}" HorizontalAlignment="Right" IsChecked="{Binding IsEdit}"
                                 ToolTip="{DynamicResource TipToggleEdit}">
                      <Image Source="{StaticResource di_edit_xaml}"/>
                   </ToggleButton>

               </Grid>

               <DataGrid Grid.Row="1" ItemsSource="{Binding Points}" SelectedItem="{Binding Point}" AutoGenerateColumns="False" MaxHeight="400"
                         CanUserAddRows="{Binding IsEdit}" CanUserDeleteRows="{Binding IsEdit}"
                         HorizontalAlignment="Stretch">
                  <DataGrid.Columns>
                     <DataGridTextColumn Header="{DynamicResource Number}" Binding="{Binding Path=Num}" Width="40"/>
                     <DataGridTextColumn Header="{DynamicResource X_m}" Binding="{Binding Path=X, StringFormat={}{0:F4}}" Width="100"/>
                     <DataGridTextColumn Header="{DynamicResource Y_m}" Binding="{Binding Path=Y, StringFormat={}{0:F4}}" Width="100"/>
                  </DataGrid.Columns>
                  <!--<DataGrid.ContextMenu>
                     <ContextMenu IsEnabled="{Binding ElementName=EditTB, Path=IsChecked}">
                        <MenuItem Header="Перенумеровать" Command="{Binding RenumPointCommand}">
                           <MenuItem.Icon>
                              <Image Source="{StaticResource di_list_xaml}"/>
                           </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Импорт из csv" Command="{Binding ImportCsvCommand}">
                           <MenuItem.Icon>
                              <Image Source="{StaticResource di_to_csv_xaml}"/>
                           </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Экспорт в csv" Command="{Binding ExportCsvCommand}">
                           <MenuItem.Icon>
                              <Image Source="{StaticResource di_from_csv_xaml}"/>
                           </MenuItem.Icon>
                        </MenuItem>
                     </ContextMenu>
                  </DataGrid.ContextMenu>-->
               </DataGrid>

               <StackPanel Grid.Row="2" Margin="0,4,0,0" MaxWidth="240">
                  <TextBlock Text="{DynamicResource ContourDrawActiveHint}" TextWrapping="Wrap"
                             Foreground="#6B7280" FontStyle="Italic" FontSize="11" Margin="0,0,0,2"
                             Visibility="{Binding IsDrawingActive, Converter={StaticResource BoolToVisibility}}"/>
                  <TextBlock Text="{DynamicResource ContourClosingHint}" TextWrapping="Wrap"
                             Foreground="#6B7280" FontStyle="Italic" FontSize="11" Margin="0,0,0,2"
                             Visibility="{Binding IsEdit, Converter={StaticResource BoolToVisibility}}"/>
                  <TextBlock Text="{DynamicResource ContourNeedsClosingHint}" TextWrapping="Wrap"
                             Foreground="#B45309" FontWeight="SemiBold" FontSize="11"
                             Visibility="{Binding NeedsClosingHint, Converter={StaticResource BoolToVisibility}}"/>
               </StackPanel>
               
            </Grid>
         </GroupBox>
         
      </Grid>

      <local:ContourEditCanvas x:Name="ViewCanvas" Margin="5,10,5,5" Grid.Column="1"/>
      
      <TextBlock Grid.Column="1" Text="{Binding Description}" Margin="5"  IsEnabled="False" 
                        VerticalAlignment="Top" HorizontalAlignment="Center"/>

   </Grid>
</UserControl>
