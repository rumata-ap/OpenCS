<UserControl x:Class="OpenCS.Views.FireMeshPlotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:OpenCS.Views.Helpers">

   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
              Padding="6,4">
         <Grid>
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="Auto"/>
               <ColumnDefinition Width="*"/>
               <ColumnDefinition Width="Auto"/>
               <ColumnDefinition Width="Auto"/>
               <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource FirePlot_TimeLabel}" VerticalAlignment="Center" Margin="0,0,8,0"
                       Visibility="{Binding HasTimeSlider, Converter={StaticResource BoolToVisibility}}"/>
            <Slider Grid.Column="1" Minimum="{Binding TimeMin}" Maximum="{Binding TimeMax}"
                    Value="{Binding SelectedTimeMin}" VerticalAlignment="Center"
                    Visibility="{Binding HasTimeSlider, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Grid.Column="2" Text="{Binding TimeLabelText}" Margin="8,0,12,0"
                       VerticalAlignment="Center" FontFamily="Consolas"
                       Visibility="{Binding HasTimeSlider, Converter={StaticResource BoolToVisibility}}"/>
            <CheckBox Grid.Column="3" Content="{DynamicResource PlotShowValues}"
                      IsChecked="{Binding ShowValues}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button Grid.Column="4" Content="{DynamicResource PlotFitAll}"
                    Command="{Binding FitAllCommand}" Padding="8,2"/>
         </Grid>
      </Border>

      <Border Grid.Row="1" BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
              Padding="6,4"
              Visibility="{Binding IsTemperatureMode, Converter={StaticResource BoolToVisibility}}">
         <StackPanel Orientation="Horizontal">
            <CheckBox Content="{DynamicResource PlotSmoothColormap}"
                      IsChecked="{Binding SmoothColormap}" VerticalAlignment="Center" Margin="0,0,16,0"/>
            <CheckBox Content="{DynamicResource FireThermal_ShowIsolines}"
                      IsChecked="{Binding ShowIsolines}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <CheckBox Content="{DynamicResource FireThermal_IsolineLabels}"
                      IsChecked="{Binding ShowIsolineLabels}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{DynamicResource FireThermal_IsolineStep}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox x:Name="isolineStepBox"
                     Text="{Binding IsolineStepText, UpdateSourceTrigger=LostFocus}"
                     Width="56" VerticalAlignment="Center" Margin="0,0,4,0"
                     KeyDown="IsolineStep_KeyDown"
                     LostFocus="IsolineStep_LostFocus"/>
            <TextBlock Text="°C" VerticalAlignment="Center" Foreground="Gray"/>
         </StackPanel>
      </Border>

      <Grid Grid.Row="2">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
         </Grid.ColumnDefinitions>
         <Border Grid.Column="0" Margin="4"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
            <h:FireMeshCanvas x:Name="meshCanvas" ViewModel="{Binding}"/>
         </Border>
         <Border Grid.Column="1" Width="64" Margin="4"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
            <DockPanel>
               <TextBlock DockPanel.Dock="Top" Text="{Binding ColorbarTitle}"
                          FontSize="10" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,2"/>
               <ItemsControl ItemsSource="{Binding ColorBands}">
                  <ItemsControl.ItemsPanel>
                     <ItemsPanelTemplate>
                        <UniformGrid Columns="1"/>
                     </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                     <DataTemplate>
                        <Grid>
                           <Rectangle Fill="{Binding Brush}"/>
                           <TextBlock Text="{Binding Label}" FontSize="9"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                     </DataTemplate>
                  </ItemsControl.ItemTemplate>
               </ItemsControl>
            </DockPanel>
         </Border>
      </Grid>
   </Grid>
</UserControl>
