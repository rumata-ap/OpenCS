<UserControl x:Class="OpenCS.Views.CrackWidthResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
   <Grid Margin="16">
      <StackPanel>
         <Border Padding="12,8" CornerRadius="4" Background="{Binding StatusBrush}" Margin="0,0,0,12">
            <TextBlock Text="{Binding SummaryText}" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14"/>
         </Border>

         <Border Padding="8,6" CornerRadius="4" Background="#F0F4F8" BorderBrush="#D5DDE5" BorderThickness="1" Margin="0,0,0,8">
            <StackPanel>
               <TextBlock Margin="0,2"><Run Text="N, кН: "/><Run Text="{Binding NText, Mode=OneWay}" FontWeight="Bold"/></TextBlock>
               <TextBlock Margin="0,2"><Run Text="Mx,дл / Mx,полн, кН·м: "/><Run Text="{Binding MxLongText, Mode=OneWay}" FontWeight="Bold"/><Run Text=" / "/><Run Text="{Binding MxTotalText, Mode=OneWay}" FontWeight="Bold"/></TextBlock>
               <TextBlock Margin="0,2"><Run Text="Mcrc, кН·м: "/><Run Text="{Binding McrcText, Mode=OneWay}" FontWeight="Bold"/></TextBlock>
            </StackPanel>
         </Border>

         <Border Padding="8,6" CornerRadius="4" Background="#FFF8F0" BorderBrush="#E8D5C0" BorderThickness="1"
                 Visibility="{Binding Cracked, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
               <TextBlock Margin="0,2"><Run Text="acrc,дл, мм: "/><Run Text="{Binding AcrcLongText, Mode=OneWay}" FontWeight="Bold" FontSize="14"/></TextBlock>
               <TextBlock Margin="0,2"><Run Text="acrc,кратк, мм: "/><Run Text="{Binding AcrcShortText, Mode=OneWay}" FontWeight="Bold" FontSize="14"/></TextBlock>
               <TextBlock Margin="0,6,0,2" FontSize="11" Foreground="#666">
                  <Run Text="σs, МПа: "/><Run Text="{Binding SigmaSText, Mode=OneWay}"/>
                  <Run Text="   ψs: "/><Run Text="{Binding PsiSText, Mode=OneWay}"/>
                  <Run Text="   ls, мм: "/><Run Text="{Binding LsText, Mode=OneWay}"/>
                  <Run Text="   ds,экв, мм: "/><Run Text="{Binding DsEqText, Mode=OneWay}"/>
               </TextBlock>
            </StackPanel>
         </Border>

         <Border Padding="8,6" CornerRadius="4" Background="#F5F0FA" BorderBrush="#D8D0E8" BorderThickness="1"
                 Margin="0,8,0,0"
                 Visibility="{Binding EtaEnabled, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
               <TextBlock Text="{DynamicResource EtaParamsHeader}" FontWeight="SemiBold" Margin="0,0,0,4"/>
               <TextBlock Text="{Binding EtaModeText}" Margin="0,2"/>
               <TextBlock Margin="0,2">
                  <Run Text="ηx: "/><Run Text="{Binding EtaXText, Mode=OneWay}" FontWeight="Bold"/>
                  <Run Text="   ηy: "/><Run Text="{Binding EtaYText, Mode=OneWay}" FontWeight="Bold"/>
               </TextBlock>
               <TextBlock Text="{Binding EtaPsiText}" Margin="0,2" Foreground="#555"/>
               <TextBlock Text="{Binding EtaMxText}" Margin="0,2"/>
               <TextBlock Text="{Binding EtaMyText}" Margin="0,2"/>
            </StackPanel>
         </Border>

         <TextBlock Text="{Binding ErrorText}" Foreground="DarkRed" TextWrapping="Wrap" Margin="0,8,0,0"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>
      </StackPanel>
   </Grid>
</UserControl>
