<Window x:Class="OpenCS.Views.DiagramSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:CScore;assembly=CScore"
        Title="{DynamicResource SelectDiagramType}"
        Height="250" Width="380"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
   <Grid Margin="10">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Text="{DynamicResource AvailableDiagramTypes}" FontWeight="SemiBold" Margin="0,0,0,8"/>
      <ListBox x:Name="diagramTypeList" Grid.Row="1" Margin="0,0,0,10">
         <ListBox.ItemTemplate>
            <DataTemplate>
               <TextBlock Text="{Binding Label}" Margin="4"/>
            </DataTemplate>
         </ListBox.ItemTemplate>
      </ListBox>
      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
         <Button Content="OK" Click="Ok_Click" Width="80" Height="28" Margin="0,0,8,0" IsDefault="True"/>
         <Button Content="{DynamicResource Cancel}" Click="Cancel_Click" Width="80" Height="28" IsCancel="True"/>
      </StackPanel>
   </Grid>
</Window>