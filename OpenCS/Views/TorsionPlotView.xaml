<UserControl x:Class="OpenCS.Views.TorsionPlotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:OpenCS.Views.Helpers">
   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
              Padding="6,4">
         <StackPanel Orientation="Horizontal">
            <CheckBox Content="{DynamicResource TorsionShowPhysicalTau}"
                      IsChecked="{Binding ShowPhysicalTau}"
                      Margin="0,0,10,0" VerticalAlignment="Center"
                      Visibility="{Binding CanShowPhysicalTau, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{Binding BoundaryNote}" Foreground="Gray" FontStyle="Italic"
                       Margin="0,0,14,0" VerticalAlignment="Center"
                       Visibility="{Binding IsBoundaryOnly, Converter={StaticResource BoolToVisibility}}"/>
            <Button Content="{DynamicResource PlotFitAll}"
                    Command="{Binding FitAllCommand}" Padding="8,2"/>
         </StackPanel>
      </Border>

      <Grid Grid.Row="1">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
         </Grid.ColumnDefinitions>

         <Border Grid.Column="0" Margin="4"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
            <h:TorsionFieldCanvas ViewModel="{Binding}"/>
         </Border>

         <Border Grid.Column="1" Width="64" Margin="4"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                 Visibility="{Binding HasField, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
               <TextBlock DockPanel.Dock="Top" Text="{Binding ValueUnit}"
                          FontSize="10" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,2"/>
               <ItemsControl ItemsSource="{Binding ColorBands}">
                  <ItemsControl.ItemsPanel>
                     <ItemsPanelTemplate>
                        <UniformGrid Columns="1"/>
                     </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                     <DataTemplate>
                        <Grid>
                           <Rectangle Fill="{Binding Brush}"/>
                           <TextBlock Text="{Binding Label}" FontSize="9"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                     </DataTemplate>
                  </ItemsControl.ItemTemplate>
               </ItemsControl>
            </DockPanel>
         </Border>
      </Grid>
   </Grid>
</UserControl>
