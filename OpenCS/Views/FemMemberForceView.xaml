<UserControl x:Class="OpenCS.Views.FemMemberForceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:u="clr-namespace:OpenCS.Utilites"
             xmlns:helpers="clr-namespace:OpenCS.Views.Helpers">
    <UserControl.Resources>
        <u:FemForceComponentLabelConverter x:Key="ForceComponentLabelConv"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6">
            <TextBlock Text="{DynamicResource FemMemberForceComponent}" VerticalAlignment="Center"/>
            <ComboBox x:Name="componentBox" Width="100" Margin="6,0"
                      SelectionChanged="ComponentBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource ForceComponentLabelConv}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" Margin="6">
            <helpers:FemMemberForceCanvas x:Name="canvas"/>
        </Border>
    </Grid>
</UserControl>
