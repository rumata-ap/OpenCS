<UserControl x:Class="OpenCS.Views.PlateSectionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenCS.ViewModels">

   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Верхняя панель -->
      <Border Grid.Row="0" BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
              Padding="8,6">
         <StackPanel Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Tag}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding Tag, UpdateSourceTrigger=PropertyChanged}"
                     Width="240" Margin="0,0,12,0"/>
            <Button Style="{StaticResource IconButton25}"
                    Command="{Binding SaveCommand}"
                    ToolTip="{DynamicResource Save}"
                    Margin="0,0,8,0">
               <Path Width="16" Height="16" Stretch="Uniform"
                     Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                     Data="M17 3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V7L17 3M19 19H5V5H16.17L19 7.83V19M12 12C10.34 12 9 13.34 9 15S10.34 18 12 18 15 16.66 15 15 13.66 12 12 12M6 6H15V10H6V6Z"/>
            </Button>
         </StackPanel>
      </Border>

      <!-- Основное содержимое -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
         <StackPanel Margin="10">

            <!-- Геометрия -->
            <GroupBox Header="{DynamicResource PlateSectionGeometry}" Margin="0,0,0,8">
               <Grid Margin="6">
                  <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="160"/>
                     <ColumnDefinition Width="120"/>
                     <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>

                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource PlateThicknessMm}"
                             VerticalAlignment="Center" Margin="0,0,8,4"/>
                  <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                           Text="{Binding HMm, UpdateSourceTrigger=PropertyChanged, StringFormat=G6}"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource PlateNLayers}"
                             VerticalAlignment="Center" Margin="0,0,8,4"/>
                  <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                           IsEnabled="{Binding IsLayered}"
                           Text="{Binding NLayers, UpdateSourceTrigger=PropertyChanged}"/>
               </Grid>
            </GroupBox>

            <!-- Материалы -->
            <GroupBox Header="{DynamicResource PlateSectionMaterials}" Margin="0,0,0,8">
               <Grid Margin="6">
                  <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="160"/>
                     <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>

                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Concrete}"
                             VerticalAlignment="Center" Margin="0,0,8,4"/>
                  <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                            ItemsSource="{Binding App.Concretes}"
                            SelectedItem="{Binding ConcreteMaterial, Mode=TwoWay}"
                            DisplayMemberPath="Tag"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Reinforcement}"
                             VerticalAlignment="Center" Margin="0,0,8,4"/>
                  <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                            ItemsSource="{Binding App.Armatures}"
                            SelectedItem="{Binding RebarMaterial, Mode=TwoWay}"
                            DisplayMemberPath="Tag"/>

                  <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource PlateTensionConcrete}"
                             VerticalAlignment="Center" Margin="0,0,8,4"/>
                  <CheckBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,4"
                            IsChecked="{Binding TensionConcrete, Mode=TwoWay}"
                            VerticalAlignment="Center"/>

                  <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource PlateSofteningModel}"
                             VerticalAlignment="Center" Margin="0,0,8,4"/>
                  <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,4"
                            ItemsSource="{Binding SofteningOptions}"
                            SelectedIndex="{Binding SofteningIndex, Mode=TwoWay}"/>

                  <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource PlateModel}"
                             VerticalAlignment="Center" Margin="0,0,8,4"/>
                  <ComboBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,4"
                            ItemsSource="{Binding PlateModelOptions}"
                            SelectedValuePath="Key" DisplayMemberPath="Display"
                            SelectedValue="{Binding PlateModel, Mode=TwoWay}"/>
               </Grid>
            </GroupBox>

            <!-- Арматурные слои -->
            <GroupBox Header="{DynamicResource PlateRebarLayers}" Margin="0,0,0,8">
               <StackPanel>
                  <DataGrid ItemsSource="{Binding RebarLayers}"
                            SelectedItem="{Binding SelectedRebarLayer, Mode=TwoWay}"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            SelectionMode="Single"
                            SelectionUnit="FullRow"
                            GridLinesVisibility="Horizontal"
                            HeadersVisibility="Column"
                            Margin="4,4,4,4"
                            MaxHeight="280">

                     <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource PlateLayerName}"
                                            Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                            Width="100"/>
                        <DataGridComboBoxColumn Header="{DynamicResource PlateLayerMode}"
                                                SelectedValueBinding="{Binding InputMode, UpdateSourceTrigger=PropertyChanged}"
                                                SelectedValuePath="Key" DisplayMemberPath="Display"
                                                Width="140">
                           <DataGridComboBoxColumn.EditingElementStyle>
                              <Style TargetType="ComboBox">
                                 <Setter Property="ItemsSource" Value="{Binding DataContext.InputModeOptions,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                              </Style>
                           </DataGridComboBoxColumn.EditingElementStyle>
                           <DataGridComboBoxColumn.ElementStyle>
                              <Style TargetType="ComboBox">
                                 <Setter Property="ItemsSource" Value="{Binding DataContext.InputModeOptions,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                              </Style>
                           </DataGridComboBoxColumn.ElementStyle>
                        </DataGridComboBoxColumn>

                        <DataGridTextColumn Header="{DynamicResource PlateLayerDiamX}"
                                            Binding="{Binding DiameterXMm, UpdateSourceTrigger=PropertyChanged, StringFormat=G4}"
                                            Width="70">
                           <DataGridTextColumn.EditingElementStyle>
                              <Style TargetType="TextBox">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="direct">
                                       <Setter Property="IsReadOnly" Value="True"/>
                                    </DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.EditingElementStyle>
                           <DataGridTextColumn.ElementStyle>
                              <Style TargetType="TextBlock">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="direct">
                                       <Setter Property="Foreground" Value="Gray"/>
                                    </DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{DynamicResource PlateLayerSpacingX}"
                                            Binding="{Binding SpacingXMm, UpdateSourceTrigger=PropertyChanged, StringFormat=G4}"
                                            Width="75">
                           <DataGridTextColumn.EditingElementStyle>
                              <Style TargetType="TextBox">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_count"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                    <DataTrigger Binding="{Binding InputMode}" Value="direct"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.EditingElementStyle>
                           <DataGridTextColumn.ElementStyle>
                              <Style TargetType="TextBlock">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_count"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                    <DataTrigger Binding="{Binding InputMode}" Value="direct"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{DynamicResource PlateLayerCountX}"
                                            Binding="{Binding CountPerMeterX, UpdateSourceTrigger=PropertyChanged, StringFormat=G4}"
                                            Width="85">
                           <DataGridTextColumn.EditingElementStyle>
                              <Style TargetType="TextBox">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_spacing"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                    <DataTrigger Binding="{Binding InputMode}" Value="direct"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.EditingElementStyle>
                           <DataGridTextColumn.ElementStyle>
                              <Style TargetType="TextBlock">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_spacing"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                    <DataTrigger Binding="{Binding InputMode}" Value="direct"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{DynamicResource PlateLayerZsx}"
                                            Binding="{Binding ZsxMm, UpdateSourceTrigger=PropertyChanged, StringFormat=G4}"
                                            Width="70"/>

                        <DataGridTextColumn Header="{DynamicResource PlateLayerDiamY}"
                                            Binding="{Binding DiameterYMm, UpdateSourceTrigger=PropertyChanged, StringFormat=G4}"
                                            Width="70">
                           <DataGridTextColumn.EditingElementStyle>
                              <Style TargetType="TextBox">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="direct"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.EditingElementStyle>
                           <DataGridTextColumn.ElementStyle>
                              <Style TargetType="TextBlock">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="direct"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{DynamicResource PlateLayerSpacingY}"
                                            Binding="{Binding SpacingYMm, UpdateSourceTrigger=PropertyChanged, StringFormat=G4}"
                                            Width="75">
                           <DataGridTextColumn.EditingElementStyle>
                              <Style TargetType="TextBox">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_count"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                    <DataTrigger Binding="{Binding InputMode}" Value="direct"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.EditingElementStyle>
                           <DataGridTextColumn.ElementStyle>
                              <Style TargetType="TextBlock">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_count"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                    <DataTrigger Binding="{Binding InputMode}" Value="direct"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{DynamicResource PlateLayerCountY}"
                                            Binding="{Binding CountPerMeterY, UpdateSourceTrigger=PropertyChanged, StringFormat=G4}"
                                            Width="85">
                           <DataGridTextColumn.EditingElementStyle>
                              <Style TargetType="TextBox">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_spacing"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                    <DataTrigger Binding="{Binding InputMode}" Value="direct"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.EditingElementStyle>
                           <DataGridTextColumn.ElementStyle>
                              <Style TargetType="TextBlock">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_spacing"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                    <DataTrigger Binding="{Binding InputMode}" Value="direct"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{DynamicResource PlateLayerZsy}"
                                            Binding="{Binding ZsyMm, UpdateSourceTrigger=PropertyChanged, StringFormat=G4}"
                                            Width="70"/>

                        <DataGridTextColumn Header="{DynamicResource PlateLayerAsx}"
                                            Binding="{Binding AsxCm2, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                            Width="80">
                           <DataGridTextColumn.EditingElementStyle>
                              <Style TargetType="TextBox">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_spacing"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_count"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.EditingElementStyle>
                           <DataGridTextColumn.ElementStyle>
                              <Style TargetType="TextBlock">
                                 <Setter Property="HorizontalAlignment" Value="Right"/>
                                 <Setter Property="VerticalAlignment" Value="Center"/>
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_spacing"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_count"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{DynamicResource PlateLayerAsy}"
                                            Binding="{Binding AsyCm2, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                            Width="80">
                           <DataGridTextColumn.EditingElementStyle>
                              <Style TargetType="TextBox">
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_spacing"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_count"><Setter Property="IsReadOnly" Value="True"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.EditingElementStyle>
                           <DataGridTextColumn.ElementStyle>
                              <Style TargetType="TextBlock">
                                 <Setter Property="HorizontalAlignment" Value="Right"/>
                                 <Setter Property="VerticalAlignment" Value="Center"/>
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_spacing"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                    <DataTrigger Binding="{Binding InputMode}" Value="diameter_count"><Setter Property="Foreground" Value="Gray"/></DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                     </DataGrid.Columns>
                  </DataGrid>

                  <!-- Кнопки управления слоями -->
                  <StackPanel Orientation="Horizontal" Margin="4,0,4,4">
                     <Button Style="{StaticResource IconButton25}"
                             Command="{Binding AddRebarLayerCommand}"
                             ToolTip="{DynamicResource AddRebarLayer}" Margin="0,0,4,0">
                        <Path Width="14" Height="14" Stretch="Uniform"
                              Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                              Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"/>
                     </Button>
                     <Button Style="{StaticResource IconButton25}"
                             Command="{Binding DeleteRebarLayerCommand}"
                             ToolTip="{DynamicResource DeleteRebarLayer}">
                        <Path Width="14" Height="14" Stretch="Uniform"
                              Fill="#CC3333"
                              Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"/>
                     </Button>
                  </StackPanel>
               </StackPanel>
            </GroupBox>

         </StackPanel>
      </ScrollViewer>

      <!-- Кнопки внизу -->
      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,4">
         <Button Content="{DynamicResource Delete}"
                 Command="{Binding DeleteCommand}"
                 Foreground="#CC3333" Padding="16,4"/>
      </StackPanel>

   </Grid>
</UserControl>
