<Window x:Class="OpenCS.Views.FemMemberRotationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FemMemberRotationTitle}"
        Width="300" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <StackPanel Margin="12">
        <TextBlock Text="{DynamicResource FemMemberRotationDeg}"/>
        <TextBox x:Name="angleBox" Margin="0,2,0,6"/>
        <TextBlock Text="{DynamicResource FemMemberRotationConventionHint}"
                   Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <Button Content="{DynamicResource FemMemberRotationApply}" Click="Apply_Click"/>
    </StackPanel>
</Window>
