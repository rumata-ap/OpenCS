<UserControl x:Class="OpenCS.Views.TorsionResultView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="12">
        <StackPanel Orientation="Vertical">
            <TextBlock FontSize="16" FontWeight="Bold"
                       Text="{DynamicResource TorsionTitle}" Margin="0,0,0,8"/>
            <TextBlock Margin="0,0,0,4">
                <Run Text="{DynamicResource TorsionMethod}"/>
                <Run Text=": "/>
                <Run Text="{Binding MethodText, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock Foreground="{Binding StatusBrush, Mode=OneWay}" FontWeight="Bold"
                       Text="{Binding StatusText, Mode=OneWay}" Margin="0,0,0,12"/>
            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Margin="0,2">
                        <Run Text="{DynamicResource TorsionIt}"/>
                        <Run Text=" (мм⁴): "/>
                        <Run Text="{Binding ItText, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2">
                        <Run Text="{DynamicResource TorsionShearCenter}"/>
                        <Run Text=": "/>
                        <Run Text="{Binding ShearCenterText, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2">
                        <Run Text="{DynamicResource TorsionTauMax}"/>
                        <Run Text=": "/>
                        <Run Text="{Binding TauMaxText, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2">
                        <Run Text="{DynamicResource TorsionElements}"/>
                        <Run Text=": "/>
                        <Run Text="{Binding ElementsText, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2">
                        <Run Text="{DynamicResource TorsionElementSize}"/>
                        <Run Text=": "/>
                        <Run Text="{Binding ElementSizeText, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" Foreground="DarkOrange"
                               Visibility="{Binding IsSingular, Converter={StaticResource BoolToVisibility}}">
                        <Run Text="{DynamicResource TorsionSingular}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
