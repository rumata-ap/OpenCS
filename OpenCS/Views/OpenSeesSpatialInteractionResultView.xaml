<UserControl x:Class="OpenCS.Views.OpenSeesSpatialInteractionResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:OpenCS.Views">
   <TabControl>
      <TabItem Header="{DynamicResource OpenSeesSpatialTabPolar}">
         <Grid Margin="8">
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="*"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
               <TextBlock Text="{DynamicResource OpenSeesSpatialSelectedN}" VerticalAlignment="Center" Margin="0,0,6,0"/>
               <ComboBox ItemsSource="{Binding AvailableAxialForces}" SelectedItem="{Binding SelectedAxialForce}"
                         Width="110" Margin="0,0,14,0"/>
               <TextBlock Text="{DynamicResource OpenSeesSpatialSelectedAngle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
               <ComboBox ItemsSource="{Binding AvailableAngles}" SelectedItem="{Binding SelectedAngle}"
                         Width="90"/>
            </StackPanel>

            <Border Grid.Row="1" BorderThickness="1"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
               <h:PlotCanvas x:Name="PolarPlot"/>
            </Border>

            <Grid Grid.Row="2" Margin="0,6,0,6">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="160"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="160"/>
                  <ColumnDefinition Width="*"/>
               </Grid.ColumnDefinitions>
               <TextBlock Grid.Column="0" Text="{DynamicResource OpenSeesSpatialSelectedMx}"/>
               <TextBlock Grid.Column="1" Text="{Binding SelectedPoint.MomentMxNm, StringFormat={}{0:G6}}"/>
               <TextBlock Grid.Column="2" Text="{DynamicResource OpenSeesSpatialSelectedMy}"/>
               <TextBlock Grid.Column="3" Text="{Binding SelectedPoint.MomentMyNm, StringFormat={}{0:G6}}"/>
            </Grid>

            <DataGrid Grid.Row="3" ItemsSource="{Binding PointRows}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False" Margin="0">
               <DataGrid.Columns>
                  <DataGridTextColumn Header="{DynamicResource OpenSeesSpatialAngleColumn}" Binding="{Binding AngleDegrees}"/>
                  <DataGridTextColumn Header="{DynamicResource OpenSeesSpatialMxColumn}" Binding="{Binding MomentMxKnM}"/>
                  <DataGridTextColumn Header="{DynamicResource OpenSeesSpatialMyColumn}" Binding="{Binding MomentMyKnM}"/>
                  <DataGridTextColumn Header="{DynamicResource OpenSeesSpatialKxColumn}" Binding="{Binding CurvatureMx}"/>
                  <DataGridTextColumn Header="{DynamicResource OpenSeesSpatialKyColumn}" Binding="{Binding CurvatureMy}"/>
                  <DataGridTextColumn Header="{DynamicResource OpenSeesSpatialStatusColumn}" Binding="{Binding StatusText}"/>
                  <DataGridTextColumn Header="{DynamicResource OpenSeesSpatialArtifactColumn}" Binding="{Binding ArtifactDirectory}"/>
               </DataGrid.Columns>
            </DataGrid>
         </Grid>
      </TabItem>

      <TabItem Header="{DynamicResource OpenSeesSpatialTabHistory}">
         <Grid Margin="8">
            <Grid.RowDefinitions>
               <RowDefinition Height="*"/>
               <RowDefinition Height="220"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" BorderThickness="1"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
               <h:PlotCanvas x:Name="HistoryPlot"/>
            </Border>
            <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedPoint.HistoryRows}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False" Margin="0,6,0,0">
               <DataGrid.Columns>
                  <DataGridTextColumn Header="{DynamicResource OpenSeesSpatialStepColumn}" Binding="{Binding Step}"/>
                  <DataGridTextColumn Header="{DynamicResource OpenSeesSpatialMxColumn}" Binding="{Binding MomentMxNm}"/>
                  <DataGridTextColumn Header="{DynamicResource OpenSeesSpatialMyColumn}" Binding="{Binding MomentMyNm}"/>
                  <DataGridTextColumn Header="{DynamicResource OpenSeesSpatialKxColumn}" Binding="{Binding CurvatureMx}"/>
                  <DataGridTextColumn Header="{DynamicResource OpenSeesSpatialKyColumn}" Binding="{Binding CurvatureMy}"/>
                  <DataGridCheckBoxColumn Header="{DynamicResource OpenSeesSpatialConvergedColumn}" Binding="{Binding Converged}"/>
               </DataGrid.Columns>
            </DataGrid>
         </Grid>
      </TabItem>

      <TabItem Header="{DynamicResource OpenSeesSpatialTabDiagnostics}">
         <ScrollViewer Padding="12" VerticalScrollBarVisibility="Auto">
            <StackPanel>
               <TextBlock Text="{DynamicResource OpenSeesSpatialStatusLabel}" FontWeight="SemiBold"/>
               <TextBlock Text="{Binding StatusText}" Margin="0,0,0,8"/>
               <TextBlock Text="{Binding ErrorText}" Foreground="DarkRed" TextWrapping="Wrap"
                          Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,8"/>
               <TextBlock Text="{DynamicResource OpenSeesSpatialDiagnosticsLabel}" FontWeight="SemiBold"/>
               <ItemsControl ItemsSource="{Binding Diagnostics}" Margin="0,4,0,8"/>
               <TextBlock Text="{DynamicResource OpenSeesSpatialArtifactLabel}" FontWeight="SemiBold"/>
               <TextBlock Text="{Binding SelectedPoint.ArtifactDirectory}" TextWrapping="Wrap"/>
            </StackPanel>
         </ScrollViewer>
      </TabItem>
   </TabControl>
</UserControl>
