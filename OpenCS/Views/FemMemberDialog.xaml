<Window x:Class="OpenCS.Views.FemMemberDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FemMemberDlgTitle}"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
   <Grid Margin="12">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="8"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="130"/>
         <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Tag}"
                 VerticalAlignment="Center" Margin="0,0,8,8"/>
      <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TagBox"
                 Text="{Binding MemberTag, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,8"/>

      <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource FemMemberType}"
                 VerticalAlignment="Center" Margin="0,0,8,8"/>
      <ComboBox  Grid.Row="1" Grid.Column="1"
                 IsEditable="True"
                 ItemsSource="{Binding MemberTypes}"
                 Text="{Binding MemberType, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,8"/>

      <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource FemMemberDlgRange}"
                 VerticalAlignment="Center" Margin="0,0,8,8"/>
      <TextBox   Grid.Row="2" Grid.Column="1"
                 Height="80"
                 VerticalContentAlignment="Top"
                 TextWrapping="Wrap"
                 AcceptsReturn="False"
                 VerticalScrollBarVisibility="Auto"
                 Text="{Binding Range, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="{DynamicResource LiraElemRangeDlgHint}"
                 FontFamily="Consolas"
                 Margin="0,0,0,8"/>

      <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                  Orientation="Horizontal" HorizontalAlignment="Right">
         <Button Content="{DynamicResource OK}" IsDefault="True"
                 Click="Ok_Click" Padding="20,4" Margin="0,0,8,0"/>
         <Button Content="{DynamicResource Cancel}" IsCancel="True" Padding="16,4"/>
      </StackPanel>
   </Grid>
</Window>
