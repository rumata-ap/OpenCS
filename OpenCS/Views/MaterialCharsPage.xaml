<UserControl x:Class="OpenCS.Views.MaterialCharsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OpenCS.ViewModels"
             xmlns:ut="clr-namespace:OpenCS.Utilites"
             xmlns:core="clr-namespace:CScore;assembly=CScore"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="500"
             Background="White">

   <UserControl.Resources>
      <ut:MPaConvert x:Key="mpa" />
      <ut:GPaConvert x:Key="gpa" />
      <ut:MPaConvertInv x:Key="mpa_" />
      <ut:ConvertInv x:Key="inv" />
   </UserControl.Resources>

   <Grid Margin="10">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="#FF2813EB" CornerRadius="4" Padding="8" Margin="0,0,0,10">
         <StackPanel>
            <TextBlock Text="{Binding Header, FallbackValue='Материал: B25 | Тип расчёта: C'}"
                       Foreground="White" FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding MaterialTag, FallbackValue='B25'}"
                       Visibility="Collapsed"/>
         </StackPanel>
      </Border>

      <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="0,0,0,1" Margin="0,0,0,5">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
             <Button Content="Построить диаграмму"
                     Click="BuildDiagram_Click"
                     Margin="0,0,5,0" Height="28"
                     Cursor="Hand"
                     Background="Transparent"
                     BorderBrush="#FF2813EB"
                     Foreground="#FF2813EB">
                <Button.Style>
                   <Style TargetType="Button">
                      <Setter Property="Template">
                         <Setter.Value>
                            <ControlTemplate TargetType="Button">
                               <Border Background="{TemplateBinding Background}"
                                       BorderBrush="{TemplateBinding BorderBrush}"
                                       BorderThickness="1" CornerRadius="3"
                                       Padding="8,3">
                                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                               </Border>
                            </ControlTemplate>
                         </Setter.Value>
                      </Setter>
                   </Style>
                </Button.Style>
             </Button>
             <Button Content="Редактировать материал" 
                     Click="EditParentMaterial_Click"
                     Margin="0,0,5,0" Height="28"
                     Cursor="Hand"
                     Background="Transparent"
                     BorderBrush="#FF2813EB"
                     Foreground="#FF2813EB">
                <Button.Style>
                   <Style TargetType="Button">
                      <Setter Property="Template">
                         <Setter.Value>
                            <ControlTemplate TargetType="Button">
                               <Border Background="{TemplateBinding Background}"
                                       BorderBrush="{TemplateBinding BorderBrush}"
                                       BorderThickness="1" CornerRadius="3"
                                       Padding="8,3">
                                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                               </Border>
                            </ControlTemplate>
                         </Setter.Value>
                      </Setter>
                   </Style>
                </Button.Style>
             </Button>
          </StackPanel>
      </Border>

      <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
         <Grid ShowGridLines="True" Margin="0,5,0,5">
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="2*"/>
               <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Обозначение" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="0" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Tag}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Класс" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="1" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Class}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Прочность при сжатии Rc, МПа" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="2" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Fc, Converter={StaticResource mpa_}, StringFormat={}{0:F2}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="3" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Прочность при растяжении Rt, МПа" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="3" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Ft, Converter={StaticResource mpa}, StringFormat={}{0:F2}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="4" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Предел текучести Ry, МПа" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="4" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Ry, Converter={StaticResource mpa}, StringFormat={}{0:F2}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="5" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Предел прочности Ru, МПа" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="5" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Ru, Converter={StaticResource mpa}, StringFormat={}{0:F2}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="6" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Начальный модуль упругости, ГПа" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="6" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding E, Converter={StaticResource gpa}, StringFormat={}{0:F2}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="7" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Деформация при достижении Rc (eps_c0)" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="7" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Ec0, Converter={StaticResource inv}, StringFormat={}{0:F5}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="8" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Деформация при достижении 0.6*Rc (eps_c1)" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="8" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Ec1, Converter={StaticResource inv}, StringFormat={}{0:F5}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="9" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Предельная деформация сжатия (eps_c2)" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="9" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Ec2, Converter={StaticResource inv}, StringFormat={}{0:F6}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="10" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Приведенная по Rc деформация (eps_c1_red)" Foreground="#FF2813EB" TextWrapping="Wrap"/>
            <DockPanel Grid.Row="10" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Ec1Red, Converter={StaticResource inv}, StringFormat={}{0:F6}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="11" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Приведенная по Rt деформация (eps_t1_red)" Foreground="#FF2813EB" TextWrapping="Wrap"/>
            <DockPanel Grid.Row="11" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Et1Red, StringFormat={}{0:F6}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="12" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Деформация при достижении Rt (eps_t0)" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="12" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Et0, StringFormat={}{0:F6}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="13" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Деформация при достижении 0.6*Rt (eps_t1)" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="13" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Et1, StringFormat={}{0:F6}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="14" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Предельная деформация по Rt (eps_t2)" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="14" Grid.Column="1">
               <TextBox Margin="2" Text="{Binding Et2, StringFormat={}{0:F6}}" TextAlignment="Center"/>
            </DockPanel>

            <TextBlock Grid.Row="15" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Тип материала" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="15" Grid.Column="1">
               <ComboBox Margin="2" HorizontalContentAlignment="Center"
                         SelectedItem="{Binding Type}" SelectedIndex="0">
                  <core:MatType>0</core:MatType>
                  <core:MatType>1</core:MatType>
                  <core:MatType>2</core:MatType>
                  <core:MatType>3</core:MatType>
                  <core:MatType>4</core:MatType>
               </ComboBox>
            </DockPanel>

            <TextBlock Grid.Row="16" Grid.Column="0" Margin="2" TextAlignment="Center"
                       Text="Влажность среды" Foreground="#FF2813EB"/>
            <DockPanel Grid.Row="16" Grid.Column="1">
               <ComboBox Margin="2" HorizontalContentAlignment="Center"
                         SelectedItem="{Binding Dampness}" SelectedIndex="1">
                  <core:Dampness>1</core:Dampness>
                  <core:Dampness>2</core:Dampness>
                  <core:Dampness>3</core:Dampness>
               </ComboBox>
            </DockPanel>
         </Grid>
      </ScrollViewer>

      <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
         <Button Content="Сохранить" Click="Save_Click" Height="32" Width="120"
                 FontWeight="SemiBold"
                 Background="#FF2813EB" Foreground="White"
                 BorderThickness="0"/>
      </StackPanel>
   </Grid>
</UserControl>
