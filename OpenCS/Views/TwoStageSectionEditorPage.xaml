<UserControl x:Class="OpenCS.Views.TwoStageSectionEditorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenCS.ViewModels"
             xmlns:core="clr-namespace:CScore;assembly=CScore"
             xmlns:conv="clr-namespace:OpenCS.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:OpenCS.Views">
   <UserControl.Resources>
      <conv:MatTypeToBrushConverter x:Key="MatTypeToBrush"/>
      <conv:MatTypeToGeometryConverter x:Key="MatTypeToGeom"/>
      <ObjectDataProvider x:Key="DiagramTypes" MethodName="GetValues"
                          ObjectType="{x:Type sys:Enum}">
         <ObjectDataProvider.MethodParameters>
            <x:Type TypeName="core:DiagrammType"/>
         </ObjectDataProvider.MethodParameters>
      </ObjectDataProvider>
      <DataTemplate x:Key="AreaListItemTemplate" DataType="{x:Type vm:MaterialAreaVM}">
         <Grid Margin="2,1">
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="16"/>
               <ColumnDefinition Width="*"/>
               <ColumnDefinition Width="22"/>
            </Grid.ColumnDefinitions>
            <Path Grid.Column="0" Width="12" Height="12" Stretch="Uniform"
                  Fill="{Binding MaterialType, Converter={StaticResource MatTypeToBrush}}"
                  Data="{Binding MaterialType, Converter={StaticResource MatTypeToGeom}}"/>
            <TextBlock Grid.Column="1" Text="{Binding Tag}"
                       VerticalAlignment="Center" Margin="4,0"/>
            <Button Grid.Column="2" Style="{StaticResource IconButton25}"
                    ToolTip="{DynamicResource DeleteArea}"
                    Command="{Binding DataContext.RemoveAreaFromSectionCommand,
                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}">
               <Path Data="M4,4 L12,12 M12,4 L4,12" Stroke="Gray"
                     StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            </Button>
         </Grid>
      </DataTemplate>
   </UserControl.Resources>

   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Верхняя панель -->
      <Border Grid.Row="0" BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
              Padding="8,6">
         <StackPanel Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Tag}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding Tag, UpdateSourceTrigger=PropertyChanged}"
                     Width="220" Margin="0,0,12,0"/>
            <Button Content="{DynamicResource Save}"
                    Command="{Binding SaveCommand}"
                    Padding="16,3"/>
         </StackPanel>
      </Border>

      <!-- Основная область -->
      <Grid Grid.Row="1">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="140"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="220" MinWidth="140"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*" MinWidth="100"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="280" MinWidth="200"/>
         </Grid.ColumnDefinitions>

         <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" ShowsPreview="True"/>
         <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" ShowsPreview="True"/>
         <GridSplitter Grid.Column="5" HorizontalAlignment="Stretch" ShowsPreview="True"/>

         <!-- Этап 1 -->
         <DockPanel Grid.Column="0" Margin="4">
            <TextBlock DockPanel.Dock="Top" Text="{DynamicResource CrossSectionStage1}"
                       FontWeight="SemiBold" Margin="0,0,0,4"/>
            <StackPanel DockPanel.Dock="Bottom">
               <!-- Кривизна 1-го этапа -->
               <GroupBox Header="{DynamicResource Stage1Kurvature}" Margin="0,4,0,4">
                  <Grid Margin="4">
                     <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                     </Grid.ColumnDefinitions>
                     <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                     </Grid.RowDefinitions>
                     <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource KurvatureE0}"
                                VerticalAlignment="Center" Margin="0,0,4,4"/>
                     <TextBox  Grid.Row="0" Grid.Column="1"
                               Text="{Binding E0, UpdateSourceTrigger=PropertyChanged, StringFormat=G6}"
                               Margin="0,0,0,4"/>
                     <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource KurvatureKy}"
                                VerticalAlignment="Center" Margin="0,0,4,4"/>
                     <TextBox  Grid.Row="1" Grid.Column="1"
                               Text="{Binding Ky, UpdateSourceTrigger=PropertyChanged, StringFormat=G6}"
                               Margin="0,0,0,4"/>
                     <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource KurvatureKz}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                     <TextBox  Grid.Row="2" Grid.Column="1"
                               Text="{Binding Kz, UpdateSourceTrigger=PropertyChanged, StringFormat=G6}"/>
                  </Grid>
               </GroupBox>
               <!-- Кнопки добавления Этап 1 -->
               <StackPanel Orientation="Horizontal">
                  <Button Content="{DynamicResource AddConcreteAreaShort}"
                          Command="{Binding AddS1ConcreteCommand}"
                          Padding="5,3" Margin="0,0,3,0" FontSize="11"/>
                  <Button Content="{DynamicResource AddRebarAreaShort}"
                          Command="{Binding AddS1RebarCommand}"
                          Padding="5,3" Margin="0,0,3,0" FontSize="11"/>
                  <Button Content="{DynamicResource AddSteelAreaShort}"
                          Command="{Binding AddS1SteelCommand}"
                          Padding="5,3" FontSize="11"/>
               </StackPanel>
            </StackPanel>
            <ListBox ItemsSource="{Binding Stage1Areas}"
                     SelectedItem="{Binding SelectedArea, Mode=TwoWay}"
                     BorderThickness="1" Padding="2"
                     ItemTemplate="{StaticResource AreaListItemTemplate}"/>
         </DockPanel>

         <!-- Этап 2 -->
         <DockPanel Grid.Column="2" Margin="4">
            <TextBlock DockPanel.Dock="Top" Text="{DynamicResource CrossSectionStage2}"
                       FontWeight="SemiBold" Margin="0,0,0,4"/>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
               <Button Content="{DynamicResource AddConcreteAreaShort}"
                       Command="{Binding AddS2ConcreteCommand}"
                       Padding="5,3" Margin="0,0,3,0" FontSize="11"/>
               <Button Content="{DynamicResource AddRebarAreaShort}"
                       Command="{Binding AddS2RebarCommand}"
                       Padding="5,3" Margin="0,0,3,0" FontSize="11"/>
               <Button Content="{DynamicResource AddSteelAreaShort}"
                       Command="{Binding AddS2SteelCommand}"
                       Padding="5,3" FontSize="11"/>
            </StackPanel>
            <ListBox ItemsSource="{Binding Stage2Areas}"
                     SelectedItem="{Binding SelectedArea, Mode=TwoWay}"
                     BorderThickness="1" Padding="2"
                     ItemTemplate="{StaticResource AreaListItemTemplate}"/>
         </DockPanel>

         <!-- Превью сечения -->
         <Border Grid.Column="4" BorderThickness="1,0,1,0"
                 BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}">
            <local:PlotCanvas x:Name="preview"/>
         </Border>

         <!-- Редактор выбранной области -->
         <ContentControl Grid.Column="6" Content="{Binding SelectedArea}">
            <ContentControl.Style>
               <Style TargetType="ContentControl">
                  <Style.Triggers>
                     <DataTrigger Binding="{Binding SelectedArea}" Value="{x:Null}">
                        <Setter Property="Template">
                           <Setter.Value>
                              <ControlTemplate>
                                 <TextBlock Text="{DynamicResource CrossSectionSelectArea}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Foreground="LightGray" FontSize="13" TextWrapping="Wrap"
                                            Margin="16"/>
                              </ControlTemplate>
                           </Setter.Value>
                        </Setter>
                     </DataTrigger>
                  </Style.Triggers>
               </Style>
            </ContentControl.Style>
            <ContentControl.ContentTemplate>
               <DataTemplate DataType="{x:Type vm:MaterialAreaVM}">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                     <StackPanel Margin="8">
                        <TextBlock Text="{DynamicResource Tag}" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding Tag, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource Material}" Margin="0,0,0,2"/>
                        <ComboBox ItemsSource="{Binding App.Materials}"
                                  SelectedItem="{Binding Material}"
                                  DisplayMemberPath="Tag"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource DiagramType}" Margin="0,0,0,2"/>
                        <ComboBox ItemsSource="{StaticResource DiagramTypes}"
                                  SelectedItem="{Binding DiagrammType}"
                                  Margin="0,0,0,8"/>
                        <GroupBox Header="{DynamicResource Hull}" Margin="0,0,0,8">
                           <StackPanel Margin="4">
                              <ComboBox x:Name="hullComboTS"
                                        ItemsSource="{Binding ProjectContours}"
                                        SelectedItem="{Binding PoolContour, Mode=TwoWay}"
                                        DisplayMemberPath="Tag"
                                        Margin="0,0,0,4"/>
                              <StackPanel Orientation="Horizontal">
                                 <Button Content="{DynamicResource SelectFromPool}"
                                         Command="{Binding SetHullFromPoolCommand}"
                                         CommandParameter="{Binding SelectedItem, ElementName=hullComboTS}"
                                         Padding="6,3" Margin="0,0,4,0"/>
                                 <Button Content="{DynamicResource ClearHull}"
                                         Command="{Binding ClearHullCommand}"
                                         Padding="6,3"/>
                              </StackPanel>
                              <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="Gray">
                                 <Run Text="{DynamicResource CurrentHull}"/>
                                 <Run Text="{Binding Hull.Tag, FallbackValue='-'}"/>
                              </TextBlock>
                           </StackPanel>
                        </GroupBox>
                        <GroupBox Header="{DynamicResource MeshGrid}" Margin="0,0,0,8">
                           <StackPanel Margin="4">
                              <TextBlock Margin="0,0,0,4">
                                 <Run Text="{DynamicResource MeshFibersCount}"/>
                                 <Run Text="{Binding FibersCount, Mode=OneWay}"/>
                              </TextBlock>
                              <StackPanel Orientation="Horizontal">
                                 <Button Content="{DynamicResource MeshConfigure}"
                                         Command="{Binding DataContext.OpenMeshForAreaCommand,
                                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                                         CommandParameter="{Binding}"
                                         Padding="8,3" Margin="0,0,4,0"/>
                                 <Button Content="{DynamicResource MeshClear}"
                                         Command="{Binding ClearMeshCommand}"
                                         Padding="8,3"/>
                              </StackPanel>
                           </StackPanel>
                        </GroupBox>
                     </StackPanel>
                  </ScrollViewer>
               </DataTemplate>
            </ContentControl.ContentTemplate>
         </ContentControl>

      </Grid>
   </Grid>
</UserControl>
