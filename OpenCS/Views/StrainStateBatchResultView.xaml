<UserControl x:Class="OpenCS.Views.StrainStateBatchResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

   <Grid Margin="12">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Шапка: вердикт -->
      <Border Grid.Row="0" Padding="8,6" Margin="0,0,0,8" CornerRadius="4"
              Background="{Binding StatusBrush}">
         <TextBlock Text="{Binding SummaryText}" FontWeight="Bold"
                    HorizontalAlignment="Center"/>
      </Border>

      <!-- Таблица строк -->
      <DataGrid Grid.Row="1" x:Name="RowsGrid" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                CanUserSortColumns="True" SelectionMode="Single" SelectionUnit="FullRow"
                MouseDoubleClick="RowsGrid_MouseDoubleClick">
         <DataGrid.RowStyle>
            <Style TargetType="DataGridRow">
               <Style.Triggers>
                  <DataTrigger Binding="{Binding IsConverged}" Value="True">
                     <Setter Property="Background" Value="#1A2D7A3E"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsConverged}" Value="False">
                     <Setter Property="Background" Value="#1AC0392B"/>
                  </DataTrigger>
               </Style.Triggers>
            </Style>
         </DataGrid.RowStyle>
         <DataGrid.ContextMenu>
            <ContextMenu>
               <MenuItem Header="{DynamicResource CalcTaskNew}"
                         Click="CreateTask_Click"/>
               <Separator/>
               <MenuItem Header="{DynamicResource ExportCsvBtn}"
                         Click="ExportCsv_Click"/>
            </ContextMenu>
         </DataGrid.ContextMenu>
         <DataGrid.Columns>
            <DataGridTextColumn Header="{DynamicResource StrainStateBatch_ColNum}"
                                Binding="{Binding Num}" Width="40"/>
            <DataGridTextColumn Header="{DynamicResource StrainStateBatch_ColLabel}"
                                Binding="{Binding Label}"     Width="*"/>
            <DataGridTextColumn Header="N, кН"
                                Binding="{Binding NText}"     Width="75"/>
            <DataGridTextColumn Header="Mx, кН·м"
                                Binding="{Binding MxText}"    Width="82"/>
            <DataGridTextColumn Header="My, кН·м"
                                Binding="{Binding MyText}"    Width="82"/>
            <DataGridTextColumn Header="e₀"
                                Binding="{Binding E0Text}"    Width="88"/>
            <DataGridTextColumn Header="ky"
                                Binding="{Binding KyText}"    Width="88"/>
            <DataGridTextColumn Header="kz"
                                Binding="{Binding KzText}"    Width="88"/>
            <DataGridTextColumn Header="{DynamicResource StrainStateBatch_ColIter}"
                                Binding="{Binding IterText}"  Width="52"/>
            <DataGridTextColumn Header="{DynamicResource StrainStateBatch_ColResidual}"
                                Binding="{Binding ResText}"   Width="72"/>
            <DataGridTextColumn Header="{DynamicResource StrainStateBatch_ColStatus}"
                                Binding="{Binding StatusText}" Width="65"/>
         </DataGrid.Columns>
      </DataGrid>

      <!-- Кнопки внизу -->
      <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
         <Button Content="{DynamicResource CalcTaskNew}"
                 Click="CreateTask_Click"
                 Padding="12,4" Margin="0,0,8,0"
                 x:Name="CreateTaskBtn" IsEnabled="False"/>
         <Button Content="{DynamicResource ExportCsvBtn}"
                 Click="ExportCsv_Click"
                 Padding="12,4"/>
      </StackPanel>
   </Grid>
</UserControl>
