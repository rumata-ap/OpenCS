<Window x:Class="OpenCS.Views.ForceSetPropsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ForceSetPropsTitle}"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

   <Grid Margin="12">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="150"/>
         <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Набор (текущее имя) -->
      <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource ForceLoadCurrentName}"
                 VerticalAlignment="Center" Margin="0,0,8,6"/>
      <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentName}"
                 Foreground="Gray" VerticalAlignment="Center" Margin="0,0,0,6"
                 TextTrimming="CharacterEllipsis"/>

      <!-- Название -->
      <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource ForceLoadTitleLabel}"
                 VerticalAlignment="Center" Margin="0,0,8,6"/>
      <TextBox x:Name="TitleBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,6"
               Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>

      <!-- Вид загружения -->
      <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource ForceLoadKindLabel}"
                 VerticalAlignment="Center" Margin="0,0,8,6"/>
      <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6"
                ItemsSource="{Binding KindOptions}"
                SelectedIndex="{Binding KindIndex, Mode=TwoWay}"/>

      <!-- γf -->
      <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource ForceLoadGammaLabel}"
                 VerticalAlignment="Center" Margin="0,0,8,6"/>
      <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
         <TextBox Text="{Binding GammaFText, UpdateSourceTrigger=PropertyChanged}"
                  Width="80"/>
         <TextBlock Text="{DynamicResource ForceLoadGammaHint}" Foreground="Gray"
                    FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
      </StackPanel>

      <!-- Группа -->
      <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource ForceLoadGroupLabel}"
                 VerticalAlignment="Top" Margin="0,2,8,6"/>
      <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,8">
         <TextBox Text="{Binding Group, UpdateSourceTrigger=PropertyChanged}"/>
         <TextBlock Text="{DynamicResource ForceLoadGroupHint}" Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
      </StackPanel>

      <!-- Превью -->
      <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource ForceLoadPreviewLabel}"
                 VerticalAlignment="Center" Margin="0,0,8,8"/>
      <Border Grid.Row="5" Grid.Column="1" BorderThickness="1"
              BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
              Padding="4,3" Margin="0,0,0,8">
         <TextBlock Text="{Binding Preview}" FontFamily="Courier New" FontSize="11"
                    TextWrapping="Wrap"/>
      </Border>

      <!-- Кнопки -->
      <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                  Orientation="Horizontal" HorizontalAlignment="Right">
         <Button Content="{DynamicResource OK}" IsDefault="True"
                 Click="Ok_Click" Padding="20,4" Margin="0,0,8,0"/>
         <Button Content="{DynamicResource Cancel}" IsCancel="True" Padding="16,4"/>
      </StackPanel>
   </Grid>
</Window>
