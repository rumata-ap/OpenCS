<UserControl x:Class="OpenCS.Views.ShellLiraSignDiagram"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ClipToBounds="False">

   <UserControl.Resources>
      <SolidColorBrush x:Key="ForceAxisXBrush" Color="ForestGreen"/>
      <SolidColorBrush x:Key="ForceAxisYBrush" Color="RoyalBlue"/>
      <SolidColorBrush x:Key="ForceAxisTauBrush" Color="#CC2222"/>
      <SolidColorBrush x:Key="ForceAxisTwistBrush" Color="#CC9900"/>
      <SolidColorBrush x:Key="LiraAxisBrush" Color="#444444"/>
   </UserControl.Resources>

   <Canvas Width="268" Height="212">
      <Canvas Canvas.Top="14">
         <!-- Подписи видов -->
         <TextBlock Canvas.Left="38" Canvas.Top="0" FontSize="9" Foreground="Gray"
                    Text="{DynamicResource ForceSignConventionShellViewPlan}">
            <TextBlock.RenderTransform>
               <TranslateTransform Y="-8"/>
            </TextBlock.RenderTransform>
         </TextBlock>
         <TextBlock Canvas.Left="200" Canvas.Top="0" FontSize="9" Foreground="Gray"
                    Text="{DynamicResource ForceSignConventionShellViewSide}">
            <TextBlock.RenderTransform>
               <TranslateTransform Y="-8"/>
            </TextBlock.RenderTransform>
         </TextBlock>
         <TextBlock Canvas.Left="4" Canvas.Top="92" FontSize="9" Foreground="Gray"
                    Text="{DynamicResource ForceSignConventionShellViewFront}"/>

         <!-- План XY -->
         <Rectangle Canvas.Left="26" Canvas.Top="24" Width="58" Height="58"
                    Fill="#EEEEEE" Stroke="#666666" StrokeThickness="1"/>

         <TextBlock Canvas.Left="18" Canvas.Top="78" Text="1" FontSize="9" Foreground="Gray"/>
         <TextBlock Canvas.Left="86" Canvas.Top="78" Text="2" FontSize="9" Foreground="Gray"/>
         <TextBlock Canvas.Left="18" Canvas.Top="16" Text="3" FontSize="9" Foreground="Gray"/>
         <TextBlock Canvas.Left="86" Canvas.Top="16" Text="4" FontSize="9" Foreground="Gray"/>

         <Line X1="26" Y1="82" X2="118" Y2="82" Stroke="{StaticResource LiraAxisBrush}" StrokeThickness="0.9"/>
         <Line X1="26" Y1="82" X2="26" Y2="8" Stroke="{StaticResource LiraAxisBrush}" StrokeThickness="0.9"/>
         <TextBlock Canvas.Left="118" Canvas.Top="74" Text="X" FontSize="9" Foreground="{StaticResource LiraAxisBrush}"/>
         <TextBlock Canvas.Left="10" Canvas.Top="4" Text="Y" FontSize="9" Foreground="{StaticResource LiraAxisBrush}"/>

         <!-- Nx -->
         <Line X1="26" Y1="52" X2="12" Y2="52" Stroke="{StaticResource ForceAxisXBrush}" StrokeThickness="1.3"/>
         <Polygon Points="12,52 18,49 18,55" Fill="{StaticResource ForceAxisXBrush}"/>
         <Line X1="84" Y1="52" X2="98" Y2="52" Stroke="{StaticResource ForceAxisXBrush}" StrokeThickness="1.3"/>
         <Polygon Points="98,52 92,49 92,55" Fill="{StaticResource ForceAxisXBrush}"/>

         <!-- Ny -->
         <Line X1="55" Y1="82" X2="55" Y2="96" Stroke="{StaticResource ForceAxisYBrush}" StrokeThickness="1.3"/>
         <Polygon Points="55,96 52,90 58,90" Fill="{StaticResource ForceAxisYBrush}"/>
         <Line X1="55" Y1="24" X2="55" Y2="10" Stroke="{StaticResource ForceAxisYBrush}" StrokeThickness="1.3"/>
         <Polygon Points="55,10 52,16 58,16" Fill="{StaticResource ForceAxisYBrush}"/>

         <!-- Nxy -->
         <Line X1="55" Y1="82" X2="38" Y2="82" Stroke="{StaticResource ForceAxisTauBrush}" StrokeThickness="1.3"/>
         <Polygon Points="38,82 44,79 44,85" Fill="{StaticResource ForceAxisTauBrush}"/>
         <Line X1="55" Y1="24" X2="72" Y2="24" Stroke="{StaticResource ForceAxisTauBrush}" StrokeThickness="1.3"/>
         <Polygon Points="72,24 66,21 66,27" Fill="{StaticResource ForceAxisTauBrush}"/>
         <Line X1="26" Y1="55" X2="26" Y2="68" Stroke="{StaticResource ForceAxisTauBrush}" StrokeThickness="1.3"/>
         <Polygon Points="26,68 23,62 29,62" Fill="{StaticResource ForceAxisTauBrush}"/>
         <Line X1="84" Y1="52" X2="84" Y2="38" Stroke="{StaticResource ForceAxisTauBrush}" StrokeThickness="1.3"/>
         <Polygon Points="84,38 81,44 87,44" Fill="{StaticResource ForceAxisTauBrush}"/>

         <!-- Mxy -->
         <Path Stroke="{StaticResource ForceAxisTwistBrush}" StrokeThickness="1.2" Fill="Transparent"
               Data="M 78,56 A 8,8 0 0 1 78,72"/>
         <Polygon Points="78,75 75,69 81,69" Fill="{StaticResource ForceAxisTwistBrush}"/>
         <Path Stroke="{StaticResource ForceAxisTwistBrush}" StrokeThickness="1.2" Fill="Transparent"
               Data="M 32,56 A 8,8 0 0 0 32,40"/>
         <Polygon Points="32,37 29,43 35,43" Fill="{StaticResource ForceAxisTwistBrush}"/>
         <Path Stroke="{StaticResource ForceAxisTwistBrush}" StrokeThickness="1.2" Fill="Transparent"
               Data="M 38,30 A 8,8 0 0 1 54,30"/>
         <Polygon Points="57,30 51,27 51,33" Fill="{StaticResource ForceAxisTwistBrush}"/>
         <Path Stroke="{StaticResource ForceAxisTwistBrush}" StrokeThickness="1.2" Fill="Transparent"
               Data="M 74,76 A 8,8 0 0 0 58,76"/>
         <Polygon Points="55,76 61,73 61,79" Fill="{StaticResource ForceAxisTwistBrush}"/>

         <!-- Разрез XZ -->
         <Rectangle Canvas.Left="18" Canvas.Top="128" Width="74" Height="8"
                    Fill="#DDDDDD" Stroke="#666666" StrokeThickness="1"/>
         <Line X1="18" Y1="144" X2="98" Y2="144" Stroke="{StaticResource LiraAxisBrush}" StrokeThickness="0.9"/>
         <Line X1="18" Y1="144" X2="18" Y2="108" Stroke="{StaticResource LiraAxisBrush}" StrokeThickness="0.9"/>
         <TextBlock Canvas.Left="98" Canvas.Top="136" Text="X" FontSize="9" Foreground="{StaticResource LiraAxisBrush}"/>
         <TextBlock Canvas.Left="6" Canvas.Top="104" Text="Z" FontSize="9" Foreground="{StaticResource LiraAxisBrush}"/>

         <!-- Qx -->
         <Line X1="55" Y1="132" X2="55" Y2="112" Stroke="{StaticResource ForceAxisXBrush}" StrokeThickness="1.4"/>
         <Polygon Points="55,112 51,120 59,120" Fill="{StaticResource ForceAxisXBrush}"/>

         <!-- Mx -->
         <Path Stroke="{StaticResource ForceAxisXBrush}" StrokeThickness="1.2" Fill="Transparent"
               Data="M 22,132 A 8,8 0 0 0 22,148"/>
         <Polygon Points="19,151 25,145 25,151" Fill="{StaticResource ForceAxisXBrush}"/>
         <Path Stroke="{StaticResource ForceAxisXBrush}" StrokeThickness="1.2" Fill="Transparent"
               Data="M 88,132 A 8,8 0 0 1 88,148"/>
         <Polygon Points="91,151 85,145 85,151" Fill="{StaticResource ForceAxisXBrush}"/>

         <!-- Разрез YZ -->
         <Rectangle Canvas.Left="188" Canvas.Top="24" Width="8" Height="58"
                    Fill="#DDDDDD" Stroke="#666666" StrokeThickness="1"/>
         <Line X1="188" Y1="82" X2="188" Y2="8" Stroke="{StaticResource LiraAxisBrush}" StrokeThickness="0.9"/>
         <Line X1="188" Y1="82" X2="162" Y2="82" Stroke="{StaticResource LiraAxisBrush}" StrokeThickness="0.9"/>
         <TextBlock Canvas.Left="180" Canvas.Top="4" Text="Y" FontSize="9" Foreground="{StaticResource LiraAxisBrush}"/>
         <TextBlock Canvas.Left="152" Canvas.Top="86" Text="Z" FontSize="9" Foreground="{StaticResource LiraAxisBrush}"/>

         <!-- Qy -->
         <Line X1="188" Y1="51" X2="168" Y2="51" Stroke="{StaticResource ForceAxisYBrush}" StrokeThickness="1.4"/>
         <Polygon Points="168,51 176,47 176,55" Fill="{StaticResource ForceAxisYBrush}"/>

         <!-- My -->
         <Path Stroke="{StaticResource ForceAxisYBrush}" StrokeThickness="1.2" Fill="Transparent"
               Data="M 192,28 A 8,8 0 0 1 208,28"/>
         <Polygon Points="211,28 204,25 204,31" Fill="{StaticResource ForceAxisYBrush}"/>
         <Path Stroke="{StaticResource ForceAxisYBrush}" StrokeThickness="1.2" Fill="Transparent"
               Data="M 192,74 A 8,8 0 0 0 208,74"/>
         <Polygon Points="211,74 204,71 204,77" Fill="{StaticResource ForceAxisYBrush}"/>
      </Canvas>
   </Canvas>
</UserControl>
