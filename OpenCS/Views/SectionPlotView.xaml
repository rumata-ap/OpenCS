<UserControl x:Class="OpenCS.Views.SectionPlotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:OpenCS.Views.Helpers">

   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>  <!-- тулбар -->
         <RowDefinition Height="*"/>     <!-- canvas + colorbars -->
      </Grid.RowDefinitions>

      <!-- Тулбар -->
      <Border Grid.Row="0" BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
              Padding="6,4">
         <StackPanel Orientation="Horizontal">
            <CheckBox Content="{DynamicResource PlotShowMainMat}"
                      IsChecked="{Binding ShowConcrete}" Margin="0,0,10,0"
                      VerticalAlignment="Center"/>
            <CheckBox Content="{DynamicResource PlotShowRebar}"
                      IsChecked="{Binding ShowRebar}"    Margin="0,0,10,0"
                      VerticalAlignment="Center"/>
            <CheckBox Content="{DynamicResource PlotShowValues}"
                      IsChecked="{Binding ShowValues}"   Margin="0,0,10,0"
                      VerticalAlignment="Center"/>
            <CheckBox Content="{DynamicResource PlotShowMaxCompr}"
                      IsChecked="{Binding ShowMaxCompr}" Margin="0,0,14,0"
                      VerticalAlignment="Center"/>
            <Button Content="{DynamicResource PlotFitAll}"
                    Command="{Binding FitAllCommand}"
                    Padding="8,2"/>
         </StackPanel>
      </Border>

      <!-- Основная область: colorbar Арматура | Canvas | colorbar Осн.материал -->
      <Grid Grid.Row="1">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>  <!-- colorbar Арматура (слева) -->
            <ColumnDefinition Width="*"/>     <!-- FiberCanvas -->
            <ColumnDefinition Width="Auto"/>  <!-- colorbar Осн.материал (справа) -->
         </Grid.ColumnDefinitions>

         <!-- Colorbar Арматура (слева, скрыт если нет арматуры) -->
         <Border Grid.Column="0" Width="64" Margin="4"
                 Visibility="{Binding HasRebar, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
               <TextBlock Text="{DynamicResource ColorbarRebar}"
                          FontSize="10" TextWrapping="Wrap" TextAlignment="Center"
                          Margin="0,0,0,2"/>
               <!-- Градиент с метками min/0/max поверх (overlay) -->
               <Grid MinHeight="120">
                  <Border Margin="18,0,4,0">
                     <Border.Background>
                        <!-- красный(top=max)→белый→синий(bottom=min) -->
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                           <GradientStop Color="#0000FF" Offset="0"/>
                           <GradientStop Color="#FFFFFF" Offset="0.5"/>
                           <GradientStop Color="#FF0000" Offset="1"/>
                        </LinearGradientBrush>
                     </Border.Background>
                  </Border>
                  <TextBlock Text="{Binding RebarMax, StringFormat='{}{0:G4}'}"
                             FontSize="8" VerticalAlignment="Top"
                             HorizontalAlignment="Left" Margin="0,1"/>
                  <TextBlock Text="0" FontSize="8" VerticalAlignment="Center"
                             HorizontalAlignment="Left" Margin="0,0"/>
                  <TextBlock Text="{Binding RebarMin, StringFormat='{}{0:G4}'}"
                             FontSize="8" VerticalAlignment="Bottom"
                             HorizontalAlignment="Left" Margin="0,0,0,1"/>
               </Grid>
            </StackPanel>
         </Border>

         <!-- FiberCanvas -->
         <h:FiberCanvas Grid.Column="1" x:Name="Canvas"
                        ViewModel="{Binding}"/>

         <!-- Colorbar Осн. материал (справа) -->
         <Border Grid.Column="2" Width="64" Margin="4">
            <StackPanel>
               <TextBlock Text="{DynamicResource ColorbarMainMaterial}"
                          FontSize="10" TextWrapping="Wrap" TextAlignment="Center"
                          Margin="0,0,0,2"/>
               <!-- Градиент с метками min/0/max поверх (overlay) -->
               <Grid MinHeight="120">
                  <Border Margin="4,0,18,0">
                     <Border.Background>
                        <!-- красный(top=max)→белый→синий(bottom=min) -->
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                           <GradientStop Color="#FF0000" Offset="0"/>
                           <GradientStop Color="#FFFFFF" Offset="0.5"/>
                           <GradientStop Color="#0000FF" Offset="1"/>
                        </LinearGradientBrush>
                     </Border.Background>
                  </Border>
                  <TextBlock Text="{Binding ConcreteMax, StringFormat='{}{0:G4}'}"
                             FontSize="8" VerticalAlignment="Top"
                             HorizontalAlignment="Right" Margin="0,1"/>
                  <TextBlock Text="0" FontSize="8" VerticalAlignment="Center"
                             HorizontalAlignment="Right" Margin="0,0"/>
                  <TextBlock Text="{Binding ConcreteMin, StringFormat='{}{0:G4}'}"
                             FontSize="8" VerticalAlignment="Bottom"
                             HorizontalAlignment="Right" Margin="0,0,0,1"/>
               </Grid>
            </StackPanel>
         </Border>
      </Grid>
   </Grid>
</UserControl>
