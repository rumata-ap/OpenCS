<UserControl x:Class="OpenCS.Views.FemAnalysisResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
             xmlns:u="clr-namespace:OpenCS.Utilites"
             xmlns:helpers="clr-namespace:OpenCS.Views.Helpers"
             xmlns:local="clr-namespace:OpenCS.Views"
             Language="ru-RU">
    <UserControl.Resources>
        <u:AnyDoubleConverter x:Key="AnyDoubleConv"/>
        <u:NToKNConvert x:Key="NToKN"/>
        <u:FemForceComponentLabelConverter x:Key="ForceComponentLabelConv"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="IconToggleButton25" TargetType="ToggleButton">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Width" Value="25"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        <Style x:Key="IconButton25" TargetType="Button">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Width" Value="25"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        <ContextMenu x:Key="ResultMemberContextMenu">
            <MenuItem Header="{DynamicResource FemResultMember2D}" Click="MemberShow2DCtx_Click"/>
            <MenuItem Header="{DynamicResource FemResultMemberSection}" Click="MemberSectionCtx_Click"/>
        </ContextMenu>
        <ContextMenu x:Key="ResultNodeContextMenu">
            <MenuItem Header="{DynamicResource FemResultNodeValues}" Click="NodeValuesCtx_Click"/>
        </ContextMenu>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- 3D -->
            <TabItem Header="{DynamicResource FemResultTab3D}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ToolBar Grid.Row="0">
                        <TextBlock Text="{DynamicResource FemResultDeformScale}" VerticalAlignment="Center" Margin="4,0,2,0"/>
                        <TextBox Width="65" Text="{Binding DeformScale, StringFormat=F2, Converter={StaticResource AnyDoubleConv}, UpdateSourceTrigger=PropertyChanged, Delay=500}" VerticalAlignment="Center" TextAlignment="Center" Margin="4,0"/>
                        <Button Style="{StaticResource IconButton25}" ToolTip="{DynamicResource FemResetScale}" Command="{Binding ResetDeformScaleCommand}">
                            <Path Data="M12,6V9L16,5L12,1V4A8,8 0 0,0 4,12C4,14.21 4.9,16.21 6.34,17.65L7.76,16.24C6.67,15.15 6,13.66 6,12A6,6 0 0,1 12,6Z" Fill="Black" Stretch="Uniform" Margin="2"/>
                        </Button>
                        <Separator/>
                        <ToggleButton x:Name="showNodesCheck" Style="{StaticResource IconToggleButton25}"
                                      IsChecked="True" ToolTip="{DynamicResource Fem3DShowNodes}"
                                      Checked="NodesToggle" Unchecked="NodesToggle">
                            <Path Data="M12,4A2.5,2.5 0 0,1 14.5,6.5A2.5,2.5 0 0,1 12,9A2.5,2.5 0 0,1 9.5,6.5A2.5,2.5 0 0,1 12,4M5.5,14A2.5,2.5 0 0,1 8,16.5A2.5,2.5 0 0,1 5.5,19A2.5,2.5 0 0,1 3,16.5A2.5,2.5 0 0,1 5.5,14M18.5,14A2.5,2.5 0 0,1 21,16.5A2.5,2.5 0 0,1 18.5,19A2.5,2.5 0 0,1 16,16.5A2.5,2.5 0 0,1 18.5,14Z" Fill="Black" Stretch="Uniform" Margin="2"/>
                        </ToggleButton>
                        <ToggleButton x:Name="highlightWholeMemberCheck" Style="{StaticResource IconToggleButton25}"
                                      IsChecked="True" ToolTip="{DynamicResource FemResultHighlightWholeMember}"
                                      Checked="HighlightWholeMemberToggle" Unchecked="HighlightWholeMemberToggle">
                            <Path Data="M4,11H20V13H4V11M2,7A2,2 0 0,1 4,5H20A2,2 0 0,1 22,7V17A2,2 0 0,1 20,19H4A2,2 0 0,1 2,17V7M4,7V17H20V7H4Z" Fill="Black" Stretch="Uniform" Margin="2"/>
                        </ToggleButton>
                        <Separator/>
                        <TextBlock Text="{DynamicResource FemResultForceComponent}" VerticalAlignment="Center" Margin="4,0,2,0"/>
                        <ComboBox Width="90" Margin="4,0" VerticalAlignment="Center"
                                  ItemsSource="{Binding ForceComponents}"
                                  SelectedItem="{Binding SelectedForceComponent, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource ForceComponentLabelConv}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="{DynamicResource FemResultForceScale}" VerticalAlignment="Center" Margin="4,0,2,0"/>
                        <TextBox Width="65" Text="{Binding ForceScale, StringFormat=F2, Converter={StaticResource AnyDoubleConv}, UpdateSourceTrigger=PropertyChanged, Delay=500}" VerticalAlignment="Center" TextAlignment="Center" Margin="4,0"/>
                        <Button Style="{StaticResource IconButton25}" ToolTip="{DynamicResource FemResetScale}" Command="{Binding ResetForceScaleCommand}">
                            <Path Data="M12,6V9L16,5L12,1V4A8,8 0 0,0 4,12C4,14.21 4.9,16.21 6.34,17.65L7.76,16.24C6.67,15.15 6,13.66 6,12A6,6 0 0,1 12,6Z" Fill="Black" Stretch="Uniform" Margin="2"/>
                        </Button>
                    </ToolBar>
                    <h:HelixViewport3D x:Name="viewport" Grid.Row="1" Background="White"
                                       ShowCoordinateSystem="True" ShowViewCube="True"
                                       ZoomAroundMouseDownPoint="True"
                                       PreviewMouseRightButtonDown="Viewport_PreviewMouseRightButtonDown"/>
                </Grid>
            </TabItem>

            <!-- Перемещения -->
            <TabItem Header="{DynamicResource FemResultTabDisp}">
                <DataGrid x:Name="displacementsGrid" ItemsSource="{Binding Displacements}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False"
                          SelectedItem="{Binding SelectedDisplacementRow, Mode=OneWay}"
                          SelectionChanged="DisplacementsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource FemColNode}" Binding="{Binding NodeTag}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColDispUx}" Binding="{Binding Ux, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColDispUy}" Binding="{Binding Uy, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColDispUz}" Binding="{Binding Uz, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColDispRx}" Binding="{Binding Rx, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColDispRy}" Binding="{Binding Ry, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColDispRz}" Binding="{Binding Rz, StringFormat=G6}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Реакции -->
            <TabItem Header="{DynamicResource FemResultTabReact}">
                <DataGrid x:Name="reactionsGrid" ItemsSource="{Binding Reactions}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False"
                          SelectedItem="{Binding SelectedReactionRow, Mode=OneWay}"
                          SelectionChanged="ReactionsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource FemColNode}" Binding="{Binding NodeTag}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColReactRx}" Binding="{Binding Rx, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColReactRy}" Binding="{Binding Ry, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColReactRz}" Binding="{Binding Rz, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColReactMx}" Binding="{Binding Mx, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColReactMy}" Binding="{Binding My, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColReactMz}" Binding="{Binding Mz, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Усилия -->
            <TabItem Header="{DynamicResource FemResultTabForces}">
                <DataGrid x:Name="elementForcesGrid" ItemsSource="{Binding ElementForces}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False"
                          SelectedItem="{Binding SelectedForceRow, Mode=OneWay}"
                          SelectionChanged="ElementForcesGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource FemColElement}" Binding="{Binding ElemTag}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColForceNi}"  Binding="{Binding Ni,  Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColForceQyi}" Binding="{Binding Qyi, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColForceQzi}" Binding="{Binding Qzi, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColForceMxi}" Binding="{Binding Mxi, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColForceMyi}" Binding="{Binding Myi, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColForceMzi}" Binding="{Binding Mzi, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColForceNj}"  Binding="{Binding Nj,  Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColForceQyj}" Binding="{Binding Qyj, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColForceQzj}" Binding="{Binding Qzj, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColForceMxj}" Binding="{Binding Mxj, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColForceMyj}" Binding="{Binding Myj, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                        <DataGridTextColumn Header="{DynamicResource FemColForceMzj}" Binding="{Binding Mzj, Converter={StaticResource NToKN}, StringFormat=G6}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Напряжения и деформации fiber-сечения -->
            <TabItem Header="{DynamicResource FemResultTabSections}"
                     Visibility="{Binding HasSectionResults, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="150"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{DynamicResource FemResultSectionPoint}" Margin="6,6,6,2"/>
                    <DataGrid Grid.Row="1" Margin="6,2" ItemsSource="{Binding SectionLocations}"
                              SelectedItem="{Binding SelectedSectionLocation, Mode=TwoWay}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource FemResultSectionMember}" Binding="{Binding SourceMemberTag}"/>
                            <DataGridTextColumn Header="{DynamicResource FemResultSectionElement}" Binding="{Binding MeshElementTag}"/>
                            <DataGridTextColumn Header="{DynamicResource FemResultSectionPoint}" Binding="{Binding IntegrationPoint}"/>
                            <DataGridTextColumn Header="{DynamicResource FemResultSectionPosition}" Binding="{Binding PositionFromMemberStartM, StringFormat=F3}"/>
                            <DataGridTextColumn Header="{DynamicResource FemResultSectionPosition}" Binding="{Binding RelativePosition, StringFormat=P1}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Margin="6,2">
                        <TextBlock Text="{DynamicResource FemResultSectionPosition}"/>
                        <TextBlock Text="{Binding SelectedSectionPositionLabel}"/>
                        <ProgressBar Minimum="0" Maximum="1" Height="8" Margin="0,3"
                                     Value="{Binding SelectedSectionLocation.RelativePosition}"/>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{DynamicResource FemResultSectionStart}"/>
                            <TextBlock DockPanel.Dock="Right" Text="{DynamicResource FemResultSectionEnd}"/>
                        </DockPanel>
                    </StackPanel>
                    <Grid Grid.Row="3" Visibility="{Binding HasSelectedSectionState, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{DynamicResource FemResultSectionStress}" Margin="6,2"/>
                            <local:SectionPlotView Grid.Row="1" DataContext="{Binding SectionStressPlot}"/>
                        </Grid>
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{DynamicResource FemResultSectionStrain}" Margin="6,2"/>
                            <local:SectionPlotView Grid.Row="1" DataContext="{Binding SectionStrainPlot}"/>
                        </Grid>
                    </Grid>
                    <TextBlock Grid.Row="3" Text="{DynamicResource FemResultSectionUnavailable}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasSelectedSectionState, Converter={StaticResource InverseBoolToVisibility}}"/>
                </Grid>
            </TabItem>

            <!-- История (только нелинейный расчёт) -->
            <TabItem Header="{DynamicResource FemResultTabHistory}" Visibility="{Binding IsNonlinear, Converter={StaticResource BoolToVis}}">
                <helpers:FemLoadFactorCanvas x:Name="loadFactorCanvas"/>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4"
                    Visibility="{Binding IsNonlinear, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{DynamicResource FemResultStep}" VerticalAlignment="Center"/>
            <Slider x:Name="stepSlider" Width="220" Margin="8,0"
                    Minimum="0" Maximum="{Binding MaxStepIndex}"
                    Value="{Binding SelectedStepIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding CurrentStepLabel}" VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
