<UserControl x:Class="OpenCS.Views.ShellStrainBatchResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <TextBlock x:Name="SummaryText" DockPanel.Dock="Top" FontWeight="Bold" Margin="0,0,0,6"/>
        <DataGrid x:Name="RowsGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource ShellStrainColLabel}" Binding="{Binding Label}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource ShellStrainColStatus}" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="{DynamicResource ShellStrainColIter}" Binding="{Binding Iterations}" Width="90"/>
                <DataGridTextColumn Header="{DynamicResource ShellStrainColResidual}" Binding="{Binding Residual}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
