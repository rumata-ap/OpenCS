<UserControl x:Class="OpenCS.Views.SteelCheckResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock FontSize="16" FontWeight="Bold" Text="{Binding SectionTag}"/>
            <TextBlock Text="{Binding SteelTag}" Margin="0,2,0,0" Foreground="Gray"/>
        </StackPanel>

        <!-- Контекст расчёта -->
        <Border Grid.Row="1" Padding="8,6" Margin="0,0,0,4" CornerRadius="4"
                Background="#F0F4F8" BorderBrush="#D5DDE5" BorderThickness="1">
            <StackPanel>
                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#555" Text="Параметры расчёта:"/>
                <TextBlock FontSize="12" Text="{Binding ContextSummary}" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Усилия -->
        <Border Grid.Row="2" Padding="8,6" Margin="0,0,0,8" CornerRadius="4"
                Background="#FFF8F0" BorderBrush="#E8D5C0" BorderThickness="1">
            <StackPanel>
                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#555" Text="Усилия:"/>
                <TextBlock FontSize="12" Text="{Binding ForcesSummary}" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Вердикт -->
        <Border Grid.Row="3" Padding="12,8" Margin="0,0,0,8" CornerRadius="4"
                Background="{Binding StatusBrush}">
            <TextBlock Text="{Binding VerdictText}" HorizontalAlignment="Center"
                       FontWeight="Bold" FontSize="14" Foreground="{Binding VerdictBrush}"/>
        </Border>

        <!-- Кнопка экспорта -->
        <Button Grid.Row="4" Content="{DynamicResource ExportCsvBtn}" Margin="0,0,0,8"
                HorizontalAlignment="Left" Padding="12,4"
                Click="ExportCsv_Click"/>

        <!-- Группы проверок — текстовый вывод -->
        <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="True" Margin="0,0,0,8">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="12" Height="12" CornerRadius="2"
                                            Background="{Binding HeaderBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding MaxRatioText}" Margin="12,0,0,0"
                                               FontWeight="SemiBold" Foreground="{Binding MaxRatioBrush}"/>
                                </StackPanel>
                            </Expander.Header>
                            <ItemsControl ItemsSource="{Binding Items}" Margin="4,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Padding="8,6" CornerRadius="4"
                                                Background="{Binding RowBackground}"
                                                BorderBrush="#E0E0E0" BorderThickness="1">
                                            <StackPanel>
                                                <!-- Строка: формула + описание + коэфф. -->
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontWeight="Bold" Foreground="#2C3E50">
                                                        <Run Text="{Binding Formula, Mode=OneWay}"/>
                                                        <Run Text="  "/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Description}" FontWeight="SemiBold"/>
                                                    <TextBlock Margin="12,0,0,0" Foreground="#555">
                                                        <Run Text="{Binding AppliedDisplay, Mode=OneWay}"/>
                                                        <Run Text=" ≤ "/>
                                                        <Run Text="{Binding AllowableDisplay, Mode=OneWay}"/>
                                                        <Run Text="  →  "/>
                                                    </TextBlock>
                                                    <TextBlock FontWeight="Bold" Foreground="{Binding RatioBrush}">
                                                        <Run Text="{Binding RatioText, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Margin="8,0,0,0" FontWeight="Bold"
                                                               Foreground="{Binding PassedBrush}">
                                                        <Run Text="{Binding PassedText, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <!-- Норма -->
                                                <TextBlock FontSize="11" Foreground="#888" Margin="0,2,0,0"
                                                           Text="{Binding NormRef}"/>
                                                <!-- Трассировка -->
                                                <TextBlock FontSize="11" Foreground="#6A5ACD" Margin="0,2,0,0"
                                                           Text="{Binding Trace}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
