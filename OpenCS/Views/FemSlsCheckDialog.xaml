<Window x:Class="OpenCS.Views.FemSlsCheckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FemSlsDlgTitle}"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Схема -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource FemCheckDlgSchema}"
                   VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox Grid.Row="0" Grid.Column="1"
                  ItemsSource="{Binding Schemas}" DisplayMemberPath="Tag"
                  SelectedItem="{Binding SelectedSchema}" Margin="0,0,0,8"/>

        <!-- Элемент -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource FemCheckDlgMember}"
                   VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox Grid.Row="1" Grid.Column="1"
                  ItemsSource="{Binding Members}" DisplayMemberPath="Tag"
                  SelectedItem="{Binding SelectedMember}" Margin="0,0,0,8"/>

        <!-- Наборы усилий -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource FemCheckDlgForceSets}"
                   VerticalAlignment="Top" Margin="0,4,8,4"/>
        <CheckBox Grid.Row="2" Grid.Column="1"
                  Content="{DynamicResource FemCheckDlgAllSets}"
                  IsChecked="{Binding AllSets}" Margin="0,4,0,4"/>
        <ListBox Grid.Row="3" Grid.Column="1"
                 x:Name="ForceSetsBox"
                 ItemsSource="{Binding FilteredForceSets}"
                 DisplayMemberPath="Tag"
                 SelectionMode="Extended"
                 IsEnabled="{Binding CanSelectSets}"
                 Margin="0,0,0,8"/>

        <!-- Метод проверки -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource FemSlsDlgPlateKind}"
                   VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox Grid.Row="4" Grid.Column="1"
                  ItemsSource="{Binding SlsKinds}"
                  SelectedItem="{Binding SelectedSlsKind}"
                  DisplayMemberPath="Label"
                  Margin="0,0,0,8"/>

        <!-- NL набор усилий (shell_layered) -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource FemSlsDlgNlForceSet}"
                   VerticalAlignment="Center" Margin="0,0,8,8"
                   Visibility="{Binding NlRowVisibility}"/>
        <ComboBox Grid.Row="5" Grid.Column="1"
                  ItemsSource="{Binding NlForceSets}"
                  SelectedItem="{Binding SelectedNlForceSet}"
                  DisplayMemberPath="Tag"
                  Margin="0,0,0,8"
                  Visibility="{Binding NlRowVisibility}"/>

        <!-- Доля длительности (shell_layered, без NL-набора) -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource FemSlsDlgLtFraction}"
                   VerticalAlignment="Center" Margin="0,0,8,8"
                   Visibility="{Binding NlRowVisibility}"/>
        <TextBox Grid.Row="6" Grid.Column="1"
                 Text="{Binding LtFraction, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding LtFractionEnabled}"
                 Margin="0,0,0,8"
                 Visibility="{Binding NlRowVisibility}"/>

        <!-- φ1 (wa_sls / capri_sls) -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="{DynamicResource FemCheckDlgPhi1Mode}"
                   VerticalAlignment="Center" Margin="0,0,8,8"
                   Visibility="{Binding Phi1RowVisibility}"/>
        <Grid Grid.Row="7" Grid.Column="1" Margin="0,0,0,8"
              Visibility="{Binding Phi1RowVisibility}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Phi1Modes}"
                      SelectedItem="{Binding SelectedPhi1Mode}"
                      DisplayMemberPath="Label"/>
            <TextBlock Grid.Column="1" Text="φ1 ="
                       VerticalAlignment="Center" Margin="8,0,4,0"
                       Visibility="{Binding Phi1ManualVisibility}"/>
            <TextBox Grid.Column="2"
                     Text="{Binding Phi1, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{Binding Phi1ManualVisibility}"/>
        </Grid>

        <!-- acrc,пред + φ2 -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="{DynamicResource FemCheckDlgAcrcLim}"
                   VerticalAlignment="Center" Margin="0,0,8,8"/>
        <Grid Grid.Row="8" Grid.Column="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding AcrcLimMm, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Grid.Column="1" Text="{DynamicResource FemSlsDlgPhi2Label}"
                       VerticalAlignment="Center" Margin="8,0,4,0"/>
            <TextBox Grid.Column="2"
                     Text="{Binding Phi2, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- Характеристики материалов (CalcType) -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="{DynamicResource FemCheckDlgCalcType}"
                   VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox Grid.Row="9" Grid.Column="1"
                  ItemsSource="{Binding CalcTypeOptions}"
                  SelectedItem="{Binding SelectedCalcTypeOption}"
                  DisplayMemberPath="Label"
                  Margin="0,0,0,8"/>

        <!-- Имя -->
        <TextBlock Grid.Row="10" Grid.Column="0" Text="{DynamicResource FemCheckDlgTag}"
                   VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox Grid.Row="10" Grid.Column="1"
                 Text="{Binding Tag, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,8"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource OK}" IsDefault="True"
                    Click="Ok_Click" Padding="20,4" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Cancel}" IsCancel="True" Padding="16,4"/>
        </StackPanel>
    </Grid>
</Window>
