<UserControl x:Class="OpenCS.Views.CrossSectionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenCS.ViewModels"
             xmlns:core="clr-namespace:CScore;assembly=CScore"
             xmlns:conv="clr-namespace:OpenCS.Converters"
             xmlns:local="clr-namespace:OpenCS.Views">
   <UserControl.Resources>
      <conv:MatTypeToBrushConverter x:Key="MatTypeToBrush"/>
      <conv:MatTypeToGeometryConverter x:Key="MatTypeToGeom"/>
   </UserControl.Resources>

   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Верхняя панель: обозначение + кнопка Сохранить -->
      <Border Grid.Row="0" BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
              Padding="8,6">
         <StackPanel Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Tag}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding Tag, UpdateSourceTrigger=PropertyChanged}"
                     Width="220" Margin="0,0,12,0"/>
            <Button Content="{DynamicResource Save}"
                    Command="{Binding SaveCommand}"
                    Padding="16,3"/>
         </StackPanel>
      </Border>

      <!-- Основная область: список | превью | редактор -->
      <Grid Grid.Row="1">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" MinWidth="140"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*" MinWidth="100"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="280" MinWidth="200"/>
         </Grid.ColumnDefinitions>

         <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" ShowsPreview="True"/>
         <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" ShowsPreview="True"/>

         <!-- Левая панель: В сечении / Из пула -->
         <Grid Grid.Column="0" Margin="4">
            <Grid.RowDefinitions>
               <RowDefinition Height="*"/>
               <RowDefinition Height="4"/>
               <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Список областей сечения -->
            <DockPanel Grid.Row="0">
               <TextBlock DockPanel.Dock="Top" Text="{DynamicResource CrossSectionAreas}"
                          FontWeight="SemiBold" Margin="0,0,0,4"/>
               <ListBox ItemsSource="{Binding Areas}"
                        SelectedItem="{Binding SelectedArea, Mode=TwoWay}"
                        BorderThickness="1" Padding="2">
                  <ListBox.ItemTemplate>
                     <DataTemplate DataType="{x:Type vm:MaterialAreaVM}">
                        <Grid Margin="2,1">
                           <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="16"/>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="22"/>
                           </Grid.ColumnDefinitions>
                           <Path Grid.Column="0" Width="12" Height="12" Stretch="Uniform"
                                 Fill="{Binding MaterialType, Converter={StaticResource MatTypeToBrush}}"
                                 Data="{Binding MaterialType, Converter={StaticResource MatTypeToGeom}}"/>
                           <TextBlock Grid.Column="1" Text="{Binding Tag}"
                                      VerticalAlignment="Center" Margin="4,0"/>
                           <Button Grid.Column="2" Style="{StaticResource IconButton25}"
                                   ToolTip="{DynamicResource DeleteArea}"
                                   Command="{Binding DataContext.RemoveAreaFromSectionCommand,
                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}">
                              <Path Data="M4,4 L12,12 M12,4 L4,12" Stroke="Gray"
                                    StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                           </Button>
                        </Grid>
                     </DataTemplate>
                  </ListBox.ItemTemplate>
               </ListBox>
            </DockPanel>

            <GridSplitter Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                          ShowsPreview="True" Height="4"/>

            <!-- Список областей из пула -->
            <DockPanel Grid.Row="2">
               <TextBlock DockPanel.Dock="Top" Text="{DynamicResource CrossSectionPool}"
                          FontWeight="SemiBold" Margin="0,4,0,4"/>
               <ListBox ItemsSource="{Binding App.MaterialAreas}"
                        BorderThickness="1" Padding="2">
                  <ListBox.ItemTemplate>
                     <DataTemplate DataType="{x:Type core:MaterialArea}">
                        <Grid Margin="2,1">
                           <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="16"/>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="22"/>
                           </Grid.ColumnDefinitions>
                           <Path Grid.Column="0" Width="12" Height="12" Stretch="Uniform"
                                 Fill="{Binding Material.Type, Converter={StaticResource MatTypeToBrush}, FallbackValue=Gray}"
                                 Data="{Binding Material.Type, Converter={StaticResource MatTypeToGeom}, FallbackValue={x:Null}}"/>
                           <TextBlock Grid.Column="1" Text="{Binding Tag}"
                                      VerticalAlignment="Center" Margin="4,0"/>
                           <Button Grid.Column="2" Style="{StaticResource IconButton25}"
                                   ToolTip="{DynamicResource AddToSection}"
                                   Command="{Binding DataContext.AddFromPoolCommand,
                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}">
                              <Path Data="M8,4 L8,12 M4,8 L12,8" Stroke="Gray"
                                    StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                           </Button>
                        </Grid>
                     </DataTemplate>
                  </ListBox.ItemTemplate>
               </ListBox>
            </DockPanel>
         </Grid>

         <!-- Центральная панель: превью сечения -->
         <Border Grid.Column="2" BorderThickness="1,0,1,0"
                 BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}">
            <local:PlotCanvas x:Name="preview"/>
         </Border>

         <!-- Правая панель: редактор выбранной области -->
         <ContentControl Grid.Column="4" Content="{Binding SelectedArea}">
            <ContentControl.Style>
               <Style TargetType="ContentControl">
                  <Style.Triggers>
                     <DataTrigger Binding="{Binding SelectedArea}" Value="{x:Null}">
                        <Setter Property="Template">
                           <Setter.Value>
                              <ControlTemplate>
                                 <TextBlock Text="{DynamicResource CrossSectionSelectArea}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Foreground="LightGray" FontSize="13" TextWrapping="Wrap"
                                            Margin="16"/>
                              </ControlTemplate>
                           </Setter.Value>
                        </Setter>
                     </DataTrigger>
                  </Style.Triggers>
               </Style>
            </ContentControl.Style>
            <ContentControl.ContentTemplate>
               <DataTemplate DataType="{x:Type vm:MaterialAreaVM}">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                     <StackPanel Margin="8">

                        <!-- Обозначение -->
                        <TextBlock Text="{DynamicResource Tag}" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding Tag, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8"/>

                        <!-- Материал -->
                        <TextBlock Text="{DynamicResource Material}" Margin="0,0,0,2"/>
                        <ComboBox ItemsSource="{Binding App.Materials}"
                                  SelectedItem="{Binding Material}"
                                  DisplayMemberPath="Tag"
                                  Margin="0,0,0,8"/>

                        <!-- Тип диаграммы -->
                        <TextBlock Text="{DynamicResource DiagramType}" Margin="0,0,0,2"/>
                        <ComboBox ItemsSource="{Binding DiagramTypeValues}"
                                  SelectedItem="{Binding DiagrammType}"
                                  Margin="0,0,0,8"/>

                        <!-- Hull -->
                        <GroupBox Header="{DynamicResource Hull}" Margin="0,0,0,8">
                           <StackPanel Margin="4">
                              <ComboBox ItemsSource="{Binding ProjectContours}"
                                        SelectedItem="{Binding PoolContour, Mode=TwoWay}"
                                        DisplayMemberPath="Tag"
                                        Margin="0,0,0,4"/>
                              <StackPanel Orientation="Horizontal">
                                 <Button Content="{DynamicResource SelectFromPool}"
                                         Command="{Binding SetHullFromPoolCommand}"
                                         CommandParameter="{Binding PoolContour}"
                                         Padding="6,3" Margin="0,0,4,0"/>
                                 <Button Content="{DynamicResource ClearHull}"
                                         Command="{Binding ClearHullCommand}"
                                         Padding="6,3"/>
                              </StackPanel>
                              <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="Gray">
                                 <Run Text="{DynamicResource CurrentHull}"/>
                                 <Run Text="{Binding Hull.Tag, FallbackValue='-'}"/>
                              </TextBlock>
                           </StackPanel>
                        </GroupBox>

                        <!-- Сетка -->
                        <GroupBox Header="{DynamicResource MeshGrid}" Margin="0,0,0,8">
                           <StackPanel Margin="4">
                              <TextBlock Margin="0,0,0,4">
                                 <Run Text="{DynamicResource MeshFibersCount}"/>
                                 <Run Text="{Binding FibersCount, Mode=OneWay}"/>
                              </TextBlock>
                              <StackPanel Orientation="Horizontal">
                                 <Button Content="{DynamicResource MeshConfigure}"
                                         Command="{Binding DataContext.OpenMeshForAreaCommand,
                                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                                         CommandParameter="{Binding}"
                                         Padding="8,3" Margin="0,0,4,0"/>
                                 <Button Content="{DynamicResource MeshClear}"
                                         Command="{Binding ClearMeshCommand}"
                                         Padding="8,3"/>
                              </StackPanel>
                           </StackPanel>
                        </GroupBox>

                     </StackPanel>
                  </ScrollViewer>
               </DataTemplate>
            </ContentControl.ContentTemplate>
         </ContentControl>

      </Grid>
   </Grid>
</UserControl>
