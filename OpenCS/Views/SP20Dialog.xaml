<Window x:Class="OpenCS.Views.SP20Dialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OpenCS.ViewModels"
        Title="{DynamicResource SP20DialogTitle}"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

   <Grid Margin="12">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="160"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="120"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Выбор наборов -->
      <TextBlock Grid.Row="0" Text="{DynamicResource SP20SelectSets}"
                 FontWeight="SemiBold" Margin="0,0,0,4"/>

      <ListBox Grid.Row="1" ItemsSource="{Binding Items}"
               BorderThickness="1" Margin="0,0,0,8">
         <ListBox.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:ForceSetSelectionVM}">
               <StackPanel Orientation="Horizontal" Margin="2,1">
                  <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                            VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding ForceSet.Tag}" Margin="6,0,0,0"
                             VerticalAlignment="Center"/>
               </StackPanel>
            </DataTemplate>
         </ListBox.ItemTemplate>
      </ListBox>

      <!-- Режим сочетания -->
      <Grid Grid.Row="2" Margin="0,0,0,8">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
         </Grid.ColumnDefinitions>
         <TextBlock Grid.Column="0" Text="{DynamicResource SP20ModeLabel}"
                    VerticalAlignment="Center"/>
         <ComboBox Grid.Column="1" ItemsSource="{Binding ModeOptions}"
                   SelectedItem="{Binding SelectedMode, Mode=TwoWay}"/>
      </Grid>

      <!-- Флаги вывода -->
      <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
         <CheckBox Content="{DynamicResource SP20MakeEnvelope}"
                   IsChecked="{Binding MakeEnvelope, Mode=TwoWay}"
                   Margin="0,0,16,0"/>
         <CheckBox Content="{DynamicResource SP20MakeCases}"
                   IsChecked="{Binding MakeCases, Mode=TwoWay}"/>
      </StackPanel>

      <!-- Имя результата -->
      <Grid Grid.Row="4" Margin="0,0,0,8">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
         </Grid.ColumnDefinitions>
         <TextBlock Grid.Column="0" Text="{DynamicResource SP20ResultName}"
                    VerticalAlignment="Center"/>
         <TextBox Grid.Column="1"
                  Text="{Binding ResultName, UpdateSourceTrigger=PropertyChanged}"/>
      </Grid>

      <!-- Preview -->
      <GroupBox Grid.Row="5" Header="{DynamicResource SP20Preview}" Margin="0,0,0,8">
         <ScrollViewer VerticalScrollBarVisibility="Auto">
            <TextBlock Text="{Binding Preview}" FontFamily="Courier New" FontSize="11"
                       Margin="4" TextWrapping="Wrap"/>
         </ScrollViewer>
      </GroupBox>

      <!-- Кнопки -->
      <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
         <Button Content="{DynamicResource SP20Generate}"
                 Command="{Binding GenerateCommand}"
                 Padding="16,4" Margin="0,0,8,0"/>
         <Button Content="{DynamicResource Cancel}"
                 IsCancel="True"
                 Padding="16,4"/>
      </StackPanel>

   </Grid>
</Window>
