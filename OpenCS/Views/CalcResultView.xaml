<UserControl x:Class="OpenCS.Views.CalcResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

   <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="16">

         <!-- Заголовок -->
         <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{Binding TaskTag}"   FontSize="15" FontWeight="Bold" Margin="0,0,10,0"/>
            <TextBlock Text="{Binding StatusText}" FontSize="13" Foreground="{Binding StatusBrush}"/>
         </StackPanel>
         <TextBlock Text="{Binding Created}" Foreground="Gray" Margin="0,0,0,16"/>

         <!-- Результаты (strain_state) -->
         <ItemsControl ItemsSource="{Binding Rows}">
            <ItemsControl.ItemTemplate>
               <DataTemplate>
                  <Grid Margin="0,2">
                     <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                     </Grid.ColumnDefinitions>
                     <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="Gray"/>
                     <TextBlock Grid.Column="1" Text="{Binding Value}" FontFamily="Consolas"/>
                  </Grid>
               </DataTemplate>
            </ItemsControl.ItemTemplate>
         </ItemsControl>

      </StackPanel>
   </ScrollViewer>
</UserControl>
