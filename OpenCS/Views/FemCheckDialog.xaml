<Window x:Class="OpenCS.Views.FemCheckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FemCheckDlgTitle}"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 1. Схема -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource FemCheckDlgSchema}"
                   VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox Grid.Row="0" Grid.Column="1"
                  ItemsSource="{Binding Schemas}" DisplayMemberPath="Tag"
                  SelectedItem="{Binding SelectedSchema}" Margin="0,0,0,8"/>

        <!-- 2. Элемент -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource FemCheckDlgMember}"
                   VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox Grid.Row="1" Grid.Column="1"
                  ItemsSource="{Binding Members}" DisplayMemberPath="Tag"
                  SelectedItem="{Binding SelectedMember}" Margin="0,0,0,8"/>

        <!-- 3. Чекбокс "все наборы" -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource FemCheckDlgForceSets}"
                   VerticalAlignment="Top" Margin="0,4,8,4"/>
        <CheckBox Grid.Row="2" Grid.Column="1"
                  Content="{DynamicResource FemCheckDlgAllSets}"
                  IsChecked="{Binding AllSets}" Margin="0,4,0,4"/>

        <!-- 4. Список наборов усилий -->
        <ListBox Grid.Row="3" Grid.Column="1"
                 x:Name="ForceSetsBox"
                 ItemsSource="{Binding FilteredForceSets}"
                 DisplayMemberPath="Tag"
                 SelectionMode="Extended"
                 IsEnabled="{Binding CanSelectSets}"
                 Margin="0,0,0,8"/>

        <!-- 5. Вид проверки -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource FemCheckDlgNormCode}"
                   VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox Grid.Row="4" Grid.Column="1"
                  ItemsSource="{Binding NormCodes}"
                  SelectedItem="{Binding SelectedNormCode}"
                  DisplayMemberPath="Label"
                  Margin="0,0,0,8"/>

        <!-- 6. Метод плитной проверки (видим только для rc_plate_check) -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource FemCheckDlgPlateKind}"
                   VerticalAlignment="Center" Margin="0,0,8,8"
                   Visibility="{Binding PlateRowVisibility}"/>
        <Grid Grid.Row="5" Grid.Column="1" Margin="0,0,0,8"
              Visibility="{Binding PlateRowVisibility}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding PlateKinds}"
                      SelectedItem="{Binding SelectedPlateKind}"
                      DisplayMemberPath="Label"/>
            <TextBlock Grid.Column="1" Text="{DynamicResource FemCheckDlgAcrcLim}"
                       VerticalAlignment="Center" Margin="8,0,4,0"
                       Visibility="{Binding AcrcRowVisibility}"/>
            <TextBox Grid.Column="2"
                     Text="{Binding AcrcLimMm, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{Binding AcrcRowVisibility}"/>
        </Grid>

        <!-- 7. CalcType -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource FemCheckDlgCalcType}"
                   VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox Grid.Row="6" Grid.Column="1"
                  ItemsSource="{Binding CalcTypeOptions}"
                  SelectedItem="{Binding SelectedCalcTypeOption}"
                  DisplayMemberPath="Label"
                  Margin="0,0,0,8"/>

        <!-- 8. Имя -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="{DynamicResource FemCheckDlgTag}"
                   VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox Grid.Row="7" Grid.Column="1"
                 Text="{Binding Tag, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,8"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource OK}" IsDefault="True"
                    Click="Ok_Click" Padding="20,4" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Cancel}" IsCancel="True" Padding="16,4"/>
        </StackPanel>
    </Grid>
</Window>
