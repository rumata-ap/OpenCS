<UserControl x:Class="OpenCS.Views.CrackingBatchResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

   <Grid Margin="12">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Padding="8,6" CornerRadius="4" Background="{Binding StatusBrush}" Margin="0,0,0,8">
         <TextBlock Text="{Binding SummaryText}" FontWeight="Bold" HorizontalAlignment="Center"/>
      </Border>

      <DataGrid Grid.Row="1" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                CanUserSortColumns="True">
         <DataGrid.RowStyle>
            <Style TargetType="DataGridRow">
               <Style.Triggers>
                  <DataTrigger Binding="{Binding IsConverged}" Value="True">
                     <Setter Property="Background" Value="#1A2D7A3E"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsConverged}" Value="False">
                     <Setter Property="Background" Value="#1AC0392B"/>
                  </DataTrigger>
               </Style.Triggers>
            </Style>
         </DataGrid.RowStyle>
         <DataGrid.Columns>
            <DataGridTextColumn Header="{DynamicResource StrainStateBatch_ColNum}" Binding="{Binding Num}" Width="40"/>
            <DataGridTextColumn Header="{DynamicResource StrainStateBatch_ColLabel}" Binding="{Binding Label}" Width="*"/>
            <DataGridTextColumn Header="N, кН" Binding="{Binding NText}" Width="75"/>
            <DataGridTextColumn Header="{DynamicResource Cracking_ColMxCrc}" Binding="{Binding MxCrcText}" Width="90"/>
            <DataGridTextColumn Header="{DynamicResource Cracking_ColMyCrc}" Binding="{Binding MyCrcText}" Width="90"/>
            <DataGridTextColumn Header="{DynamicResource Cracking_ColMcrc}" Binding="{Binding McrcText}" Width="90"/>
            <DataGridTextColumn Header="{DynamicResource StrainStateBatch_ColStatus}" Binding="{Binding StatusText}" Width="70"/>
         </DataGrid.Columns>
      </DataGrid>
   </Grid>
</UserControl>
