<UserControl x:Class="OpenCS.Views.StrengthNDMBatchResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

   <TabControl>
      <TabItem Header="{DynamicResource ResultTabSummary}">
         <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12,8">
               <TextBlock Text="{Binding TaskTag}" FontSize="14" FontWeight="Bold"/>
               <TextBlock Text="{Binding CreatedText}" Foreground="Gray" Margin="0,0,0,8"/>
               <TextBlock Text="{Binding ErrorText}" Foreground="DarkRed" FontWeight="Bold"
                          Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>
               <TextBlock Text="{Binding SummaryText}" FontSize="13" Foreground="{Binding StatusBrush}"
                          TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
         </ScrollViewer>
      </TabItem>

      <TabItem Header="{DynamicResource StrengthNDMBatch_TabRows}">
         <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                   IsReadOnly="True" CanUserAddRows="False" Margin="4">
            <DataGrid.RowStyle>
               <Style TargetType="DataGridRow">
                  <Style.Triggers>
                     <DataTrigger Binding="{Binding IsPassed}" Value="True">
                        <Setter Property="Background" Value="#2200CC44"/>
                     </DataTrigger>
                     <DataTrigger Binding="{Binding IsPassed}" Value="False">
                        <Setter Property="Background" Value="#22CC2200"/>
                     </DataTrigger>
                  </Style.Triggers>
               </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
               <DataGridTextColumn Header="{DynamicResource StrainStateBatch_ColNum}"
                                   Binding="{Binding Num}" Width="40"/>
               <DataGridTextColumn Header="{DynamicResource StrainStateBatch_ColLabel}"
                                   Binding="{Binding Label}" Width="*"/>
               <DataGridTextColumn Header="N, кН" Binding="{Binding NText}" Width="75"/>
               <DataGridTextColumn Header="Mx, кН·м" Binding="{Binding MxText}" Width="82"/>
               <DataGridTextColumn Header="My, кН·м" Binding="{Binding MyText}" Width="82"/>
               <DataGridTextColumn Header="{DynamicResource StrengthNDM_ColEpsConcrete}"
                                   Binding="{Binding EpsConcreteCompText}" Width="85"/>
               <DataGridTextColumn Header="{DynamicResource StrengthNDM_ColEpsConcreteUlt}"
                                   Binding="{Binding EpsConcreteUltText}" Width="85"/>
               <DataGridTextColumn Header="{DynamicResource StrengthNDM_ColConcreteOk}"
                                   Binding="{Binding ConcreteOkText}" Width="65"/>
               <DataGridTextColumn Header="{DynamicResource StrengthNDM_ColEpsRebar}"
                                   Binding="{Binding EpsRebarTensionText}" Width="85"/>
               <DataGridTextColumn Header="{DynamicResource StrengthNDM_ColEpsRebarUlt}"
                                   Binding="{Binding EpsRebarUltText}" Width="85"/>
               <DataGridTextColumn Header="{DynamicResource StrengthNDM_ColRebarOk}"
                                   Binding="{Binding RebarOkText}" Width="65"/>
               <DataGridTextColumn Header="{DynamicResource StrengthNDM_ColStrengthOk}"
                                   Binding="{Binding StrengthOkText}" Width="65"/>
               <DataGridTextColumn Header="{DynamicResource StrainStateBatch_ColIter}"
                                   Binding="{Binding IterText}" Width="52"/>
               <DataGridTextColumn Header="{DynamicResource StrainStateBatch_ColStatus}"
                                   Binding="{Binding StatusText}" Width="65"/>
            </DataGrid.Columns>
         </DataGrid>
      </TabItem>
   </TabControl>
</UserControl>
