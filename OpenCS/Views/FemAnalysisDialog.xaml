<Window x:Class="OpenCS.Views.FemAnalysisDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FemAnalysisCreate}" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="12">
        <TextBlock Text="{DynamicResource FemAnalysisTagLabel}"/>
        <TextBox x:Name="TagBox" Text=""/>

        <TextBlock Text="{DynamicResource FemAnalysisLoadLabel}" Margin="0,8,0,0"/>
        <ComboBox x:Name="LoadSourceBox" DisplayMemberPath="Label"/>

        <TextBlock Text="{DynamicResource FemAnalysisExeLabel}" Margin="0,8,0,0"/>
        <TextBox x:Name="ExeBox" Text=""/>

        <TextBlock Text="{DynamicResource FemAnalysisTimeoutLabel}" Margin="0,8,0,0"/>
        <TextBox x:Name="TimeoutBox" Text="120"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{DynamicResource OK}" Click="Ok_Click" Padding="16,4" MinWidth="80"/>
            <Button Content="{DynamicResource Cancel}" Click="Cancel_Click" Padding="16,4" MinWidth="80" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>
