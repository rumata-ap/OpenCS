<Window x:Class="OpenCS.Views.FemAnalysisDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FemAnalysisCreate}" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="12">
        <TextBlock Text="{DynamicResource FemAnalysisTagLabel}"/>
        <TextBox x:Name="TagBox" Text=""/>

        <TextBlock Text="{DynamicResource FemAnalysisKindLabel}" Margin="0,8,0,0"/>
        <StackPanel Orientation="Horizontal">
            <RadioButton x:Name="KindLinearRadio" Content="{DynamicResource FemAnalysisKindLinear}"
                         GroupName="Kind" IsChecked="True" Checked="KindRadio_Changed" Margin="0,0,16,0"/>
            <RadioButton x:Name="KindNonlinearRadio" Content="{DynamicResource FemAnalysisKindNonlinear}"
                         GroupName="Kind" Checked="KindRadio_Changed"/>
        </StackPanel>

        <TextBlock Text="{DynamicResource FemAnalysisLoadLabel}" Margin="0,8,0,0"/>
        <ComboBox x:Name="LoadSourceBox" DisplayMemberPath="Label"/>

        <TextBlock Text="{DynamicResource FemAnalysisExeLabel}" Margin="0,8,0,0"/>
        <TextBox x:Name="ExeBox" Text=""/>

        <TextBlock Text="{DynamicResource FemAnalysisTimeoutLabel}" Margin="0,8,0,0"/>
        <TextBox x:Name="TimeoutBox" Text="120"/>

        <StackPanel x:Name="NonlinearPanel" Visibility="Collapsed" Margin="0,8,0,0">
            <Separator Margin="0,4"/>
            <TextBlock Text="{DynamicResource FemAnalysisCalcTypeLabel}"/>
            <ComboBox x:Name="CalcTypeBox"/>

            <TextBlock Text="{DynamicResource FemAnalysisLoadStepsLabel}" Margin="0,8,0,0"/>
            <TextBox x:Name="LoadStepsBox" Text="10"/>

            <TextBlock Text="{DynamicResource FemAnalysisToleranceLabel}" Margin="0,8,0,0"/>
            <TextBox x:Name="ToleranceBox" Text="1E-06"/>

            <TextBlock Text="{DynamicResource FemAnalysisMaxIterationsLabel}" Margin="0,8,0,0"/>
            <TextBox x:Name="MaxIterationsBox" Text="50"/>

            <TextBlock Text="{DynamicResource FemAnalysisGeomTransfLabel}" Margin="0,8,0,0"/>
            <ComboBox x:Name="GeomTransfBox" DisplayMemberPath="Label"/>

            <TextBlock Text="{DynamicResource FemAnalysisConvergenceTestLabel}" Margin="0,8,0,0"/>
            <ComboBox x:Name="ConvergenceTestBox" DisplayMemberPath="Label"/>

            <TextBlock Text="{DynamicResource FemAnalysisIntegrationPointsLabel}" Margin="0,8,0,0"/>
            <TextBox x:Name="IntegrationPointsBox" Text="5"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{DynamicResource OK}" Click="Ok_Click" Padding="16,4" MinWidth="80"/>
            <Button Content="{DynamicResource Cancel}" Click="Cancel_Click" Padding="16,4" MinWidth="80" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>
