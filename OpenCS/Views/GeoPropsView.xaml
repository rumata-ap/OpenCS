<UserControl x:Class="OpenCS.Views.GeoPropsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:core="clr-namespace:CScore;assembly=CScore"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="250">
   <GroupBox Header="{DynamicResource GeoPropsHeader}" Margin="3">
      <Grid Margin="2">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
         </Grid.ColumnDefinitions>
         <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
         </Grid.RowDefinitions>

         <TextBlock Grid.Row="0" Grid.Column="1"
                    Text="{Binding A, StringFormat={}{0:F4}}"
                    Foreground="Green" FontWeight="Bold" />
         <TextBlock Grid.Row="1" Grid.Column="1"
                    Text="{Binding EA, StringFormat={}{0:F2}}"
                    Foreground="Green" FontWeight="Bold" />
         <TextBlock Grid.Row="2" Grid.Column="1"
                    Text="{Binding ESx, StringFormat={}{0:F2}}"
                    Foreground="Green" FontWeight="Bold" />
         <TextBlock Grid.Row="3" Grid.Column="1"
                    Text="{Binding ESy, StringFormat={}{0:F2}}"
                    Foreground="Green" FontWeight="Bold" />
         <TextBlock Grid.Row="4" Grid.Column="1"
                    Text="{Binding EIx, StringFormat={}{0:F2}}"
                    Foreground="Green" FontWeight="Bold" />
         <TextBlock Grid.Row="5" Grid.Column="1"
                    Text="{Binding EIy, StringFormat={}{0:F2}}"
                    Foreground="Green" FontWeight="Bold" />
         <TextBlock Grid.Row="6" Grid.Column="1"
                    Text="{Binding EIxy, StringFormat={}{0:F2}}"
                    Foreground="Green" FontWeight="Bold" />
         <TextBlock Grid.Row="7" Grid.Column="1"
                    Text="{Binding Centroid.X, StringFormat={}{0:F4}}"
                    Foreground="Green" FontWeight="Bold" />
         <TextBlock Grid.Row="8" Grid.Column="1"
                    Text="{Binding Centroid.Y, StringFormat={}{0:F4}}"
                    Foreground="Green" FontWeight="Bold" />

         <TextBlock Grid.Row="0" Text="Area: " Foreground="Blue" FontWeight="Bold" />
         <TextBlock Grid.Row="1" Text="EA: " Foreground="Blue" FontWeight="Bold" />
         <TextBlock Grid.Row="2" Text="ESx: " Foreground="Blue" FontWeight="Bold" />
         <TextBlock Grid.Row="3" Text="ESy: " Foreground="Blue" FontWeight="Bold" />
         <TextBlock Grid.Row="4" Text="EIx: " Foreground="Blue" FontWeight="Bold" />
         <TextBlock Grid.Row="5" Text="EIy: " Foreground="Blue" FontWeight="Bold" />
         <TextBlock Grid.Row="6" Text="EIxy: " Foreground="Blue" FontWeight="Bold" />
         <TextBlock Grid.Row="7" Text="Xc: " Foreground="Blue" FontWeight="Bold" />
         <TextBlock Grid.Row="8" Text="Yc: " Foreground="Blue" FontWeight="Bold" />

         <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Unit_m2}" Foreground="Green" />
         </StackPanel>
         <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Unit_kN}" Foreground="Green" />
         </StackPanel>
         <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Unit_kNm}" Foreground="Green" />
         </StackPanel>
         <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Unit_kNm}" Foreground="Green" />
         </StackPanel>
         <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Unit_kNm2}" Foreground="Green" />
         </StackPanel>
         <StackPanel Grid.Row="5" Grid.Column="2" Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Unit_kNm2}" Foreground="Green" />
         </StackPanel>
         <StackPanel Grid.Row="6" Grid.Column="2" Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Unit_kNm2}" Foreground="Green" />
         </StackPanel>
         <StackPanel Grid.Row="7" Grid.Column="2" Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Unit_m}" Foreground="Green" />
         </StackPanel>
         <StackPanel Grid.Row="8" Grid.Column="2" Orientation="Horizontal">
            <TextBlock Text="{DynamicResource Unit_m}" Foreground="Green" />
         </StackPanel>
      </Grid>
   </GroupBox>
</UserControl>