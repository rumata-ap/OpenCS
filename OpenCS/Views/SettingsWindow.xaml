<Window x:Class="OpenCS.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Width="500" Height="680"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="0,0,0,5">
            <TabItem Header="Графики">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="Цвета и размеры" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="95"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="26"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                </Grid.RowDefinitions>

                <!-- Фон -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Фон" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="BgBox" Margin="2" Height="22"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                <Rectangle Grid.Row="0" Grid.Column="3" x:Name="BgSwatch" Margin="2" RadiusX="3" RadiusY="3"
                           Stroke="LightGray" StrokeThickness="1"/>

                <!-- Сетка -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Сетка" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="GridBox" Margin="2" Height="22"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                <Rectangle Grid.Row="1" Grid.Column="3" x:Name="GridSwatch" Margin="2" RadiusX="3" RadiusY="3"
                           Stroke="LightGray" StrokeThickness="1"/>

                <!-- Кривые -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Кривые" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="CurveBox" Margin="2" Height="22"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="2" x:Name="CurveThBox" Margin="2" Height="22"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ToolTip="Толщина, px"/>
                <Rectangle Grid.Row="2" Grid.Column="3" x:Name="CurveSwatch" Margin="2" RadiusX="3" RadiusY="3"
                           Stroke="LightGray" StrokeThickness="1"/>

                <!-- Заливка -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Заливка" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="FillBox" Margin="2" Height="22"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                <Rectangle Grid.Row="3" Grid.Column="3" x:Name="FillSwatch" Margin="2" RadiusX="3" RadiusY="3"
                           Stroke="LightGray" StrokeThickness="1"/>

                <!-- Маркеры -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Маркеры" VerticalAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="MarkerBox" Margin="2" Height="22"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="2" x:Name="MarkerSzBox" Margin="2" Height="22"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ToolTip="Размер, px"/>
                <Rectangle Grid.Row="4" Grid.Column="3" x:Name="MarkerSwatch" Margin="2" RadiusX="3" RadiusY="3"
                           Stroke="LightGray" StrokeThickness="1"/>

                <!-- Текст -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Текст" VerticalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="TextBoxField" Margin="2" Height="22"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="2" x:Name="FontSzBox" Margin="2" Height="22"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ToolTip="Размер шрифта меток"/>
                <Rectangle Grid.Row="5" Grid.Column="3" x:Name="TextSwatch" Margin="2" RadiusX="3" RadiusY="3"
                           Stroke="LightGray" StrokeThickness="1"/>

                <!-- Выделение -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Выделение" VerticalAlignment="Center"/>
                <TextBox Grid.Row="6" Grid.Column="1" x:Name="HighlightBox" Margin="2" Height="22"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                <Rectangle Grid.Row="6" Grid.Column="3" x:Name="HighlightSwatch" Margin="2" RadiusX="3" RadiusY="3"
                           Stroke="LightGray" StrokeThickness="1"/>

                <!-- Оси -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Оси" VerticalAlignment="Center"/>
                <TextBox Grid.Row="7" Grid.Column="1" x:Name="AxesColorBox" Margin="2" Height="22"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                <TextBox Grid.Row="7" Grid.Column="2" x:Name="AxesFontSzBox" Margin="2" Height="22"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ToolTip="Размер шрифта"/>
                <Rectangle Grid.Row="7" Grid.Column="3" x:Name="AxesColorSwatch" Margin="2" RadiusX="3" RadiusY="3"
                           Stroke="LightGray" StrokeThickness="1"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Палитра" Margin="0,0,0,10">
            <WrapPanel x:Name="PalettePanel" Margin="2" />
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Отображение" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="ShowGridCb" Content="Сетка" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="Толщина" VerticalAlignment="Center" FontSize="11" Margin="0,0,3,0"/>
                        <TextBox x:Name="GridThBox" Width="40" Height="22"
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                        <TextBlock Text="Засечек" VerticalAlignment="Center" FontSize="11" Margin="8,0,3,0"/>
                        <TextBox x:Name="TickCountBox" Width="40" Height="22"
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <CheckBox x:Name="ShowLabelsCb" Content="Подписи точек" Margin="0,3,0,0"/>
                <CheckBox x:Name="ShowTooltipsCb" Content="Выделение по клику" Margin="0,3,0,0"/>
                <CheckBox x:Name="ShowAxesValsCb" Content="Подписи значений на осях" Margin="0,3,0,0"/>
                <CheckBox x:Name="AxesOriginCb" Content="Оси через начало координат" Margin="0,3,0,0"/>
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Масштаб X" VerticalAlignment="Center" FontSize="11"/>
                    <TextBox Grid.Column="1" x:Name="ScaleXBox" Width="60" Height="22"
                             VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </Grid>
                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Масштаб Y" VerticalAlignment="Center" FontSize="11"/>
                    <TextBox Grid.Column="1" x:Name="ScaleYBox" Width="60" Height="22"
                             VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </Grid>
            </StackPanel>
        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
            <Button Content="По умолчанию" Click="Reset_Click" Width="110" Height="28" Margin="0,0,8,0"/>
            <Button Content="Применить" Click="Apply_Click" Width="90" Height="28" Margin="0,0,8,0" IsDefault="True"/>
            <Button Content="OK" Click="Ok_Click" Width="70" Height="28" Margin="0,0,8,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="70" Height="28" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
