<UserControl x:Class="OpenCS.Views.ShellStrainResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:OpenCS.Views.Helpers">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SummaryPanel" Margin="0,0,8,0">
                <TextBlock Text="{DynamicResource ShellStrainTitle}" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding TaskTag}"/>
                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" FontWeight="Bold"/>
                <TextBlock><Run Text="{DynamicResource ShellStrainIterations}"/><Run Text=": "/><Run Text="{Binding IterationsText}"/></TextBlock>
                <TextBlock><Run Text="{DynamicResource ShellStrainResidual}"/><Run Text=": "/><Run Text="{Binding ResidualText}"/></TextBlock>
                <TextBlock Text="{DynamicResource ShellStrainStrains}" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock><Run Text="ε₀x = "/><Run Text="{Binding Eps0xText}"/></TextBlock>
                <TextBlock><Run Text="ε₀y = "/><Run Text="{Binding Eps0yText}"/></TextBlock>
                <TextBlock><Run Text="γ₀xy = "/><Run Text="{Binding Gamma0xyText}"/></TextBlock>
                <TextBlock><Run Text="κx = "/><Run Text="{Binding KxText}"/></TextBlock>
                <TextBlock><Run Text="κy = "/><Run Text="{Binding KyText}"/></TextBlock>
                <TextBlock><Run Text="κxy = "/><Run Text="{Binding KxyText}"/></TextBlock>
                <TextBlock Text="{DynamicResource ShellStrainForces}" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock><Run Text="Nx = "/><Run Text="{Binding NxRow}"/></TextBlock>
                <TextBlock><Run Text="Ny = "/><Run Text="{Binding NyRow}"/></TextBlock>
                <TextBlock><Run Text="Nxy = "/><Run Text="{Binding NxyRow}"/></TextBlock>
                <TextBlock><Run Text="Mx = "/><Run Text="{Binding MxRow}"/></TextBlock>
                <TextBlock><Run Text="My = "/><Run Text="{Binding MyRow}"/></TextBlock>
                <TextBlock><Run Text="Mxy = "/><Run Text="{Binding MxyRow}"/></TextBlock>
                <TextBlock Text="{DynamicResource ShellStrainStiffness}" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock><Run Text="EAx = "/><Run Text="{Binding EAxText}"/></TextBlock>
                <TextBlock><Run Text="EAy = "/><Run Text="{Binding EAyText}"/></TextBlock>
                <TextBlock><Run Text="EIx = "/><Run Text="{Binding EIxText}"/></TextBlock>
                <TextBlock><Run Text="EIy = "/><Run Text="{Binding EIyText}"/></TextBlock>
                <TextBlock><Run Text="{DynamicResource ShellStrainZc}"/><Run Text=" = "/><Run Text="{Binding ZcText}"/></TextBlock>
            </StackPanel>
        </ScrollViewer>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <helpers:ThroughThicknessCanvas x:Name="EpsCanvas" Grid.Row="0" Margin="0,0,0,4"/>
            <helpers:ThroughThicknessCanvas x:Name="SigCanvas" Grid.Row="1" Margin="0,4,0,0"/>
        </Grid>
    </Grid>
</UserControl>
