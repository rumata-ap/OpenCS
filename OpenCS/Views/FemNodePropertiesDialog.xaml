<Window x:Class="OpenCS.Views.FemNodePropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FemNodePropsTitle}"
        Width="320" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <StackPanel Margin="12">
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource FemNodePropsTag}" Grid.Column="0"/>
            <TextBlock x:Name="tagText" Grid.Column="1" FontWeight="Bold"/>
        </Grid>
        <TextBlock Text="{DynamicResource FemNodePropsMembers}" Margin="0,8,0,2"/>
        <ListBox x:Name="membersList" MaxHeight="80" MouseDoubleClick="MembersList_DoubleClick"/>

        <TextBlock Text="{DynamicResource FemNodePropsDof}" Margin="0,8,0,2"/>
        <StackPanel Orientation="Horizontal">
            <CheckBox x:Name="txCheck" Content="Tx" Margin="0,0,8,0" Checked="Dof_Changed" Unchecked="Dof_Changed"/>
            <CheckBox x:Name="tyCheck" Content="Ty" Margin="0,0,8,0" Checked="Dof_Changed" Unchecked="Dof_Changed"/>
            <CheckBox x:Name="tzCheck" Content="Tz" Margin="0,0,8,0" Checked="Dof_Changed" Unchecked="Dof_Changed"/>
            <CheckBox x:Name="rxCheck" Content="Rx" Margin="0,0,8,0" Checked="Dof_Changed" Unchecked="Dof_Changed"/>
            <CheckBox x:Name="ryCheck" Content="Ry" Margin="0,0,8,0" Checked="Dof_Changed" Unchecked="Dof_Changed"/>
            <CheckBox x:Name="rzCheck" Content="Rz" Checked="Dof_Changed" Unchecked="Dof_Changed"/>
        </StackPanel>

        <Separator Margin="0,8"/>
        <TextBlock Text="{DynamicResource FemNodePropsLoadCase}" Margin="0,2"/>
        <ComboBox x:Name="loadCaseCombo" DisplayMemberPath="Tag" SelectionChanged="LoadCaseCombo_SelectionChanged"/>
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="fxBox" Grid.Column="0" Margin="1"/>
            <TextBox x:Name="fyBox" Grid.Column="1" Margin="1"/>
            <TextBox x:Name="fzBox" Grid.Column="2" Margin="1"/>
            <TextBox x:Name="mxBox" Grid.Column="3" Margin="1"/>
            <TextBox x:Name="myBox" Grid.Column="4" Margin="1"/>
            <TextBox x:Name="mzBox" Grid.Column="5" Margin="1"/>
        </Grid>
        <Button Content="{DynamicResource FemNodePropsApplyLoad}" Click="ApplyLoad_Click"/>
    </StackPanel>
</Window>
