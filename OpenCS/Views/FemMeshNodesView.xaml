<UserControl x:Class="OpenCS.Views.FemMeshNodesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
   <DataGrid x:Name="meshNodesGrid"
             AutoGenerateColumns="False"
             IsReadOnly="True"
             CanUserAddRows="False"
             CanUserDeleteRows="False"
             EnableRowVirtualization="True"
             VirtualizingPanel.IsVirtualizing="True">
      <DataGrid.Columns>
         <DataGridTextColumn Header="{DynamicResource FemNodeTag}" Binding="{Binding NodeTag}" Width="80"/>
         <DataGridTextColumn Header="X, м" Binding="{Binding X, StringFormat=F4}" Width="100"/>
         <DataGridTextColumn Header="Y, м" Binding="{Binding Y, StringFormat=F4}" Width="100"/>
         <DataGridTextColumn Header="Z, м" Binding="{Binding Z, StringFormat=F4}" Width="100"/>
         <DataGridTextColumn Header="{DynamicResource FemMeshSourceNodeTag}" Binding="{Binding SourceNodeTag}" Width="100"/>
         <DataGridTextColumn Header="{DynamicResource FemMeshSourceMemberTag}" Binding="{Binding SourceMemberTag}" Width="100"/>
      </DataGrid.Columns>
   </DataGrid>
</UserControl>
